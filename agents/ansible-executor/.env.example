# ============ NATS 配置 ============
# NATS 地址，支持逗号分隔多个地址（高可用）
NATS_SERVERS=nats://localhost:4222
# NATS 认证用户名（无认证可留空）
NATS_USERNAME=your_nats_username
# NATS 认证密码（无认证可留空）
NATS_PASSWORD=your_nats_password
# 连接协议：nats / tls
NATS_PROTOCOL=tls
# TLS 模式下的 CA 证书路径（NATS_PROTOCOL=tls 时建议必填）
NATS_TLS_CA_FILE=/path/to/ca.pem

# NATS 实例 ID（默认 default）
# 用于拼接 RPC subject，例如 ansible.playbook.{NATS_INSTANCE_ID}
NATS_INSTANCE_ID=default

# 连接超时（秒）
# NATS 建连超时，网络抖动环境可适当调大
NATS_CONNECT_TIMEOUT=5

# ============ Ansible 执行队列配置 ============
# 并行 worker 数量（控制同一时刻最多执行多少个任务）
ANSIBLE_MAX_WORKERS=4
# 回调 RPC 超时（秒），超过后进入 callback retry 队列
ANSIBLE_CALLBACK_TIMEOUT=10
# 任务工作目录（playbook/inventory 临时文件写入位置）
ANSIBLE_WORK_DIR=/tmp/ansible-executor

# ============ JetStream 任务队列配置（生产） ============
# 只需要配置一个命名空间，其余自动派生
# 命名空间用于隔离 stream/subject，避免和其他服务冲突
ANSIBLE_JS_NAMESPACE=bk.ans_exec

# 以下为高级覆盖项，通常不需要改
# ANSIBLE_JS_STREAM=BK_ANS_EXEC_TASKS
# ANSIBLE_JS_SUBJECT_PREFIX=bk.ans_exec.tasks
# ANSIBLE_JS_DURABLE=ansible-executor-default
# 单任务最大投递次数（达到后进入 DLQ）
ANSIBLE_JS_MAX_DELIVER=5
# 每次消费确认等待时间（秒），超时会触发重投递
ANSIBLE_JS_ACK_WAIT=300
# 重试退避（秒，逗号分隔），对应每次重试间隔
ANSIBLE_JS_BACKOFF=5,15,30,60
# 死信队列 subject（任务/回调重试最终失败后写入）
ANSIBLE_DLQ_SUBJECT=bk.ans_exec.tasks.dlq
# 本地任务状态存储（sqlite）路径，用于 task.query 与幂等
ANSIBLE_STATE_DB_PATH=/tmp/ansible-executor/task_state.db
