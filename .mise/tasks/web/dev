#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
WEB_DIR="${ROOT_DIR}/web"

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm 未安装。请先在本机安装并加入 PATH。"
  exit 1
fi

if [ ! -d "${WEB_DIR}" ]; then
  echo "未找到 web 目录: ${WEB_DIR}"
  exit 1
fi

cd "${WEB_DIR}"
pnpm dev
