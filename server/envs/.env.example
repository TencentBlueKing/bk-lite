DEBUG=True
SECRET_KEY=weops-lite

DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

ENABLE_CELERY=False
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_BEAT_SCHEDULER=

REDIS_CACHE_URL=

NATS_SERVERS=
NATS_NAMESPACE=

SNMP_TRAP_NATS_SUBJECT=vector
SNMP_TRAP_ALERTS_WEBHOOK_URL=http://127.0.0.1:8000/api/v1/alerts/api/source/snmp_trap/webhook/
SNMP_TRAP_ALERTS_SECRET=
SNMP_TRAP_ALERTS_TIMEOUT=10
SNMP_TRAP_ALERTS_MAX_RETRIES=3
SNMP_TRAP_PUSH_SOURCE_ID=snmp_trap_bridge

VICTORIALOGS_HOST=
VICTORIALOGS_USER=
VICTORIALOGS_PWD=
VICTORIALOGS_SSL_VERIFY=false
VICTORIALOGS_QUERY_LIMIT_MAX=1000
VICTORIALOGS_FIELD_VALUES_LIMIT_MAX=1000
VICTORIALOGS_HITS_FIELDS_LIMIT_MAX=100

# webhookd 渲染请求（log/monitor/cmdb K8s 接入，会下发 NATS 凭据）的 TLS 校验：
# 留空/true=校验系统CA（默认安全）；自签名内网填受信 CA 路径（如 /etc/ssl/webhook-ca.pem）；false=显式关闭（不推荐）
WEBHOOK_SERVER_SSL_VERIFY=true

# MLOps 批量预测上界校验（超出时返回 HTTP 413）
# 文本/时序/日志/异常检测类算法单次 predict 最大条目数（默认 10000）
MLOPS_PREDICT_MAX_BATCH_SIZE=10000
# 图像类算法单次 predict 最大图片数（默认 100）
MLOPS_PREDICT_MAX_IMAGE_BATCH_SIZE=100
# 图像类算法单张图片 base64 字符串最大字节数（默认 10 MiB）
MLOPS_PREDICT_MAX_IMAGE_BYTES=10485760

# ---- 告警处理动作回调地址（必填） ----
# 告警处理触发作业平台（JobMgmt）后，作业平台会通过 SELF_BASE_URL 反向回调 alerts 服务。
# 必须填写 alerts 服务对 job_mgmt 网络可达的入口（不要写 127.0.0.1，job_mgmt 的 SSRF 校验会拒绝 localhost）。
# 留空时：作业可执行但完成后不会回调，ActionExecution.status 会停在 running，不会自动更新为 success/failed。
# 示例（内网 IP）：
#   SELF_BASE_URL=http://10.11.27.147:8011
SELF_BASE_URL=

# 告警详情 → "查看作业" 链接拼到的前端入口。留空时只用相对路径（dev 可用，部署后端与前端不同地址时必须填写）。
# 示例：
#   WEB_BASE_URL=http://10.11.27.147:3000
WEB_BASE_URL=

CLIENT_ID=
