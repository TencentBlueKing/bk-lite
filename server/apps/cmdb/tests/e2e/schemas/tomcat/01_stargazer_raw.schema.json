{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer tomcat 采集原始输出契约",
  "description": "2026-07-10 G5.2.x — Phase 3 任务 3.3,tomcat 是 middleware runner,extra_payload_keys={\"result\":True}(业务字段经 metric.result JSON 编码)。stargazer raw_stdout 为形态 B(平铺 dict,无 success/result 包裹),公共契约 oneOf 已兼容。",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^tomcat$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "image":       {"type": "string"},
    "container_meta": {
      "type": "object",
      "properties": {
        "container_id": {"type": "string"},
        "image":        {"type": "string"}
      }
    },
    "params": {
      "type": "object",
      "properties": {
        "host":     {"type": "string"},
        "ssh_port": {"type": "integer"}
      }
    },
    "raw_stdout": {
      "type": "object",
      "required": ["inst_name", "obj_id", "ip_addr", "port", "version"],
      "properties": {
        "inst_name":      {"type": "string", "pattern": "^[0-9.]+-tomcat-[0-9]+$"},
        "obj_id":         {"type": "string", "pattern": "^tomcat$"},
        "ip_addr":        {"type": "string"},
        "port":           {"type": ["string", "integer"]},
        "catalina_path":  {"type": "string"},
        "version":        {"type": "string"},
        "xms":            {"type": ["string", "integer"]},
        "xmx":            {"type": ["string", "integer"]},
        "max_perm_size":  {"type": ["string", "integer"]},
        "permsize":       {"type": ["string", "integer"]},
        "log_path":       {"type": "string"},
        "java_version":   {"type": "string"}
      }
    }
  }
}
