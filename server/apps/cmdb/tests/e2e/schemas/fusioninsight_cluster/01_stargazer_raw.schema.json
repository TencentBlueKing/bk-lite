{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer fusioninsight_cluster 采集脚本原始输出",
  "description": "Task 3.3 真实化版本:fusioninsight 集群(参考华为云 FusionInsight 真实 API 响应)",
  "type": "object",
  "required": ["model_id", "resource_name", "resource_id"],
  "properties": {
    "model_id":         {"type": "string"},
    "task_id":          {"type": "integer"},
    "account_id":       {"type": "string"},
    "captured_at":      {"type": "string"},
    "collected_by":     {"type": "string"},
    "request_id":       {"type": "string"},
    "total_count":      {"type": "integer"},
    "resource_name":    {"type": "string"},
    "resource_id":      {"type": "string", "pattern": "^cluster-[a-zA-Z0-9]+$"},
    "create_time":      {"type": "string"}
  }
}
