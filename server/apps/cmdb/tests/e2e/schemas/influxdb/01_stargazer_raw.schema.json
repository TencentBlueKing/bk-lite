{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer influxdb 采集原始输出契约",
  "description": "2026-07-10 G5.2.1 — Phase 2.1 第一闭环,fixture 由 cli.py 真实落盘",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^influxdb$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["success", "result"],
      "properties": {
        "success": {"type": "boolean"},
        "result": {
          "type": "object",
          "required": ["influxdb"],
          "properties": {
            "influxdb": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["ip_addr", "port"],
                "properties": {
                  "ip_addr":       {"type": "string"},
                  "port":          {"type": ["string", "integer"]},
                  "version":       {"type": "string"},
                  "https_enabled": {"type": ["string", "boolean"]}
                }
              }
            }
          }
        }
      }
    }
  }
}