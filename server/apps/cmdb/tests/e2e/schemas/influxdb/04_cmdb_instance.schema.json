{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB influxdb 实例契约(流水线 step3 输出)",
  "description": "2026-07-10 G5.2.1 — Phase 2.1 第一闭环,fixture 由真实落盘数据驱动",
  "type": "object",
  "required": ["inst_name", "ip_addr", "port"],
  "properties": {
    "inst_name": {"type": "string", "pattern": "^[0-9.]+-influxdb-[0-9]+$"},
    "ip_addr":   {"type": "string"},
    "port":      {"type": ["string", "integer"]},
    "version":   {"type": "string"},
    "https_enabled": {"type": ["string", "boolean"]}
  }
}