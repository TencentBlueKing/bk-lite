{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer rocketmq 采集原始输出契约",
  "description": "2026-07-10 v4 — G4.9 placeholder 形态(JVM 启动阻塞,init 脚本模板填充);raw_stdout 走公共契约 raw_stdout_envelope_b 形态(无 success/result 包裹,业务字段平铺);字段集对齐 discover 脚本 plugins/inputs/rocketmq/rocketmq_default_discover.sh L55-L56 真实输出;middleware runner,extra_payload_keys={\"result\": True}",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^rocketmq$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["ip_addr", "port", "version"],
      "properties": {
        "bk_inst_name":  {"type": "string"},
        "bk_obj_id":     {"type": "string"},
        "ip_addr":       {"type": "string"},
        "port":          {"type": ["string", "integer"]},
        "version":       {"type": "string"},
        "install_path":  {"type": "string"},
        "configfile":    {"type": "string"},
        "broker_id":     {"type": ["string", "integer"]},
        "broker_name":   {"type": "string"},
        "cluster_name":  {"type": "string"},
        "namesrv_addr":  {"type": "string"},
        "java_path":     {"type": "string"}
      }
    }
  }
}
