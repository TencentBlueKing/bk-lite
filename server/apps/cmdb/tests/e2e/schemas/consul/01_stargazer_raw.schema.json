{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer consul 采集原始输出契约",
  "description": "2026-07-10 v4 Phase 4 任务 4.6 — fixture 由 stargazer cli 真实落盘(middleware runner,extra_payload_keys={\"result\":True})。raw_stdout 是形态 B(平铺 dict,无 success/result 包裹),与 nginx/rabbitmq/zookeeper 同构;公共契约 00_common_contract.schema.json 已 oneOf 兼容。",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^consul$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["ip_addr", "port", "version"],
      "properties": {
        "inst_name":    {"type": "string"},
        "bk_obj_id":    {"type": "string"},
        "ip_addr":      {"type": "string"},
        "port":         {"type": ["string", "integer"]},
        "install_path": {"type": "string"},
        "version":      {"type": "string"},
        "data_dir":     {"type": "string"},
        "conf_path":    {"type": "string"},
        "role":         {"type": "string"}
      }
    }
  }
}
