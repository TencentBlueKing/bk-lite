{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB hwcloud_vpc instance",
  "description": "Task 3.1 真实化版本:hwcloud_vpc CMDB 实例契约,字段对齐 plugin.field_mappings['hwcloud_vpc']",
  "type": "object",
  "required": ["inst_name", "resource_name", "resource_id", "cidr"],
  "properties": {
    "inst_name":     {"type": "string", "description": "{resource_name}_{resource_id} 格式"},
    "resource_name": {"type": "string"},
    "resource_id":   {"type": "string"},
    "region":        {"type": "string"},
    "status":        {"type": "string", "enum": ["ACTIVE", "PENDING", "DELETED", "ERROR"]},
    "cidr":          {"type": "string"},
    "is_default":    {"type": "string"},
    "assos":         {"type": ["array", "object"], "description": "belong hwcloud 关联"}
  }
}
