{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer redis 采集脚本原始输出",
  "type": "object",
  "required": ["ip_addr", "port", "version"],
  "properties": {
    "ip_addr":       {"type": "string"},
    "port":          {"type": "string", "pattern": "^[0-9]+$"},
    "version":       {"type": "string"},
    "install_path":  {"type": "string"},
    "max_conn":      {"type": "string", "pattern": "^[0-9]+$"},
    "max_mem":       {"type": "string", "pattern": "^[0-9]+$"},
    "database_role": {"type": "string", "enum": ["master", "slave"]},
    "topo_mode":     {"type": "string"},
    "cluster_uuid":  {"type": "string"},
    "slaves":        {"type": "string"},
    "master":        {"type": "string"}
  }
}
