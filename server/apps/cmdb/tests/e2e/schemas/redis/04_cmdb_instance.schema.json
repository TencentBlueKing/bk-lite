{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB redis instance",
  "type": "object",
  "required": ["inst_name", "ip_addr", "port"],
  "properties": {
    "inst_name":     {"type": "string", "pattern": "-redis-"},
    "ip_addr":       {"type": "string"},
    "port":          {"type": "string"},
    "version":       {"type": "string"},
    "install_path":  {"type": "string"},
    "max_conn":      {"type": "string"},
    "max_mem":       {"type": "string"},
    "database_role": {"type": "string"},
    "topo_mode":     {"type": "string"},
    "cluster_uuid":  {"type": "string"},
    "slaves":        {"type": "string"},
    "master":        {"type": "string"}
  }
}
