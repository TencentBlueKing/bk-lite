{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer server_bmc 采集原始输出契约(Redfish mock 真实数据)",
  "description": "2026-07-10 v4 — server_bmc 真实落盘,raw_stdout 含 1 实例(Redfish mock,https=true),CMDB 端暂无 plugin 走 placeholder 模式",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^server_bmc$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["success", "result"],
      "properties": {
        "success": {"type": "boolean"},
        "result": {
          "type": "object",
          "required": ["server_bmc"],
          "properties": {
            "server_bmc": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["ip_addr", "port"],
                "properties": {
                  "ip_addr":           {"type": "string"},
                  "port":              {"type": ["string", "integer"]},
                  "https_enabled":     {"type": ["string", "boolean"]},
                  "redfish_available": {"type": "boolean"}
                }
              }
            }
          }
        }
      }
    }
  }
}