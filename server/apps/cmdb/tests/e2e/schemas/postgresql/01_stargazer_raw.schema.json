{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer postgresql 采集原始输出契约",
  "description": "2026-07-10 v4 Phase 3.1 — fixture 由 stargazer cli 真实落盘",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^postgresql$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["success", "result"],
      "properties": {
        "success": {"type": "boolean"},
        "result": {
          "type": "object",
          "required": ["postgresql"],
          "properties": {
            "postgresql": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["ip_addr", "port", "version"],
                "properties": {
                  "inst_name":         {"type": "string"},
                  "ip_addr":           {"type": "string"},
                  "port":              {"type": ["string", "integer"]},
                  "version":           {"type": "string"},
                  "conf_path":         {"type": "string"},
                  "data_path":         {"type": "string"},
                  "max_conn":          {"type": ["string", "integer"]},
                  "cache_memory_mb":   {"type": ["string", "integer"]},
                  "log_path":          {"type": "string"}
                }
              }
            }
          }
        }
      }
    }
  }
}
