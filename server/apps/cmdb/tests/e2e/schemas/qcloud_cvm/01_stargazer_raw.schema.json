{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer qcloud_cvm 采集脚本原始输出(stargazer 端真实落盘形态)",
  "description": "Task 3.2 真实化版本:参考腾讯云 CVM DescribeInstances 真实 API 响应。",
  "type": "object",
  "required": ["model_id", "resource_name", "resource_id", "region", "status"],
  "properties": {
    "model_id":         {"type": "string"},
    "task_id":          {"type": "integer"},
    "account_id":       {"type": "string"},
    "captured_at":      {"type": "string"},
    "collected_by":     {"type": "string"},
    "request_id":       {"type": "string"},
    "total_count":      {"type": "integer"},
    "resource_name":    {"type": "string"},
    "resource_id":      {"type": "string", "pattern": "^ins-[a-zA-Z0-9]+$"},
    "ip_addr":          {"type": "string"},
    "public_ip":        {"type": "string"},
    "region":           {"type": "string", "pattern": "^[a-z]+-[a-z]+(-[0-9]+)?$"},
    "zone":             {"type": "string"},
    "vpc":              {"type": "string"},
    "subnet":           {"type": "string"},
    "status":           {"type": "string", "enum": ["RUNNING", "STOPPED", "STARTING", "STOPPING", "TERMINATED"]},
    "instance_type":    {"type": "string"},
    "charge_type":      {"type": "string", "enum": ["PREPAID", "POSTPAID_BY_HOUR", "CDHPAID", "SPOTPAID"]},
    "os_name":          {"type": "string"},
    "vcpus":            {"type": "string"},
    "memory_mb":        {"type": "string"},
    "image_id":         {"type": "string"},
    "security_group_ids": {"type": "string"},
    "create_time":      {"type": "string"},
    "expired_time":     {"type": "string"},
    "project_id":       {"type": "integer"},
    "host_name":        {"type": "string"},
    "description":      {"type": "string"}
  }
}
