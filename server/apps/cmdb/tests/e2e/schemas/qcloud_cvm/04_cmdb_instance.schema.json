{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB qcloud_cvm instance",
  "description": "Task 3.2 真实化版本:qcloud_cvm CMDB 实例契约,字段对齐 plugin.field_mappings['qcloud_cvm']",
  "type": "object",
  "required": ["inst_name", "resource_name", "resource_id"],
  "properties": {
    "inst_name":     {"type": "string", "description": "{resource_name}_{resource_id} 格式"},
    "resource_name": {"type": "string"},
    "resource_id":   {"type": "string"},
    "ip_addr":       {"type": "string"},
    "public_ip":     {"type": "string"},
    "region":        {"type": "string"},
    "zone":          {"type": "string"},
    "vpc":           {"type": "string"},
    "status":        {"type": "string"},
    "instance_type": {"type": "string"},
    "os_name":       {"type": "string"},
    "vcpus":         {"type": "integer"},
    "memory_mb":     {"type": "integer"},
    "charge_type":   {"type": "string"},
    "assos":         {"type": ["array", "object"]}
  }
}
