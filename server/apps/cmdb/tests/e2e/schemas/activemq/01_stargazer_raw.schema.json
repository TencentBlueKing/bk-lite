{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer activemq 采集原始输出契约",
  "description": "2026-07-10 v4 Phase 4 — fixture 由 stargazer cli 真实落盘(middleware runner,extra_payload_keys={\"result\": True})。raw_stdout 是形态 B(平铺 dict,无 success/result 包裹),与 nginx/rabbitmq 同构。",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^activemq$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["ip_addr", "port", "version"],
      "properties": {
        "inst_name":       {"type": "string"},
        "ip_addr":         {"type": "string"},
        "obj_id":          {"type": "string"},
        "port":            {"type": ["string", "integer"]},
        "web_port":        {"type": ["string", "integer"]},
        "web_reachable":   {"type": ["string", "boolean"]},
        "version":         {"type": "string"},
        "listening_ports": {"type": "string"},
        "bin_path":        {"type": "string"},
        "config":          {"type": "string"},
        "user":            {"type": "string"},
        "pid":             {"type": ["string", "integer"]}
      }
    }
  }
}