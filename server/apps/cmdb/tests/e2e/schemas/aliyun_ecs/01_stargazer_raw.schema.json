{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer aliyun ECS 采集脚本原始输出(stargazer 端真实落盘形态)",
  "description": "Task 2.1 真实化版本:扩到 100+ 行真实 ECS 样本,覆盖 plugin 复杂清洗路径(image_id / security_group / vswitch / bandwidth 等)。",
  "type": "object",
  "required": ["resource_name", "resource_id", "region", "status"],
  "properties": {
    "model_id":         {"type": "string"},
    "task_id":          {"type": "integer"},
    "account_id":       {"type": "string"},
    "captured_at":      {"type": "string"},
    "collected_by":     {"type": "string"},
    "request_id":       {"type": "string"},
    "total_count":      {"type": "integer"},
    "resource_name":    {"type": "string"},
    "resource_id":      {"type": "string", "pattern": "^i-[a-zA-Z0-9]+$"},
    "ip_addr":          {"type": "string"},
    "public_ip":        {"type": "string"},
    "region":           {"type": "string", "pattern": "^[a-z]+-[a-z]+$"},
    "region_id":        {"type": "string"},
    "zone":             {"type": "string"},
    "zone_id":          {"type": "string"},
    "vpc":              {"type": "string"},
    "vswitch":          {"type": "string"},
    "status":           {"type": "string", "enum": ["Running", "Stopped", "Starting", "Stopping"]},
    "instance_type":    {"type": "string"},
    "instance_type_family": {"type": "string"},
    "os_name":          {"type": "string"},
    "os_type":          {"type": "string"},
    "os_arch":          {"type": "string"},
    "vcpus":            {"type": "string"},
    "memory":           {"type": "string"},
    "gpu":              {"type": "string"},
    "charge_type":      {"type": "string", "enum": ["PrePaid", "PostPaid"]},
    "create_time":      {"type": "string"},
    "expired_time":     {"type": "string"},
    "image_id":         {"type": "string"},
    "image_name":       {"type": "string"},
    "security_group":   {"type": "string"},
    "security_group_ids": {"type": "string"},
    "instance_network_type": {"type": "string"},
    "internet_max_bandwidth_in":  {"type": "string"},
    "internet_max_bandwidth_out": {"type": "string"},
    "internet_charge_type": {"type": "string"},
    "host_name":        {"type": "string"},
    "serial_number":    {"type": "string"},
    "deployment_set_id": {"type": "string"},
    "dedicated_host_id":  {"type": "string"},
    "operation_locks":  {"type": "string"},
    "tag_env":          {"type": "string"},
    "tag_project":      {"type": "string"},
    "tag_owner":        {"type": "string"},
    "device_available": {"type": "string"},
    "io_optimized":     {"type": "string"},
    "network_type":     {"type": "string"},
    "nat_ip":           {"type": "string"},
    "eip_ip_address":   {"type": "string"},
    "eip_bandwidth":    {"type": "string"},
    "eip_allocation_id": {"type": "string"},
    "inner_ip_address": {"type": "string"},
    "spot_strategy":    {"type": "string"},
    "spot_price_limit": {"type": "string"},
    "credit_specification": {"type": "string"},
    "deletion_protection": {"type": "string"},
    "description":      {"type": "string"}
  }
}
