{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer hwcloud_ecs 采集脚本原始输出(stargazer 端真实落盘形态)",
  "description": "Task 3.1 真实化版本:参考华为云 ECS ListServersDetails 真实 API 响应,40+ 字段覆盖 image_id / security_group / eip 等 plugin 复杂清洗路径。",
  "type": "object",
  "required": ["model_id", "resource_name", "resource_id", "region", "status"],
  "properties": {
    "model_id":         {"type": "string"},
    "task_id":          {"type": "integer"},
    "account_id":       {"type": "string"},
    "captured_at":      {"type": "string"},
    "collected_by":     {"type": "string"},
    "request_id":       {"type": "string"},
    "total_count":      {"type": "integer"},
    "resource_name":    {"type": "string"},
    "resource_id":      {"type": "string", "pattern": "^ecs-[a-zA-Z0-9]+$"},
    "ip_addr":          {"type": "string"},
    "public_ip":        {"type": "string"},
    "region":           {"type": "string", "pattern": "^[a-z]+-[a-z]+-[0-9]+$"},
    "zone":             {"type": "string"},
    "vpc":              {"type": "string"},
    "subnet":           {"type": "string"},
    "status":           {"type": "string", "enum": ["ACTIVE", "SHUTOFF", "REBOOT", "HARD_REBOOT", "DELETED", "ERROR"]},
    "instance_type":    {"type": "string"},
    "os_name":          {"type": "string"},
    "os_type":          {"type": "string"},
    "os_arch":          {"type": "string"},
    "vcpus":            {"type": "string"},
    "memory_mb":        {"type": "string"},
    "gpu":              {"type": "string"},
    "charge_type":      {"type": "string", "enum": ["0", "1", "2"]},
    "create_time":      {"type": "string"},
    "expired_time":     {"type": "string"},
    "image_id":         {"type": "string"},
    "image_name":       {"type": "string"},
    "security_group":   {"type": "string"},
    "security_group_ids": {"type": "string"},
    "host_name":        {"type": "string"},
    "instance_network_type": {"type": "string"},
    "internet_max_bandwidth_in":  {"type": "string"},
    "internet_max_bandwidth_out": {"type": "string"},
    "internet_charge_type": {"type": "string"},
    "eip_ip_address":   {"type": "string"},
    "eip_bandwidth":    {"type": "string"},
    "eip_allocation_id": {"type": "string"},
    "inner_ip_address": {"type": "string"},
    "key_name":         {"type": "string"},
    "tenant_id":        {"type": "string"},
    "project_id":       {"type": "string"},
    "description":      {"type": "string"}
  }
}
