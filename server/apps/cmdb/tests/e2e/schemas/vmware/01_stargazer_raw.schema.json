{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer vmware_vc 采集脚本原始输出(真实形态,补 license / build / host 数等)",
  "description": "Task 2.3 真实化版本:扩到 30+ 行,覆盖 vCenter 真实采集器输出字段。",
  "type": "object",
  "required": ["inst_name", "vc_version"],
  "properties": {
    "model_id":         {"type": "string"},
    "task_id":          {"type": "integer"},
    "captured_at":      {"type": "string"},
    "collected_by":     {"type": "string"},
    "inst_name":        {"type": "string"},
    "instance_id":      {"type": "string"},
    "vc_version":       {"type": "string", "pattern": "^[0-9.]+$"},
    "vc_license":       {"type": "string"},
    "vc_build":         {"type": "string"},
    "vcenter_hostname": {"type": "string"},
    "datacenter_count": {"type": "string"},
    "cluster_count":    {"type": "string"},
    "host_count":       {"type": "string"},
    "vm_count":         {"type": "string"},
    "datastore_count":  {"type": "string"},
    "network_count":    {"type": "string"},
    "resource_pools":   {"type": "string"},
    "total_cpu_cores":  {"type": "string"},
    "total_memory_gb":  {"type": "string"},
    "tags":             {"type": ["string", "object"]}
  }
}
