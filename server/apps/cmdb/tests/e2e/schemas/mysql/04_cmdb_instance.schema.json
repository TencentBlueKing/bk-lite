{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB mysql 实例契约",
  "description": "2026-07-10 Phase 2.2 第二闭环,fixture 由真实落盘数据驱动",
  "type": "object",
  "required": ["inst_name", "ip_addr", "port"],
  "properties": {
    "inst_name": {"type": "string", "pattern": "^[0-9.]+-mysql-[0-9]+$"},
    "ip_addr":   {"type": "string"},
    "port":      {"type": ["string", "integer"]},
    "version":   {"type": "string"},
    "role":      {"type": "string"},
    "basedir":   {"type": "string"},
    "datadir":   {"type": "string"}
  }
}