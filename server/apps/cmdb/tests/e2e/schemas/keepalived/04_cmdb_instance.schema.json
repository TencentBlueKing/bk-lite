{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB keepalived 实例契约",
  "description": "2026-07-10 v4 — keepalived 不用 port,用 virtual_router_id",
  "type": "object",
  "required": ["inst_name", "ip_addr", "virtual_router_id"],
  "properties": {
    "inst_name":         {"type": "string", "pattern": "^[0-9.]+-keepalived-[0-9]+$"},
    "ip_addr":           {"type": "string"},
    "bk_obj_id":         {"type": "string"},
    "version":           {"type": "string"},
    "priority":          {"type": ["string", "integer"]},
    "state":             {"type": "string"},
    "virtual_router_id": {"type": ["string", "integer"]},
    "user_name":         {"type": "string"},
    "install_path":      {"type": "string"},
    "config_file":       {"type": "string"}
  }
}