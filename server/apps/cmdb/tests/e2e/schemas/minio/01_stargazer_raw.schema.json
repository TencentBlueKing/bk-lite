{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer minio 采集原始输出契约",
  "description": "2026-07-10 G5.2.x — Phase 4 任务 4.5,fixture 由 cli.py 真实落盘(middleware runner,extra_payload_keys={\"result\":True})",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^minio$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "object",
      "required": ["ip_addr", "port", "version"],
      "properties": {
        "bk_inst_name":  {"type": "string"},
        "bk_obj_id":     {"type": "string"},
        "ip_addr":       {"type": "string"},
        "port":          {"type": ["string", "integer"]},
        "console_port":  {"type": ["string", "integer"]},
        "version":       {"type": "string"},
        "bin_path":      {"type": "string"},
        "data_path":     {"type": "string"},
        "conf_path":     {"type": "string"},
        "deploy_mode":   {"type": "string"},
        "region":        {"type": "string"},
        "start_args":    {"type": "string"}
      }
    }
  }
}
