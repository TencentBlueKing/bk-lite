{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer nginx 采集脚本原始输出",
  "type": "object",
  "required": ["ip_addr", "port", "version"],
  "properties": {
    "ip_addr":     {"type": "string"},
    "port":        {"type": "string", "pattern": "^[0-9]+$"},
    "version":     {"type": "string"},
    "bin_path":    {"type": "string"},
    "log_path":    {"type": "string"},
    "conf_path":   {"type": "string"},
    "server_name": {"type": "string"},
    "include":     {"type": "string"},
    "ssl_version": {"type": "string"}
  }
}
