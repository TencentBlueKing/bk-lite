{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMDB nginx 实例契约",
  "description": "2026-07-10 Phase 2.3 第三闭环,fixture 由真实落盘数据驱动",
  "type": "object",
  "required": ["inst_name", "ip_addr", "port"],
  "properties": {
    "inst_name": {"type": "string", "pattern": "^[0-9.]+-nginx-[0-9]+$"},
    "ip_addr":   {"type": "string"},
    "port":      {"type": ["string", "integer"]},
    "version":   {"type": "string"},
    "bin_path":  {"type": "string"},
    "log_path":  {"type": "string"},
    "conf_path": {"type": "string"},
    "server_name": {"type": "string"},
    "include":     {"type": "string"},
    "ssl_version": {"type": "string"}
  }
}