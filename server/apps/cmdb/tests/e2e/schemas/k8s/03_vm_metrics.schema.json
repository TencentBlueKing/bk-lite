{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "K8s Stargazer 上报后 CMDB 从 VM 查到的 PromQL 响应（含 namespace/workload/node/pod）",
  "type": "object",
  "required": ["status", "data"],
  "properties": {
    "status": {"type": "string", "enum": ["success", "error"]},
    "data": {
      "type": "object",
      "required": ["resultType", "result"],
      "properties": {
        "resultType": {"type": "string", "enum": ["vector"]},
        "result": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "value"],
            "properties": {
              "metric": {
                "type": "object",
                "required": ["__name__", "instance_id"],
                "properties": {
                  "__name__":    {"type": "string", "pattern": "^prometheus_kube_"},
                  "instance_id": {"type": "string"}
                }
              },
              "value": {
                "type": "array",
                "items": [{"type": "number"}, {"type": "string"}],
                "minItems": 2, "maxItems": 2
              }
            }
          }
        }
      }
    }
  }
}
