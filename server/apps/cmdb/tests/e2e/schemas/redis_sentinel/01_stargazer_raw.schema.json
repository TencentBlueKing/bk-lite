{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stargazer redis_sentinel 采集原始输出契约",
  "description": "2026-07-10 v4 — redis_sentinel entry_type=shell(init_script=redis_sentinel_default_discover.sh),CMDB 端复用 redis plugin(model_id=redis),fixture 形态 C(list-of-dict,2 实例:redis 主 + sentinel 端口)",
  "type": "object",
  "required": ["model_id", "captured_at", "raw_stdout"],
  "properties": {
    "model_id":    {"type": "string", "pattern": "^redis_sentinel$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "raw_stdout": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["inst_name", "ip_addr", "port"],
        "properties": {
          "inst_name":     {"type": "string"},
          "bk_obj_id":     {"type": "string"},
          "ip_addr":       {"type": "string"},
          "port":          {"type": "string"},
          "version":       {"type": "string"},
          "install_path":  {"type": "string"},
          "max_conn":      {"type": ["string", "integer"]},
          "max_mem":       {"type": ["string", "integer"]},
          "database_role": {"type": "string"},
          "topo_mode":     {"type": "string"},
          "cluster_uuid":  {"type": "string"},
          "slaves":        {"type": "array"},
          "master":        {"type": "object"}
        }
      }
    }
  }
}