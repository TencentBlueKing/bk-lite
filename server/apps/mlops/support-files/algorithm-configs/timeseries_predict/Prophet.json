{
  "name": "Prophet",
  "display_name": "Prophet",
  "image": "bklite/classify_timeseries_server:latest",
  "scenario_description": "长期预测，适用于明显趋势和季节性。",
  "form_config": {
    "groups": {
      "hyperparams": [
        {
          "title": "基础配置",
          "fields": [
            {
              "name": [
                "hyperparams",
                "metric"
              ],
              "type": "select",
              "label": "优化指标",
              "options": [
                {
                  "label": "RMSE (均方根误差)",
                  "value": "rmse"
                },
                {
                  "label": "MAE (平均绝对误差)",
                  "value": "mae"
                },
                {
                  "label": "MAPE (平均绝对百分比误差)",
                  "value": "mape"
                }
              ],
              "required": true,
              "placeholder": "选择优化目标指标",
              "defaultValue": "rmse"
            },
            {
              "name": [
                "hyperparams",
                "growth"
              ],
              "type": "select",
              "label": "增长模式",
              "options": [
                {
                  "label": "线性增长 (linear)",
                  "value": "linear"
                },
                {
                  "label": "逻辑增长 (logistic)",
                  "value": "logistic"
                }
              ],
              "tooltip": "linear=线性增长(默认)，logistic=逻辑增长(需设置容量上限)",
              "required": true,
              "placeholder": "选择增长模式",
              "defaultValue": "linear"
            },
            {
              "name": [
                "hyperparams",
                "yearly_seasonality"
              ],
              "type": "select",
              "label": "年度季节性",
              "options": [
                {
                  "label": "自动 (auto)",
                  "value": "auto"
                },
                {
                  "label": "启用 (true)",
                  "value": "true"
                },
                {
                  "label": "禁用 (false)",
                  "value": "false"
                }
              ],
              "tooltip": "auto=自动检测（数据>=2年则启用），true=强制启用，false=禁用",
              "required": true,
              "placeholder": "选择年度季节性",
              "defaultValue": "auto"
            },
            {
              "name": [
                "hyperparams",
                "weekly_seasonality"
              ],
              "type": "select",
              "label": "周季节性",
              "options": [
                {
                  "label": "自动 (auto)",
                  "value": "auto"
                },
                {
                  "label": "启用 (true)",
                  "value": "true"
                },
                {
                  "label": "禁用 (false)",
                  "value": "false"
                }
              ],
              "tooltip": "auto=自动检测（数据>=2周则启用），日度数据建议启用",
              "required": true,
              "placeholder": "选择周季节性",
              "defaultValue": "auto"
            },
            {
              "name": [
                "hyperparams",
                "daily_seasonality"
              ],
              "type": "select",
              "label": "日季节性",
              "options": [
                {
                  "label": "自动 (auto)",
                  "value": "auto"
                },
                {
                  "label": "启用 (true)",
                  "value": "true"
                },
                {
                  "label": "禁用 (false)",
                  "value": "false"
                }
              ],
              "tooltip": "auto=自动检测，小时级数据建议启用，日度及以上数据建议禁用",
              "required": true,
              "placeholder": "选择日季节性",
              "defaultValue": "auto"
            },
            {
              "max": 100,
              "min": 0.01,
              "name": [
                "hyperparams",
                "seasonality_prior_scale"
              ],
              "step": 0.01,
              "type": "inputNumber",
              "label": "季节性强度",
              "tooltip": "季节性强度的先验尺度。越大=季节性波动越灵活，越小=越平滑保守",
              "required": true,
              "placeholder": "推荐范围: 0.01 - 10",
              "defaultValue": 10
            },
            {
              "max": 100,
              "min": 0.01,
              "name": [
                "hyperparams",
                "holidays_prior_scale"
              ],
              "step": 0.01,
              "type": "inputNumber",
              "label": "节假日强度",
              "tooltip": "节假日效应的先验尺度，仅在提供节假日数据时有效",
              "required": true,
              "placeholder": "推荐范围: 0.01 - 10",
              "defaultValue": 10
            },
            {
              "max": 200,
              "min": 1,
              "name": [
                "hyperparams",
                "n_changepoints"
              ],
              "type": "inputNumber",
              "label": "变点数量",
              "tooltip": "Prophet 自动在训练数据前 80% 均匀分布的潜在趋势变点数量",
              "required": true,
              "placeholder": "推荐: 10-50",
              "defaultValue": 25
            }
          ]
        },
        {
          "title": "搜索空间 (Search Space)",
          "fields": [
            {
              "name": [
                "hyperparams",
                "search_space",
                "seasonality_mode"
              ],
              "type": "stringArray",
              "label": "季节性模式",
              "tooltip": "additive=加性(趋势+季节性，波动固定)，multiplicative=乘性(趋势×季节性，波动随趋势变化)",
              "required": true,
              "placeholder": "例: additive,multiplicative",
              "defaultValue": "additive,multiplicative"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "changepoint_prior_scale"
              ],
              "type": "stringArray",
              "label": "变点灵活性",
              "tooltip": "最重要的超参数！控制趋势变化灵活度。大值(0.5)=灵活但易过拟合，小值(0.001)=平滑但可能欠拟合",
              "required": true,
              "placeholder": "例: 0.001,0.01,0.05,0.1,0.5",
              "defaultValue": "0.001,0.01,0.05,0.1,0.5"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "seasonality_prior_scale"
              ],
              "type": "stringArray",
              "label": "季节性强度搜索",
              "tooltip": "搜索最优的季节性强度（会覆盖上面的固定值）",
              "required": true,
              "placeholder": "例: 0.01,0.1,1.0,10.0",
              "defaultValue": "0.01,0.1,1.0,10.0"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "holidays_prior_scale"
              ],
              "type": "stringArray",
              "label": "节假日强度搜索",
              "tooltip": "搜索最优的节假日效应强度",
              "required": true,
              "placeholder": "例: 0.01,0.1,1.0,10.0",
              "defaultValue": "0.01,0.1,1.0,10.0"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "n_changepoints"
              ],
              "type": "stringArray",
              "label": "变点数量搜索",
              "tooltip": "搜索最优的变点数量（会覆盖上面的固定值）",
              "required": true,
              "placeholder": "例: 10,25,50,100",
              "defaultValue": "10,25,50,100"
            }
          ]
        }
      ],
      "preprocessing": [
        {
          "title": "数据预处理 (Preprocessing)",
          "fields": [
            {
              "name": [
                "preprocessing",
                "handle_missing"
              ],
              "type": "select",
              "label": "缺失值处理",
              "options": [
                {
                  "label": "线性插值 (interpolate)",
                  "value": "interpolate"
                },
                {
                  "label": "前向填充 (ffill)",
                  "value": "ffill"
                },
                {
                  "label": "后向填充 (bfill)",
                  "value": "bfill"
                },
                {
                  "label": "删除 (drop)",
                  "value": "drop"
                },
                {
                  "label": "中位数填充 (median)",
                  "value": "median"
                }
              ],
              "required": true,
              "placeholder": "选择缺失值处理方式",
              "defaultValue": "interpolate"
            },
            {
              "max": 1,
              "min": 0,
              "name": [
                "preprocessing",
                "max_missing_ratio"
              ],
              "step": 0.1,
              "type": "inputNumber",
              "label": "最大缺失率",
              "required": true,
              "placeholder": "0.0 - 1.0",
              "defaultValue": 0.3
            },
            {
              "min": 1,
              "name": [
                "preprocessing",
                "interpolation_limit"
              ],
              "type": "inputNumber",
              "label": "插值限制",
              "required": true,
              "placeholder": "最多填充的连续缺失点数",
              "defaultValue": 3
            }
          ]
        }
      ]
    }
  }
}