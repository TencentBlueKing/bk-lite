{
  "name": "XGBoost",
  "display_name": "XGBoost",
  "image": "bklite/classify_text_classification_server:latest",
  "scenario_description": "通用文本分类场景，适用于客户反馈分类、情感分析、意图识别、垃圾邮件过滤等多分类任务，支持中文文本的自动分词和特征提取。",
  "form_config": {
    "groups": {
      "hyperparams": [
        {
          "title": "基础配置",
          "fields": [
            {
              "name": [
                "hyperparams",
                "metric"
              ],
              "type": "select",
              "label": "优化指标",
              "options": [
                {
                  "label": "F1 Score (加权F1分数)",
                  "value": "f1_weighted"
                },
                {
                  "label": "F1 Macro (宏平均F1)",
                  "value": "f1_macro"
                },
                {
                  "label": "Accuracy (准确率)",
                  "value": "accuracy"
                }
              ],
              "tooltip": "当前后端实际支持：f1_weighted、f1_macro、accuracy",
              "required": true,
              "placeholder": "选择优化目标指标",
              "defaultValue": "f1_weighted"
            },
            {
              "name": [
                "hyperparams",
                "use_feature_engineering"
              ],
              "type": "switch",
              "label": "启用特征工程",
              "layout": "horizontal",
              "tooltip": "是否使用特征工程增强模型效果。建议开启以获得更好的性能",
              "defaultValue": true
            },
            {
              "max": 2147483647,
              "min": 0,
              "name": [
                "hyperparams",
                "random_state"
              ],
              "step": 1,
              "type": "inputNumber",
              "label": "随机种子",
              "tooltip": "设置随机种子以确保结果可复现",
              "required": true,
              "placeholder": "例: 42",
              "defaultValue": 42
            },
            {
              "max": 1000,
              "min": 0,
              "name": [
                "hyperparams",
                "max_evals"
              ],
              "step": 1,
              "type": "inputNumber",
              "label": "超参搜索次数",
              "tooltip": "Hyperopt 最大评估次数。设置为 0 时训练器会跳过超参数优化；train.json 默认值为 20",
              "required": true,
              "placeholder": "例: 20",
              "defaultValue": 20
            }
          ]
        },
        {
          "title": "搜索空间 (Search Space)",
          "fields": [
            {
              "name": [
                "hyperparams",
                "search_space",
                "n_estimators"
              ],
              "type": "stringArray",
              "label": "树的数量 (n_estimators)",
              "tooltip": "提升树的数量。更多的树可以提高性能但增加训练时间和过拟合风险",
              "required": true,
              "placeholder": "例: 50,100,200,300",
              "defaultValue": "50,100,200,300"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "max_depth"
              ],
              "type": "stringArray",
              "label": "最大树深度 (max_depth)",
              "tooltip": "树的最大深度。更深的树可以捕捉更复杂的模式，但容易过拟合",
              "required": true,
              "placeholder": "例: 3,5,7,10",
              "defaultValue": "3,5,7,10"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "learning_rate"
              ],
              "type": "stringArray",
              "label": "学习率 (learning_rate)",
              "tooltip": "每棵树的贡献权重。较小的学习率需要更多的树，但通常能获得更好的泛化性能",
              "required": true,
              "placeholder": "例: 0.01,0.05,0.1,0.2",
              "defaultValue": "0.01,0.05,0.1,0.2"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "subsample"
              ],
              "type": "stringArray",
              "label": "样本采样比例 (subsample)",
              "tooltip": "每棵树训练时随机采样的样本比例。<1.0 可以防止过拟合",
              "required": true,
              "placeholder": "例: 0.7,0.8,0.9,1.0",
              "defaultValue": "0.7,0.8,0.9,1.0"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "colsample_bytree"
              ],
              "type": "stringArray",
              "label": "特征采样比例 (colsample_bytree)",
              "tooltip": "每棵树训练时随机采样的特征比例。<1.0 可以增加模型的鲁棒性",
              "required": true,
              "placeholder": "例: 0.7,0.8,0.9,1.0",
              "defaultValue": "0.7,0.8,0.9,1.0"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "min_child_weight"
              ],
              "type": "stringArray",
              "label": "最小叶子节点权重 (min_child_weight)",
              "tooltip": "叶子节点所需的最小样本权重和。越大越保守，可以防止过拟合",
              "required": true,
              "placeholder": "例: 1,3,5",
              "defaultValue": "1,3,5"
            },
            {
              "name": [
                "hyperparams",
                "search_space",
                "gamma"
              ],
              "type": "stringArray",
              "label": "最小损失减少 (gamma)",
              "tooltip": "节点继续分裂所需的最小损失下降值。越大越保守，可以抑制过拟合",
              "required": true,
              "placeholder": "例: 0,0.1,0.2,0.3",
              "defaultValue": "0,0.1,0.2,0.3"
            }
          ],
          "subtitle": "XGBoost 超参数搜索范围"
        }
      ],
      "preprocessing": [
        {
          "title": "文本预处理 (Preprocessing)",
          "fields": [
            {
              "name": [
                "preprocessing",
                "jieba_mode"
              ],
              "type": "select",
              "label": "分词模式",
              "options": [
                {
                  "label": "精确模式 (precise)",
                  "value": "precise"
                },
                {
                  "label": "全模式 (full)",
                  "value": "full"
                },
                {
                  "label": "搜索引擎模式 (search)",
                  "value": "search"
                }
              ],
              "tooltip": "precise=精确切分（推荐），full=扫描所有可能词汇，search=适合搜索引擎",
              "required": true,
              "placeholder": "选择结巴分词模式",
              "defaultValue": "precise"
            },
            {
              "name": [
                "preprocessing",
                "remove_stopwords"
              ],
              "type": "switch",
              "label": "移除停用词",
              "layout": "horizontal",
              "tooltip": "移除无意义词汇，通常可以提升分类效果",
              "defaultValue": true
            },
            {
              "name": [
                "preprocessing",
                "remove_punctuation"
              ],
              "type": "switch",
              "label": "移除标点符号",
              "layout": "horizontal",
              "tooltip": "移除中英文标点符号。大多数文本分类场景建议开启",
              "defaultValue": true
            },
            {
              "max": 10000,
              "min": 1,
              "name": [
                "preprocessing",
                "min_length"
              ],
              "step": 1,
              "type": "inputNumber",
              "label": "最小文本长度",
              "tooltip": "文本长度小于该值时将被过滤",
              "required": true,
              "placeholder": "例: 2",
              "defaultValue": 2
            },
            {
              "max": 100000,
              "min": 1,
              "name": [
                "preprocessing",
                "max_length"
              ],
              "step": 1,
              "type": "inputNumber",
              "label": "最大文本长度",
              "tooltip": "文本长度大于该值时将被过滤",
              "required": true,
              "placeholder": "例: 1000",
              "defaultValue": 1000
            },
            {
              "name": [
                "preprocessing",
                "lowercase"
              ],
              "type": "switch",
              "label": "英文转小写",
              "layout": "horizontal",
              "tooltip": "对英文字符执行小写化处理",
              "defaultValue": true
            }
          ],
          "subtitle": "中文文本分词和清洗配置"
        }
      ],
      "feature_engineering": [
        {
          "title": "特征工程 (Feature Engineering)",
          "fields": [
            {
              "name": [
                "feature_engineering",
                "use_tfidf"
              ],
              "type": "switch",
              "label": "启用 TF-IDF",
              "layout": "horizontal",
              "tooltip": "TF-IDF（词频-逆文档频率）是经典的文本特征，通常效果良好",
              "defaultValue": true,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ]
              ]
            },
            {
              "name": [
                "feature_engineering",
                "use_statistical"
              ],
              "type": "switch",
              "label": "启用统计特征",
              "layout": "horizontal",
              "tooltip": "文本长度、词数比例等统计特征，可以作为辅助特征",
              "defaultValue": true,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ]
              ]
            }
          ],
          "subtitle": "文本特征提取配置"
        },
        {
          "title": "TF-IDF 配置",
          "fields": [
            {
              "max": 50000,
              "min": 100,
              "name": [
                "feature_engineering",
                "tfidf",
                "max_features"
              ],
              "type": "inputNumber",
              "label": "最大特征数",
              "tooltip": "保留的最大词汇数量。过大会增加维度和训练时间，过小会损失信息",
              "required": true,
              "placeholder": "推荐: 3000-10000",
              "defaultValue": 5000,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_tfidf"
                ]
              ]
            },
            {
              "max": 100,
              "min": 1,
              "name": [
                "feature_engineering",
                "tfidf",
                "min_df"
              ],
              "type": "inputNumber",
              "label": "最小文档频率",
              "tooltip": "词汇至少在多少个文档中出现才会被保留。可以过滤罕见词",
              "required": true,
              "placeholder": "推荐: 2-5",
              "defaultValue": 2,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_tfidf"
                ]
              ]
            },
            {
              "max": 1,
              "min": 0.1,
              "name": [
                "feature_engineering",
                "tfidf",
                "max_df"
              ],
              "step": 0.05,
              "type": "inputNumber",
              "label": "最大文档频率",
              "tooltip": "词汇在文档中出现频率的上限（比例）。可以过滤过于常见的词",
              "required": true,
              "placeholder": "0.1 - 1.0",
              "defaultValue": 0.95,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_tfidf"
                ]
              ]
            },
            {
              "name": [
                "feature_engineering",
                "tfidf",
                "ngram_range"
              ],
              "type": "stringArray",
              "label": "N-gram 范围",
              "tooltip": "N-gram 范围。[1,1]=单个词，[1,2]=单个词+双词组合",
              "required": true,
              "placeholder": "例: 1,2",
              "defaultValue": "1,2",
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_tfidf"
                ]
              ]
            },
            {
              "name": [
                "feature_engineering",
                "tfidf",
                "use_idf"
              ],
              "type": "switch",
              "label": "启用 IDF",
              "layout": "horizontal",
              "tooltip": "是否启用逆文档频率加权",
              "defaultValue": true,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_tfidf"
                ]
              ]
            },
            {
              "name": [
                "feature_engineering",
                "tfidf",
                "sublinear_tf"
              ],
              "type": "switch",
              "label": "次线性 TF 缩放",
              "layout": "horizontal",
              "tooltip": "使用 log(tf) 代替 tf，可以降低高频词的影响",
              "defaultValue": true,
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_tfidf"
                ]
              ]
            }
          ]
        },
        {
          "title": "统计特征配置",
          "fields": [
            {
              "name": [
                "feature_engineering",
                "statistical_features"
              ],
              "type": "multiSelect",
              "label": "统计特征列表",
              "options": [
                {
                  "label": "文本长度 (text_length)",
                  "value": "text_length"
                },
                {
                  "label": "分词数量 (token_count)",
                  "value": "token_count"
                },
                {
                  "label": "特殊字符比例 (special_char_ratio)",
                  "value": "special_char_ratio"
                },
                {
                  "label": "数字字符比例 (digit_ratio)",
                  "value": "digit_ratio"
                },
                {
                  "label": "平均词长 (avg_word_length)",
                  "value": "avg_word_length"
                }
              ],
              "required": true,
              "placeholder": "选择需要的统计特征",
              "defaultValue": [
                "text_length",
                "token_count",
                "special_char_ratio",
                "digit_ratio",
                "avg_word_length"
              ],
              "dependencies": [
                [
                  "hyperparams",
                  "use_feature_engineering"
                ],
                [
                  "feature_engineering",
                  "use_statistical"
                ]
              ]
            }
          ]
        }
      ]
    }
  }
}