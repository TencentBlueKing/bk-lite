# ================================== File Integrity Module 配置 ==================================
{% set _monitor_paths = monitor_paths | default(paths | default('/etc/passwd,/etc/shadow,/etc/sudoers')) %}
{% set _exclude_paths = exclude_paths | default('') %}
{% set _recursive_monitor = recursive_monitor | default(false) %}
{% set _hash_algorithm = hash_algorithm | default('sha256') %}

- module: file_integrity
  paths:
    {% if _monitor_paths is string %}
    {% for path in _monitor_paths.split(',') | map('trim') | reject('equalto', '') %}
    - {{ path }}
    {% endfor %}
    {% elif _monitor_paths %}
    {% for path in _monitor_paths %}
    - {{ path }}
    {% endfor %}
    {% else %}
    # 默认监控路径
    - /etc/passwd
    - /etc/shadow
    - /etc/sudoers
    {% endif %}

  recursive: {{ _recursive_monitor | lower }}
  scan_at_start: true
  scan_rate_per_sec: 50 MiB
  max_file_size: 100 MiB
  hash_types: [{{ _hash_algorithm }}]

  exclude_files:
    {% if _exclude_paths is string and _exclude_paths %}
    {% for path in _exclude_paths.split(',') | map('trim') | reject('equalto', '') %}
    - {{ path | to_json }}
    {% endfor %}
    {% elif _exclude_paths %}
    {% for path in _exclude_paths %}
    - {{ path | to_json }}
    {% endfor %}
    {% else %}
    - '(?i)\.sw[nop]$'  # vim swap files
    - '~$'              # backup files
    - '/\.git($|/)'     # git directories
    {% endif %}

  include_files: []

  fields:
    collector: "Auditbeat"
    collect_type: "file_integrity"
    instance_id: "{{ instance_id | default('default') }}"
    _msg: ""
  fields_under_root: true
