# ================================== Windows Event Log Configuration ==================================
{#- Security - 安全日志（身份验证、授权、审计） -#}
{%- if security_enabled | default(true) %}
- name: Security
  {%- if ignore_older %}
  ignore_older: {{ ignore_older }}
  {%- endif %}
  {%- if security_level %}
  level: {{ security_level }}
  {%- endif %}
  {%- if security_event_id %}
  event_id: {{ security_event_id }}
  {%- endif %}
  fields:
    collector: "Winlogbeat"
    collect_type: "winlogbeat"
    instance_id: "{{ instance_id | default('default') }}"
    _msg: ""
  fields_under_root: true
{%- endif %}
