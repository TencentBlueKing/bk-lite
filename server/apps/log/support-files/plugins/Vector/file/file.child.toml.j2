{% set component_suffix = ((config_id | default(instance_id, true)) | lower | replace('-', '_')) %}

# ====================================
# file 日志源（生产标准参数）
# ====================================
[sources.file_{{ component_suffix }}]
type = "file"
include = [{{ include | map('tojson') | join(', ') }}]
{% if exclude %}
exclude = [{{ exclude | map('tojson') | join(', ') }}]
{% endif %}
data_dir = "/opt/fusion-collectors"
{% if ignore_older_secs %}
ignore_older_secs = {{ ignore_older_secs }}
{% endif %}
{% if read_from %}
read_from = "{{ read_from }}"
{% endif %}
{% if encoding_charset %}
[sources.file_{{ component_suffix }}.encoding]
charset = "{{ encoding_charset }}"
{% endif %}

{% if multiline %}
# ====================================
# 多行日志处理
# ====================================
multiline.condition_pattern = '{{ multiline.condition_pattern }}'
multiline.mode = "{{ multiline.mode }}"
multiline.start_pattern = '{{ multiline.start_pattern }}'
multiline.timeout_ms = {{ multiline.timeout_ms }}
{% endif %}

{% set file_input = "file_" ~ component_suffix %}
{% if parser_type == "json" %}
# ====================================
# JSON message 解析（transform 层）
# ====================================
[transforms.file_parse_{{ component_suffix }}]
type = "remap"
inputs = ["file_{{ component_suffix }}"]
source = '''
parsed, err = parse_json(.message)
if err == null && is_object(parsed) {
  . = merge(., parsed)
}
'''
{% set file_input = "file_parse_" ~ component_suffix %}
{% endif %}

# ====================================
# enrich（字段补全）
# ====================================
[transforms.file_enrich_{{ component_suffix }}]
type = "remap"
inputs = ["{{ file_input }}"]
source = '''
.collector = "Vector"
.collect_type = "file"
.instance_id = "{{ instance_id }}"
.config_id = "{{ config_id | default('', true) }}"
'''

# ====================================
# sinks
# ====================================
[sinks.vmlogs_{{ component_suffix }}]
type = "nats"
inputs = ["file_enrich_{{ component_suffix }}"]
subject = "vector"
url = "${NATS_PROTOCOL}://${NATS_SERVERS}"

[sinks.vmlogs_{{ component_suffix }}.auth]
strategy = "user_password"

[sinks.vmlogs_{{ component_suffix }}.auth.user_password]
user = "${NATS_USERNAME}"
password = "${NATS_PASSWORD}"

{% if NATS_PROTOCOL == "tls" %}
# TLS 配置
[sinks.vmlogs_{{ component_suffix }}.tls]
enabled = true
verify_certificate = true
ca_file = "${NATS_TLS_CA_FILE}"
{% endif %}

[sinks.vmlogs_{{ component_suffix }}.encoding]
codec = "json"
