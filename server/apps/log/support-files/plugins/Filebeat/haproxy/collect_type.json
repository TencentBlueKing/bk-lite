{
  "name": "haproxy",
  "collector": "Filebeat",
  "config_section": "module",
  "icon": "haproxy",
  "description": "Collects and parses HAProxy log files using Filebeat module",
  "default_query": "collect_type: haproxy | last 1 by (_time) partition by (instance_id)",
  "attrs": [
    "collect_type",
    "collector",
    "instance_id",
    "haproxy.http.request.captured_cookie",
    "haproxy.http.request.captured_headers",
    "haproxy.http.request.raw_request_line",
    "haproxy.http.response.captured_cookie",
    "haproxy.http.response.captured_headers",
    "haproxy.backend_name",
    "haproxy.backend_queue",
    "haproxy.bytes_read",
    "haproxy.client.ip",
    "haproxy.client.port",
    "haproxy.connections.active",
    "haproxy.connections.backend",
    "haproxy.connections.frontend",
    "haproxy.connections.retries",
    "haproxy.connections.server",
    "haproxy.frontend_name",
    "haproxy.server_name",
    "haproxy.server_queue",
    "haproxy.source",
    "haproxy.termination_state",
    "haproxy.time.backend_connect",
    "haproxy.time.queue",
    "haproxy.time.response",
    "haproxy.time.server_response",
    "haproxy.time.total",
    "event.dataset",
    "event.module",
    "fileset.name"
  ]
}
