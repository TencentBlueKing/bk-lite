{
  "object_name": "Host",
  "instance_type": "os",
  "collect_type": "host",
  "config_type": [
    "cpu",
    "disk",
    "diskio",
    "mem",
    "net",
    "processes",
    "system",
    "gpu"
  ],
  "collector": "Telegraf",
  "config_type_field": "metric_type",
  "instance_id": "{{cloud_region}}_{{instance_type}}_{{ip}}",
  "form_fields": [
    {
      "name": "metric_type",
      "label": "指标类型",
      "type": "checkbox_group",
      "required": true,
      "editable": false,
      "default_value": [
        "cpu",
        "disk",
        "diskio",
        "mem",
        "net",
        "processes",
        "system"
      ],
      "options": [
        {
          "label": "CPU",
          "value": "cpu",
          "description": "监控CPU使用情况，包括利用率百分比、平均负载以及系统时间与用户时间的占比",
          "label_en": "CPU"
        },
        {
          "label": "Disk",
          "value": "disk",
          "description": "监控磁盘使用情况，包括磁盘空间、读/写速率以及其他相关指标",
          "label_en": "Disk"
        },
        {
          "label": "Disk IO",
          "value": "diskio",
          "description": "监控磁盘输入/输出操作的性能和活动情况",
          "label_en": "Disk IO"
        },
        {
          "label": "Memory",
          "value": "mem",
          "description": "监控内存使用情况，包括内存利用率和可用内存",
          "label_en": "Memory"
        },
        {
          "label": "Net",
          "value": "net",
          "description": "监控网络性能，包括网络流量、带宽使用率和延迟",
          "label_en": "Net"
        },
        {
          "label": "Processes",
          "value": "processes",
          "description": "监控运行进程的信息，包括进程数量、CPU 使用率和内存消耗",
          "label_en": "Processes"
        },
        {
          "label": "System",
          "value": "system",
          "description": "监控整体系统性能和运行状况，包括系统运行时间、平均负载以及一般活动水平等指标",
          "label_en": "System"
        },
        {
          "label": "Nvidia-GPU",
          "value": "gpu",
          "description": "监控Nvidia-GPU使用情况，包括利用率百分比、显存使用和温度等指标",
          "label_en": "Nvidia GPU"
        }
      ],
      "widget_props": {},
      "transform_on_edit": {
        "origin_path": "child.content.config.tags.config_type",
        "to_form": {
          "array": true
        }
      },
      "label_en": "Metric Type"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "change_handler": {
        "type": "option_field",
        "source_field": "name",
        "target_field": "instance_name"
      },
      "enable_row_filter": true,
      "label_en": "Node"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "is_only": true,
      "widget_props": {
        "placeholder": "实例名称",
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}