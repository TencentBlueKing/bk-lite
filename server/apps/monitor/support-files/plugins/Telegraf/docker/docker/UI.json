{
  "object_name": "Docker",
  "instance_type": "docker",
  "collect_type": "docker",
  "config_type": [
    "docker"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_docker_{{endpoint}}",
  "form_fields": [
    {
      "name": "endpoint",
      "label": "端点",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "监控的Docker容器所在主机的网络地址，用于准确定位和采集性能数据",
      "widget_props": {
        "placeholder": "Docer守护进程连接地址，默认为 unix:///var/run/docker.sock"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.endpoint"
      },
      "label_en": "Endpoint"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "endpoint",
      "label": "端点",
      "type": "input",
      "required": true,
      "default_value": "unix:///var/run/docker.sock",
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "endpoint"
        ],
        "target_field": "instance_name"
      },
      "widget_props": {
        "placeholder": "Docer守护进程连接地址，默认为 unix:///var/run/docker.sock"
      },
      "label_en": "Endpoint"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ],
  "extra_edit_fields": {}
}