[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_watchguard"
        config_type = "watchguard"
        brand = "watchguard"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- WatchGuard CPU usage (WATCHGUARD-SYSTEM-STATISTICS-MIB wgSystemCpuUtil, scalar %) ----
    # 来源：LibreNMS fireware + WATCHGUARD-SYSTEM-STATISTICS-MIB（wgSystemStatisticsMIB=1.3.6.1.4.1.3097.6.3）。待现网核验。
    # 待现网核验：1.3.6.1.4.1.3097.6.3.4.0（已是 0-100%）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3097.6.3.4.0"
        name = "usage"
    # ---- WatchGuard firewall-specific (current active connections, scalar) ----
    # 待现网核验：wgSystemCurrActiveConns 1.3.6.1.4.1.3097.6.3.80.0。
    [[inputs.snmp.table]]
        name = "firewall"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3097.6.3.80.0"
        name = "active_connections"
# ---- 内存/温度/风扇/电源：WatchGuard Fireware SNMP 无标准内存利用率标量(仅 HOST-RESOURCES hrStorage ----
# ---- 需按 hrStorageDescr 行级匹配内存行)、亦无标准传感器表 → telegraf inputs.snmp 不能行级过滤 → 标 N/A 不采。----
# ---- VPN 隧道走 WATCHGUARD-IPSEC-TUNNEL-MIB per-tunnel walk 表(非单标量),本轮不做。----
