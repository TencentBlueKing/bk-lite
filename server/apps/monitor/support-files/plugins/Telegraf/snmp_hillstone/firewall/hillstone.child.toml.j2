[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_hillstone"
        config_type = "hillstone"
        brand = "hillstone"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Hillstone CPU (HILLSTONE-SYSTEM-MIB sysCPU, %, scalar, PEN 28557) ----
    # 待现网核验：sysCPU 1.3.6.1.4.1.28557.2.2.1.3.0（CPU 使用率%，snmprec=55；LibreNMS stoneos os_discovery 用此 OID）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.28557.2.2.1.3.0"
        name = "usage"
    # ---- Hillstone memory (HILLSTONE-SYSTEM-MIB sysMemTotal/sysMemUsed, KB, scalar) ----
    # 待现网核验：total 1.3.6.1.4.1.28557.2.2.1.4.0（KB，snmprec 8388608=8GB）/ used ...2.2.1.5.0（KB，snmprec 1444687）。
    # 利用率 100*used/total；绝对量 query *1024 转字节。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.28557.2.2.1.4.0"
        name = "total"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.28557.2.2.1.5.0"
        name = "used"
    # ---- Hillstone temperature (HILLSTONE-TEMPERATURE-MIB, °C, dedicated per-sensor table) ----
    # 待现网核验：温度值列 1.3.6.1.4.1.28557.2.28.1.2.1.3（每传感器°C；名列 ...1.2=CPU/Chassis_Inlet/Outlet/Switch 等）。专用温度表 → max() by instance_id。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.28557.2.28.1.2.1.3"
        name = "celsius"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.28557.2.28.1.2.1.2"
        name = "tempName"
        is_tag = true
    # ---- Hillstone PSU (HILLSTONE-POWER-MIB hillstonePowerStatus, per-supply table) ----
    # 待现网核验：电源状态列 1.3.6.1.4.1.28557.2.27.1.2.1.3（原始码 fine(0)/absent(1)/warning(2)/fail(3)/failOrNopower(4)/unsupport(5)）。
    # 下方 processors.enum 归一为 1=正常(0 fine / 1 absent 空位忽略)/2=异常(2/3/4/5)。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.28557.2.27.1.2.1.3"
        name = "state"
# ---- 电源状态归一：fine(0)→1(正常)，absent(1,空位)→1(忽略)，warning(2)/fail(3)/failOrNopower(4)/unsupport(5)→2(异常)。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
            "1" = 1
# ---- 会话数/风扇：Hillstone 会话计数未在 LibreNMS 源确认数字 OID;风扇 HILLSTONE-FAN-MIB 测试 snmprec 未实例化 → 会话/风扇 N/A 待现网核验。----
