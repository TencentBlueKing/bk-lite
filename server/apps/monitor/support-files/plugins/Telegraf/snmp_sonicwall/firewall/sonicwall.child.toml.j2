[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_sonicwall"
        config_type = "sonicwall"
        brand = "sonicwall"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- SonicWALL CPU usage (SONICWALL-FIREWALL-IP-STATISTICS-MIB sonicCurrentCPUUtil, scalar %) ----
    # 来源：LibreNMS Sonicwall + SONICWALL-FIREWALL-IP-STATISTICS-MIB（sonicwallFwStats=1.3.6.1.4.1.8741.1.3.1）。待现网核验。
    # 待现网核验：1.3.6.1.4.1.8741.1.3.1.3.0（已是 0-100%）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.8741.1.3.1.3.0"
        name = "usage"
    # ---- SonicWALL memory usage (sonicCurrentRAMUtil, scalar %, 设备直接上报使用率) ----
    # 待现网核验：1.3.6.1.4.1.8741.1.3.1.4.0（已是 0-100%）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.8741.1.3.1.4.0"
        name = "usage"
    # ---- SonicWALL firewall-specific (connection cache + NAT translations, scalars) ----
    # 待现网核验：sonicCurrentConnCacheEntries 1.3.6.1.4.1.8741.1.3.1.2.0；sonicMaxConnCacheEntries ...1.1.0；
    #            sonicNatTranslationCount 1.3.6.1.4.1.8741.1.3.1.5.0。
    [[inputs.snmp.table]]
        name = "firewall"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.8741.1.3.1.2.0"
        name = "current_connections"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.8741.1.3.1.1.0"
        name = "max_connections"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.8741.1.3.1.5.0"
        name = "nat_translations"
