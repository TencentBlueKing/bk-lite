[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_netgear"
        config_type = "netgear"
        brand = "netgear"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Netgear CPU utilization (FASTPATH private, scalar %) ----
    # 待现网核验：1.3.6.1.4.1.4526.10.1.1.4.9.0（已是 0-100%）。用 table(measurement=device_cpu)+field usage → 指标 device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.4526.10.1.1.4.9.0"
        name = "usage"
    # ---- Netgear system memory (FASTPATH, available/free + total, bytes) ----
    # 待现网核验：free(available) 1.3.6.1.4.1.4526.10.1.1.5.1.0；total ...1.5.2.0 → device_memory_free/device_memory_total。
    # 利用率在共享盘按 (total-free)/total 计算。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.4526.10.1.1.5.1.0"
        name = "free"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.4526.10.1.1.5.2.0"
        name = "total"
    # ---- Netgear temperature (FASTPATH boxServicesTempSensorTemperature, °C) ----
    # 待现网核验：温度 1.3.6.1.4.1.4526.10.43.1.8.1.5（模版单位 °C，无需换算；无独立 descr 名列，省略 descr）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.4526.10.43.1.8.1.5"
        name = "celsius"
    # ---- Netgear fans (FASTPATH boxServicesFanItemState) ----
    # 待现网核验：风扇状态 1.3.6.1.4.1.4526.10.43.1.6.1.3（无独立 descr 名列，省略 descr）。
    # 枚举 1 operational(正常) / 2 failed / 3 powering / 4 notpowering / 5 notpresent。**原生 1=normal，无需 remap**（偏离 1 即异常）。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.4526.10.43.1.6.1.3"
        name = "state"
    # ---- Netgear power supplies (FASTPATH boxServicesPowSupplyItemState) ----
    # 待现网核验：电源状态 1.3.6.1.4.1.4526.10.43.1.7.1.3（无独立 descr 名列，省略 descr）。
    # 枚举 1 operational(正常) / 2 failed / 3 powering / 4 notpowering / 5 notpresent。**原生 1=normal，无需 remap**。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.4526.10.43.1.7.1.3"
        name = "state"

# ---- 枚举归一：Netgear FASTPATH boxServices*ItemState → 统一 1=normal/2=abnormal（偏离1即异常）----
# 待现网核验：仅作用于本品牌(tagpass brand=netgear)。原生 1=operational=normal 已对齐，
# 但为与其它品牌一致地保证 1=normal/2=abnormal（其余 2 failed/3 powering/4 notpowering/5 notpresent→2），
# 统一用 processors.enum 归一（1→1，default 2），不依赖原生编码。
[[processors.enum]]
    [processors.enum.tagpass]
        brand = ["netgear"]
    [[processors.enum.mapping]]
        field = "device_fan_state"
        dest = "device_fan_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
    [[processors.enum.mapping]]
        field = "device_psu_state"
        dest = "device_psu_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
