{
  "object_name": "Storage",
  "instance_type": "storage",
  "collect_type": "pure",
  "config_type": ["pure"],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_storage_pure_{{base_url}}",
  "form_fields": [
    {
      "name": "base_url",
      "label": "API连接地址",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "Pure Storage FlashArray REST API 连接地址（含协议和端口）",
      "widget_props": {
        "placeholder": "https://pure.example.com"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.base_url"
      }
    },
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": true,
      "editable": false,
      "description": "REST API 登录用户名",
      "widget_props": {
        "placeholder": "用户名"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.username"
      }
    },
    {
      "name": "password",
      "label": "密码",
      "type": "password",
      "required": true,
      "editable": false,
      "description": "对应的登录密码",
      "widget_props": {
        "placeholder": "密码"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.password"
      }
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 10,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      }
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点"
      },
      "enable_row_filter": false
    },
    {
      "name": "base_url",
      "label": "API连接地址",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "https://pure.example.com"
      },
      "change_handler": {
        "type": "simple",
        "source_fields": ["base_url"],
        "target_field": "instance_name"
      }
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false
      }
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组"
      }
    }
  ],
  "extra_edit_fields": {}
}
