[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_advantech"
        config_type = "advantech"
        brand = "advantech"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Advantech EKI redundant-power LED state (ADVANTECH-EKI-PRONEER-MIB ledPWR1Status, scalar, PEN 10297) ----
    # 待现网核验：标量 OID 1.3.6.1.4.1.10297.202.7000.1.1.14.3.0（ledStatus 组）。原始码 0=notSupported / 1=up(电源在位/正常) / 2=down(电源输入丢失)。
    # 下方 processors.enum 归一为 1=正常/2=异常（0 notSupported 与 1 up→正常,2 down→异常）。
    # 注：另有 ledPWR2Status ...14.4.0(第二路电源),标量无法与 PWR1 同名分行,本插件取 PWR1 主电源；PWR2 略。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.10297.202.7000.1.1.14.3.0"
        name = "state"
# ---- 电源 LED 归一：0=notSupported / 1=up→1(正常)，2=down→2(异常)。共享盘 device_psu_state 约定 1=正常,>1=异常。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
            "1" = 1
# ---- CPU/内存/温度/风扇：N/A 不采。----
# ---- EKI ProView MIB 无 CPU、无内存、无数值温度对象（仅 ledTempStatus ...14.9.0 为 0/1/2 LED 枚举非摄氏度数值）；EKI 为无风扇工业交换机，无风扇对象。故 CPU/内存/温度/风扇 → N/A。----
