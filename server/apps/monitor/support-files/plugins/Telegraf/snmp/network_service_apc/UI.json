{
  "object_name": "NetworkService",
  "instance_type": "network_service",
  "collect_type": "snmp_apc",
  "config_type": [
    "apc"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{instance_type}}_snmp_apc_{{ip}}",
  "form_fields": [
    {
      "name": "ip",
      "label": "IP",
      "type": "input",
      "required": true,
      "label_en": "IP"
    },
    {
      "name": "port",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "default_value": 161,
      "label_en": "Port"
    },
    {
      "name": "version",
      "label": "版本",
      "type": "select",
      "required": true,
      "default_value": 2,
      "options": [
        {
          "label": "v2c",
          "value": 2,
          "label_en": "v2c"
        },
        {
          "label": "v3",
          "value": 3,
          "label_en": "v3"
        }
      ],
      "label_en": "Version"
    },
    {
      "name": "community",
      "label": "团体名",
      "type": "input",
      "required": true,
      "default_value": "public",
      "label_en": "Community"
    },
    {
      "name": "sec_name",
      "label": "名称",
      "type": "input",
      "required": true,
      "label_en": "Name"
    },
    {
      "name": "sec_level",
      "label": "级别",
      "type": "select",
      "required": true,
      "default_value": "authPriv",
      "options": [
        {
          "label": "noAuthNoPriv",
          "value": "noAuthNoPriv",
          "label_en": "noAuthNoPriv"
        },
        {
          "label": "authNoPriv",
          "value": "authNoPriv",
          "label_en": "authNoPriv"
        },
        {
          "label": "authPriv",
          "value": "authPriv",
          "label_en": "authPriv"
        }
      ],
      "label_en": "Level"
    },
    {
      "name": "auth_protocol",
      "label": "认证协议",
      "type": "input",
      "required": false,
      "default_value": "SHA",
      "label_en": "Auth Protocol"
    },
    {
      "name": "ENV_AUTH_PASSWORD",
      "label": "认证密码",
      "type": "password",
      "required": false,
      "label_en": "Auth Password"
    },
    {
      "name": "priv_protocol",
      "label": "加密协议",
      "type": "input",
      "required": false,
      "default_value": "AES",
      "label_en": "Privacy Protocol"
    },
    {
      "name": "ENV_PRIV_PASSWORD",
      "label": "加密密码",
      "type": "password",
      "required": false,
      "label_en": "Privacy Password"
    },
    {
      "name": "timeout",
      "label": "超时时间",
      "type": "inputNumber",
      "required": true,
      "default_value": 10,
      "label_en": "Timeout"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "label_en": "Interval"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "options_key": "node_ids_option",
      "label_en": "Node"
    },
    {
      "name": "ip",
      "label": "IP",
      "type": "input",
      "label_en": "IP"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": true,
      "label_en": "Group"
    }
  ]
}