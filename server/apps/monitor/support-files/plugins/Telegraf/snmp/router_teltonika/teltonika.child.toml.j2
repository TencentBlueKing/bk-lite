[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_teltonika"
        config_type = "teltonika"
        brand = "teltonika"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Teltonika RutOS CPU usage (HOST-RESOURCES hrProcessorLoad, per-core %, headline avg by instance) ----
    # 来源：RutOS 为 Linux + net-snmp，标准 HOST-RESOURCES。待现网核验。
    # 待现网核验：1.3.6.1.2.1.25.3.3.1.2（每核 0-100%，共享盘 avg by instance_id 取整机均值）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.25.3.3.1.2"
        name = "usage"
    # ---- Teltonika RutOS memory (UCD-SNMP-MIB, total + free, KB; usage=100*(total-free)/total) ----
    # 待现网核验：memTotalReal 1.3.6.1.4.1.2021.4.5.0；memAvailReal 1.3.6.1.4.1.2021.4.6.0（均为 KB，共享盘 *1024 转字节）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2021.4.5.0"
        name = "total"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2021.4.6.0"
        name = "free"
# ---- 温度/风扇/电源：Teltonika RUT 系列蜂窝路由器为无风扇紧凑型工业设计，未以标量形式暴露温度/电源传感器 → 温度/风扇/电源 N/A 不采。仅 CPU/内存/接口干净可采。----
