{
  "object": "NetworkService",
  "plugin": "NetworkService Gigamon SNMP",
  "templates": [
    {
      "name": "Gigamon网络服务CPU使用率过高",
      "alert_name": "网络服务${resource_name} CPU 使用率过高",
      "description": "监控 Gigamon GigaVUE 可视化节点的整机 CPU 使用率，当持续高于阈值时触发告警，提示流量转发与过滤处理负载过高的风险。",
      "metric_name": "device_cpu_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "Gigamon网络服务内存使用率过高",
      "alert_name": "网络服务${resource_name} 内存使用率过高",
      "description": "监控 Gigamon GigaVUE 可视化节点的系统内存使用率，当超过阈值时触发告警，便于及时发现映射/流表内存压力。",
      "metric_name": "device_memory_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    }
  ]
}
