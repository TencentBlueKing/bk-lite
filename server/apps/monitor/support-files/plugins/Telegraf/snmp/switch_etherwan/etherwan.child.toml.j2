[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_etherwan"
        config_type = "etherwan"
        brand = "etherwan"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- EtherWAN chassis temperature (ewnSensorTempValue, 私有树 PEN 2736, scalar) ----
    # 待现网核验：标量 OID 1.3.6.1.4.1.2736.1.1.15.2.12.0（原始值 ÷10 = 摄氏度，如 255 → 25.5°C）。
    # 单位门控 ewnSensorTempUnit ...15.2.11.0 = celsius(0)/fahrenheit(1)，本插件按出厂默认摄氏度采集。
    # metrics.json 查询用 /10 还原摄氏度，device_temperature_celsius max() by instance_id。温度传感器为 SKU 选配，无传感器机型该标量缺省，max() 自然跳过。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2736.1.1.15.2.12.0"
        name = "celsius_raw"
    # ---- EtherWAN 双路电源输入状态 (ewnPowerSupplyTable ewnPowerSupplyStatus, 每路一行, table) ----
    # 待现网核验：列 OID 1.3.6.1.4.1.2736.1.1.21.1.1.4（原始码 0=up 正常/1=down 失电或缺省），行名 ewnPowerSupplyName ...21.1.1.2（Power1/Power2）。
    # 下方 processors.enum 归一为 1=正常/2=异常（0 up→1，1 down→2）。共享盘 device_psu_state 约定 1=正常,>1=异常，故 max() by instance_id 取最差电源行。
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.2736.1.1.21"
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2736.1.1.21.1.1.2"
        name = "psuName"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2736.1.1.21.1.1.4"
        name = "state"
# ---- 电源状态归一：0=up(正常)→1(正常)，1=down(失电/缺省)→2(异常)，其余未知码 default=2。----
# ---- 共享盘 device_psu_state 约定 1=正常,>1=异常。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
            "1" = 2
# ---- CPU/内存/风扇：ADVANTECH-EKI 同类工业交换机族外，EtherWAN EX 系列私有 MIB（PEN 2736）无 CPU、无内存、无风扇对象（EX 系列为无风扇导热式被动散热），故 CPU/内存/风扇 N/A 不采。----
