{
  "object": "Router",
  "plugin": "Router Digi SNMP",
  "templates": [
    {
      "name": "Digi路由器CPU使用率过高",
      "alert_name": "路由器${resource_name} CPU 使用率过高",
      "description": "监控 Digi 工业蜂窝路由器的 CPU 使用率，当持续高于阈值时触发告警，提示可能存在控制平面过载、VPN/转发压力或异常流量，避免管理响应变慢或转发受影响。",
      "metric_name": "device_cpu_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ]
    },
    {
      "name": "Digi路由器内存使用率过高",
      "alert_name": "路由器${resource_name} 内存使用率过高",
      "description": "监控 Digi 工业蜂窝路由器的内存使用率，当持续高于阈值时触发告警，提示可能存在内存泄漏或资源紧张，避免设备稳定性下降。",
      "metric_name": "device_memory_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">"
        },
        {
          "level": "error",
          "value": 90,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">"
        }
      ]
    },
    {
      "name": "Digi路由器温度过高",
      "alert_name": "路由器${resource_name} 温度过高",
      "description": "监控 Digi 工业蜂窝路由器的机箱温度，当持续高于阈值时触发告警，提示可能存在散热不良或环境温度过高，避免器件过热损坏。",
      "metric_name": "device_temperature_celsius",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 75,
          "method": ">"
        },
        {
          "level": "error",
          "value": 65,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 60,
          "method": ">"
        }
      ]
    }
  ]
}
