[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_nec"
        config_type = "nec"
        brand = "nec"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- NEC UNIVERGE IX CPU (PRIVATE PEN 119, CPU Utilization 1min, 直接%, scalar) ----
    # 待现网核验：1.3.6.1.4.1.119.2.3.84.2.5.3.0（1 分钟 CPU 使用率%，NEC community univerge_ix 模板 units='%'）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.119.2.3.84.2.5.3.0"
        name = "usage"
    # ---- NEC memory (PEN 119, Memory Utilization, 直接%, scalar；item 名为 Utilization，按%处理) ----
    # 待现网核验：1.3.6.1.4.1.119.2.3.84.2.6.2.0（内存使用率%）。device_memory_usage 直采。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.119.2.3.84.2.6.2.0"
        name = "usage"
    # ---- NEC temperature (PEN 119, scalar, °C 直采) ----
    # 待现网核验：1.3.6.1.4.1.119.2.3.84.2.1.1.0（设备温度 ℃，scalar）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.119.2.3.84.2.1.1.0"
        name = "celsius"
# ---- 风扇/电源：NEC 经 PEN 119 per-fan/per-psu LLD 暴露状态枚举(.2.3.1.x / .2.4.1.x,行索引,状态码语义未知),inputs.snmp 难按行规范化枚举 → 风扇/电源 N/A。CPU/内存/温度三标量干净可采。----
