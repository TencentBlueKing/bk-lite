[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_fortiswitch"
        config_type = "fortiswitch"
        brand = "fortiswitch"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- FortiSwitch CPU (FORTINET-FORTISWITCH-MIB fsSysCpuUsage, 直接%, scalar, PEN 12356.106；424ef.snmprec 实测30) ----
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.106.4.1.2.0"
        name = "usage"
    # ---- FortiSwitch 内存 (fsSysMemUsage 已用 + fsSysMemCapacity 总量, KB*1024；used/total) ----
    # 待现网核验：fsSysMemUsage .12356.106.4.1.3.0(已用KB) / fsSysMemCapacity .4.1.4.0(总量KB)；snmprec used=323484 total=769604。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.106.4.1.3.0"
        name = "used"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.106.4.1.4.0"
        name = "total"
# ---- 温度/风扇/电源:FortiSwitch 仅经 ENTITY-SENSOR(按 entPhySensorType 行级过滤,inputs.snmp 不能过滤)暴露 → N/A。CPU+内存(used/total)干净可采。----
