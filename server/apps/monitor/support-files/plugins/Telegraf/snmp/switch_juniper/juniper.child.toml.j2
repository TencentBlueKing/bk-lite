[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_juniper"
        config_type = "juniper"
        brand = "juniper"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Juniper jnxOperating CPU (JUNIPER-MIB jnxOperatingCPU, per operating entity) ----
    # 待现网核验：jnxOperatingCPU 1.3.6.1.4.1.2636.3.1.13.1.8（路由引擎为真实值，风扇/电源该列为 0；已是 0-100%）
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.8"
        name = "usage"
    # ---- Juniper jnxOperating memory buffer utilization (% 直报，无 used/free 字节) ----
    # 待现网核验：jnxOperatingBuffer 1.3.6.1.4.1.2636.3.1.13.1.11 → 统一 device_memory_usage(原始%)
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.11"
        name = "usage"
    # ---- Juniper jnxOperating temperature (per operating entity, °C) ----
    # 待现网核验：jnxOperatingTemp 1.3.6.1.4.1.2636.3.1.13.1.7（模版单位 °C，无需换算）；descr=jnxOperatingDescr ...13.1.5
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.5"
        name = "descr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.7"
        name = "celsius"
    # ---- Juniper fans (jnxOperatingState, fan container subtree .6.4) ----
    # 待现网核验：风扇 jnxOperatingState 1.3.6.1.4.1.2636.3.1.13.1.6.4；descr ...13.1.5.4。
    # jnxOperatingState 枚举非 1=normal：2 running/3 ready/5 runningAtFullSpeed/7 standby=健康，6 down/off=故障。
    # → 下方 processors.enum 归一到 1=normal/2=abnormal。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.5.4"
        name = "descr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.6.4"
        name = "state"
    # ---- Juniper power supplies (jnxOperatingState, power container subtree .6.2) ----
    # 待现网核验：电源 jnxOperatingState 1.3.6.1.4.1.2636.3.1.13.1.6.2；descr ...13.1.5.2。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.5.2"
        name = "descr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.6.2"
        name = "state"

# ---- 枚举归一：把 Juniper jnxOperatingState 映射到统一 1=normal/2=abnormal（偏离1即异常）----
# 待现网核验：仅作用于本品牌(tagpass brand=juniper)。
# 健康态 2 running/3 ready/5 runningAtFullSpeed/7 standby → 1；其余(1 unknown/4 reset/6 down)→2。
[[processors.enum]]
    [processors.enum.tagpass]
        brand = ["juniper"]
    [[processors.enum.mapping]]
        field = "device_fan_state"
        dest = "device_fan_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "2" = 1
            "3" = 1
            "5" = 1
            "7" = 1
    [[processors.enum.mapping]]
        field = "device_psu_state"
        dest = "device_psu_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "2" = 1
            "3" = 1
            "5" = 1
            "7" = 1
