[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "${AUTH_PASSWORD__{{ config_id }}}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "${PRIV_PASSWORD__{{ config_id }}}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_barracuda"
        config_type = "barracuda"
        brand = "barracuda"

    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true

    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.31.1.1"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.1"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"

    # Barracuda bspyware system leaves under 1.3.6.1.4.1.20632.3.1.10.
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.20632.3.1.10.3.0"
        name = "barracuda_cpu_temperature_celsius"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.20632.3.1.10.4.0"
        name = "barracuda_system_temperature_celsius"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.20632.3.1.10.5.0"
        name = "barracuda_firmware_storage_usage"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.20632.3.1.10.6.0"
        name = "barracuda_log_storage_usage"

[[processors.starlark]]
    namepass = ["snmp"]
    [processors.starlark.tagpass]
        brand = ["barracuda"]
    source = '''
def apply(metric):
    metric.fields["device_temperature_celsius"] = max(
        metric.fields.get("barracuda_cpu_temperature_celsius", 0),
        metric.fields.get("barracuda_system_temperature_celsius", 0),
    )
    metric.fields["device_disk_usage"] = max(
        metric.fields.get("barracuda_firmware_storage_usage", 0),
        metric.fields.get("barracuda_log_storage_usage", 0),
    )
    return metric
'''
