[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_synology"
        config_type = "synology"
        brand = "synology"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Synology chassis temperature (SYNOLOGY-SYSTEM-MIB synologyTemperature, °C 直采无缩放) ----
    # synologyTemperature 1.3.6.1.4.1.6574.1.2.0，Integer，机箱温度，单位 ℃（直采，无 ÷10）。
    # 标量经合成表归一为 measurement device_temperature.celsius；共享盘 device_temperature_celsius max()。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6574.1.2.0"
        name = "celsius"
    # ---- Synology system fan status (SYNOLOGY-SYSTEM-MIB synologySystemFanStatus, 标量) ----
    # synologySystemFanStatus 1.3.6.1.4.1.6574.1.4.1.0，INTEGER {normal(1), failed(2)}。
    # 厂商码 1=正常/2=异常，与共享盘 device_fan_state(1=正常,>1=异常) 一致，processors.enum 显式归一。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6574.1.4.1.0"
        name = "state"
    # ---- Synology power-supply status (SYNOLOGY-SYSTEM-MIB synologyPowerStatus, 标量) ----
    # synologyPowerStatus 1.3.6.1.4.1.6574.1.3.0，INTEGER {normal(1), failed(2)}。
    # 共享盘 device_psu_state(1=正常,>1=异常)。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6574.1.3.0"
        name = "state"
    # ---- Synology RAID/volume array status (SYNOLOGY-RAID-MIB synologyRaidStatus, 每 RAID 组一行) ----
    # synologyRaidStatus 1.3.6.1.4.1.6574.3.1.1.3，INTEGER：normal(1)=正常；degraded/crashed/rebuilding 等非1=异常。
    # 行名 synologyRaidName(...3.1.1.2)；共享盘 device_raid_state max() by instance_id 取最差 RAID 组。
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.6574.3.1.1"
        name = "device_raid"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6574.3.1.1.2"
        name = "raidName"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6574.3.1.1.3"
        name = "state"
# ---- 风扇状态归一：normal(1)→1(正常)，failed(2)→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
            "2" = 2
# ---- 电源状态归一：normal(1)→1(正常)，failed(2)→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
            "2" = 2
# ---- RAID 状态归一：normal(1)→1(正常)，其余(degraded/crashed/rebuilding 等)→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_raid"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- CPU/内存：SYNOLOGY-SYSTEM-MIB 私有树仅 synologySystemStatus 粗粒度 normal/failed 码，未发布可轮询的系统级 CPU/内存利用率 gauge → CPU/内存 N/A 不采。----
