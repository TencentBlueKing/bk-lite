{
  "object": "Access",
  "plugin": "Access V-SOL SNMP",
  "templates": [
    {
      "metric_name": "device_cpu_usage",
      "alert_name": "CPU usage high",
      "algorithm": "Threshold",
      "threshold": 85,
      "level": "warning"
    },
    {
      "metric_name": "device_memory_usage",
      "alert_name": "Memory usage high",
      "algorithm": "Threshold",
      "threshold": 85,
      "level": "warning"
    },
    {
      "metric_name": "device_temperature_celsius",
      "alert_name": "Temperature high",
      "algorithm": "Threshold",
      "threshold": 70,
      "level": "warning"
    }
  ]
}
