[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "${AUTH_PASSWORD__{{ config_id }}}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "${PRIV_PASSWORD__{{ config_id }}}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_4rf"
        config_type = "4rf"
        brand = "4rf"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.31.1.1"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.1"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- AprisaXE receiver temperature: FourRFTemperature, degrees Celsius ----
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.14817.7.3.1.2.51.8"
        name = "celsius"
    # ---- AprisaXE fan status: fanOkay(1) -> 1, notFitted(0) -> 1, fanFailed(2)/unknown -> 2 ----
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.14817.7.3.1.2.21.1"
        name = "fan1_state"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.14817.7.3.1.2.21.2"
        name = "state"
    # ---- CPU/内存/电源：APRISAXE-MIB-4RF 当前可核对稳定共享健康对象仅覆盖温度和风扇；RSSI/SNR/TDM/以太网对象属链路或业务遥测，不提升为设备级健康。----

[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
            "1" = 1

[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "fan1_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
            "1" = 1
