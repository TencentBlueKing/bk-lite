[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_yamaha"
        config_type = "yamaha"
        brand = "yamaha"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Yamaha RTX CPU load (YAMAHA-RT-MIB, 私有企业号 1182, 直接 %, scalar) ----
    # 待现网核验：5 秒平均 CPU 使用率标量 yrhCpuUtil5sec 1.3.6.1.4.1.1182.2.1.2.0（设备直接以 0-100% 上报）。
    # 标量用 table+field 命名 → device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.1182.2.1.2.0"
        name = "usage"
    # ---- Yamaha RTX 内存 (已用 + 空闲, 字节；无总量 → used/(used+free)) ----
    # 待现网核验：内存已用 yrhMemoryUtil 派生——已用 .1182.2.2.1.0 / 空闲 .1182.2.2.2.0（bytes）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.1182.2.2.1.0"
        name = "used"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.1182.2.2.2.0"
        name = "free"
    # ---- Yamaha RTX 温度 (机箱温度, 直接 ℃, scalar) ----
    # 待现网核验：机箱温度标量 yrhTemperature 1.3.6.1.4.1.1182.2.1.3.0（℃）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.1182.2.1.3.0"
        name = "celsius"
# ---- 风扇/电源：Yamaha RTX 为紧凑型固定配置路由器（无风扇或单一固定供电），私有 MIB 未以无需行级过滤的标量形式暴露独立风扇/电源传感器 → 风扇/电源 N/A 不采。CPU/内存/温度/接口干净可采。----
