[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_engenius"
        config_type = "engenius"
        brand = "engenius"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB ifTable, 用于自动展开 ifDescr/ifOperStatus 等接口属性列) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64 位 IF-MIB HC 流量计数器 (ifXTable，无线 AP 上联高吞吐不易回绕，按 ifIndex 与上表接口行对齐) ----
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- 无线健康 (CPU/温度/内存/关联客户端数/信道利用率) → N/A ----
    # EnGenius（Senao，企业号 14125）私有 MIB 以配置为主。ENGENIUS-PRIVATE-MIB 无 CPU/温度/内存对象；
    # 仅旧版 mesh 固件的 ENGENIUS-MESH-MIB 暴露 systemMemory(14125.1.1.1.2.0，为“空闲内存百分比”) 与
    # systemUptime(字符串非数值)，且云管 ECW/EWS 机型无该私有树。关联客户端数无标量计数（须对 clientInfoTable 逐行计数，
    # 各列均为 OCTET STRING 文本，telegraf 无法可靠 gauge 化），信道利用率无对象。
    # 为跨机型（含云管）稳定可采，本插件仅采集标准 IF-MIB 接口流量 (ifHCInOctets/ifHCOutOctets) 与运行时长 (uptime)，
    # 无线 CPU/内存/温度/客户端数/信道利用率为 N/A，不伪造。
