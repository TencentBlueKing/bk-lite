[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_hirschmann"
        config_type = "hirschmann"
        brand = "hirschmann"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Hirschmann CPU (HMPRIV-MGMT-SNMP-MIB hmCpuUtilization, 直接%, scalar, PEN 248；hirschmann.snmprec 实测42) ----
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.248.14.2.15.2.1.0"
        name = "usage"
    # ---- Hirschmann 内存 (hmMemoryAllocated 已用 + hmMemoryFree 空闲, KB；无总量 → used/(used+free)) ----
    # 待现网核验：hmMemoryAllocated .248.14.2.15.3.1.0(已用) / hmMemoryFree .248.14.2.15.3.2.0(空闲)；snmprec used=27112 free=21857。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.248.14.2.15.3.1.0"
        name = "used"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.248.14.2.15.3.2.0"
        name = "free"
    # ---- Hirschmann 温度 (hmTemperature, 直接 ℃, scalar) ----
    # 待现网核验：hmTemperature .248.14.2.5.1.0(机箱温度℃)；snmprec 实测43。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.248.14.2.5.1.0"
        name = "celsius"
    # ---- Hirschmann 电源状态 (hmPSState 表 .248.14.1.2.1.3, 每电源 ok(1)/failed(2)/notInstalled(3)/unknown(4)) ----
    # 待现网核验：原始码 ok=1；下方 enum 归一 1→1(正常),其余→2(异常)。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.248.14.1.2.1.3"
        name = "state"
# ---- 风扇:Hirschmann HMPRIV MIB 未暴露独立风扇状态/转速专用标量 → 风扇 N/A。CPU/内存/温度/电源四项干净可采。----
# ---- 状态归一:电源 ok(1)→1(正常),其余(failed/notInstalled/unknown)→2(异常)。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
