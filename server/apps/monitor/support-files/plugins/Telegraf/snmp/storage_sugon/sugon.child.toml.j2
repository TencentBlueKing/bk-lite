[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_sugon"
        config_type = "sugon"
        brand = "sugon"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Sugon fan status (PEN 35904 fanState, 每风扇一行) ----
    # fanState 1.3.6.1.4.1.35904.1.2.2.3.2.1.2，风扇健康状态。normal(1)→1 正常，其余→2 异常。
    # 共享盘 device_fan_state(1=正常,>1=异常) max() by instance_id 取最差风扇行。
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.35904.1.2.2.3.2"
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.35904.1.2.2.3.2.1.2"
        name = "state"
    # ---- Sugon power-supply status (PEN 35904 powerState, 每电源一行) ----
    # powerState 1.3.6.1.4.1.35904.1.2.2.7.2.1.2，电源状态。normal(1)→1 正常，其余→2 异常。
    # 共享盘 device_psu_state(1=正常,>1=异常) max() by instance_id 取最差电源行。
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.35904.1.2.2.7.2"
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.35904.1.2.2.7.2.1.2"
        name = "state"
    # ---- Sugon disk status (PEN 35904 diskState, 每磁盘一行) ----
    # diskState 1.3.6.1.4.1.35904.1.2.2.5.2.1.6，磁盘状态。normal(1)→1 正常，其余→2 异常。
    # 共享盘 device_disk_state(1=正常,>1=异常) max() by instance_id 取最差磁盘行。
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.35904.1.2.2.5.2"
        name = "device_disk"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.35904.1.2.2.5.2.1.6"
        name = "state"
# ---- 风扇状态归一：normal(1)→1(正常)，其余→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- 电源状态归一：normal(1)→1(正常)，其余→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- 磁盘状态归一：normal(1)→1(正常)，其余→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_disk"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- CPU/内存：Sugon ParaStor 私有树未发布可轮询的控制器级 CPU/内存利用率 gauge → CPU/内存 N/A 不采。----
