[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_grandstream"
        config_type = "grandstream"
        brand = "grandstream"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB ifTable, 用于自动展开 ifDescr/ifOperStatus 等接口属性列) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64 位 IF-MIB HC 流量计数器 (ifXTable，无线 AP 上联高吞吐不易回绕，按 ifIndex 与上表接口行对齐) ----
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- 无线健康 (CPU/温度/内存/关联客户端数/信道利用率) → N/A ----
    # Grandstream GWN（企业号 42397）的 GRANDSTREAM-GWN-MIB 以无线射频统计与连接客户端信息为主，
    # 仅暴露设备运行时长 gwnDeviceUptime(42397.1.1.2.6) 这一标量系统量；无 CPU 利用率/内存使用/温度对象。
    # 关联客户端数仅以 gwnClientTable(42397.1.1.3.3) 逐行(按 MAC 索引)呈现，无标量计数对象，
    # telegraf inputs.snmp 不支持行级聚合，故无法可靠 gauge 化为客户端总数；信道利用率亦无标量对象。
    # 为跨 GWN76xx/GWN78xx 机型稳定可采，本插件仅采集标准 IF-MIB 接口流量 (ifHCInOctets/ifHCOutOctets) 与
    # 运行时长 (uptime)，无线 CPU/内存/温度/客户端数/信道利用率为 N/A，不伪造。
