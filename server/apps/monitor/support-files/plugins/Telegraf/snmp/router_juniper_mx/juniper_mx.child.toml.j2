[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_juniper_mx"
        config_type = "juniper_mx"
        brand = "juniper_mx"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Juniper jnxOperating CPU utilization (JUNIPER-MIB jnxOperatingTable, per operating entity, %) ----
    # 来源：官方 JUNIPER-MIB（复用已产 juniper switch 的 jnxOperating OID，路由器 MX 系列同 MIB）。
    # 待现网核验：jnxOperatingCPU 1.3.6.1.4.1.2636.3.1.13.1.8（路由引擎为真实值，风扇/电源该列为 0；已是 0-100%）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.8"
        name = "usage"
    # ---- Juniper jnxOperating memory buffer utilization (% 直报，无 used/free 字节) ----
    # 待现网核验：jnxOperatingBuffer 1.3.6.1.4.1.2636.3.1.13.1.11 → 统一 device_memory_usage(原始%)。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2636.3.1.13.1.11"
        name = "usage"
# ---- 机箱温度 jnxOperatingTemp → N/A：jnxOperatingTable 把 RE/FPC/Fan/PSU 实体混在同一列，----
# ---- 无热传感器实体该列报 0 哨兵，要取「真实热点行」须按 jnxOperatingDescr 文本逐行区分(行级过滤)，----
# ---- telegraf inputs.snmp 只能整列 walk、不能行级过滤 → 跳过(同风扇/电源教训)。----
# ---- 风扇/电源 → N/A(架构限制)：jnxOperatingState/jnxFruState 把路由引擎/FPC/风扇盘/电源混在同一张 jnxOperatingTable，----
# ---- 要取「风扇行/电源行」状态须按 jnxOperatingDescr 文本逐行区分(行级过滤)，telegraf inputs.snmp 只能整列 walk、不能行级过滤 → 跳过(同 paloalto entity-sensor/eltex 教训)。----
# ---- BGP 邻居走 BGP4-MIB bgpPeerTable(per-peer walk,需聚合计数)→本轮 N/A,后续可补 BGP peer 数。----
