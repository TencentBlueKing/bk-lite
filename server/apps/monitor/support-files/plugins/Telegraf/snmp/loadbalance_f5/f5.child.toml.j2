[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_f5"
        config_type = "f5"
        brand = "f5"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- F5 BIG-IP CPU usage (F5-BIGIP-SYSTEM-MIB sysGlobalHostCpuUsageRatio5s, scalar %) ----
    # 来源：官方 F5-BIGIP-SYSTEM-MIB（librenms mibs/f5）。逐级 f5=3375 → bigipTrafficMgmt=.2 → bigipSystem=.1
    #       → sysGlobals=.1 → sysGlobalStats=.2 → sysGlobalHost=.20 → CpuUsageRatio5s=.21 确认。待现网核验。
    # 待现网核验：1.3.6.1.4.1.3375.2.1.1.2.20.21.0（5 秒 CPU 使用率 %）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.20.21.0"
        name = "usage"
    # ---- F5 BIG-IP host memory (F5-BIGIP-SYSTEM-MIB sysStatMemory*, total + used, bytes) ----
    # 待现网核验：sysStatMemoryTotal 1.3.6.1.4.1.3375.2.1.1.2.1.44.0；sysStatMemoryUsed ...1.45.0（字节）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.1.44.0"
        name = "total"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.1.45.0"
        name = "used"
    # ---- F5 load-balancer specific (current client connections, scalar) ----
    # 待现网核验：sysStatClientCurConns 1.3.6.1.4.1.3375.2.1.1.2.1.8.0（当前客户端连接数）。
    [[inputs.snmp.table]]
        name = "loadbalance"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.1.8.0"
        name = "current_connections"
    # ---- F5 BIG-IP environment sensors (temperature / fan / PSU state) ----
    # 待现网核验：环境状态表按 F5-BIGIP-SYSTEM-MIB 私有 OID 采集，状态码经 enum 归一为 1=正常/2=异常。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.1.43.0"
        name = "celsius"
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.1.46.0"
        name = "state"
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.3375.2.1.1.2.1.47.0"
        name = "state"

[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
