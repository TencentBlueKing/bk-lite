[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_pulsesecure"
        config_type = "pulsesecure"
        brand = "pulsesecure"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Pulse Secure (Ivanti) IVE health scalars (PULSESECURE-PSG-MIB, PEN 12532) ----
    # CPU 使用率 iveCpuUtil 1.3.6.1.4.1.12532.10（Gauge32 0..100，直接%）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12532.10.0"
        name = "usage"
    # ---- 内存使用率 iveMemoryUtil 1.3.6.1.4.1.12532.11（Gauge32 0..100，直接%，无 used/free 字节） ----
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12532.11.0"
        name = "usage"
    # ---- Swap 使用率 iveSwapUtil 1.3.6.1.4.1.12532.24（Gauge32 0..100，直接%） ----
    [[inputs.snmp.table]]
        name = "device_swap"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12532.24.0"
        name = "usage"
    # ---- 磁盘使用率 diskFullPercent 1.3.6.1.4.1.12532.25（Gauge32 0..100，直接%） ----
    [[inputs.snmp.table]]
        name = "device_disk"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12532.25.0"
        name = "usage"
    # ---- 机箱温度 iveTemperature 1.3.6.1.4.1.12532.42（Gauge32，°C 直采无缩放；仅 MAG 刀片返回真值，其他平台返回 0） ----
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12532.42.0"
        name = "celsius"
    # ---- 已登录 Web 用户数 signedInWebUsers 1.3.6.1.4.1.12532.2（Gauge32，会话计数） ----
    # 表名 device_web + 字段 users → telegraf 拼接 device_web_users，与 metrics.json 声明一致。
    [[inputs.snmp.table]]
        name = "device_web"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12532.2.0"
        name = "users"
# ---- 风扇/电源：PULSESECURE-PSG-MIB 无风扇/电源状态对象 → N/A。温度仅 MAG 平台有效(非 MAG 返回 0)，max() 自然取真值。----
