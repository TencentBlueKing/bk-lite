{
  "object": "Firewall",
  "plugin": "Firewall Pulse Secure SNMP",
  "templates": [
    {
      "name": "Pulse Secure防火墙CPU使用率过高",
      "alert_name": "防火墙${resource_name} CPU 使用率过高",
      "description": "监控Pulse Secure / Ivanti Connect Secure防火墙的整体 CPU 使用率，当持续高于阈值时触发告警，提示可能存在流量检测负载过高、攻击活动或控制平面瓶颈，避免转发与管理响应受影响。",
      "metric_name": "device_cpu_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ]
    },
    {
      "name": "Pulse Secure防火墙内存使用率过高",
      "alert_name": "防火墙${resource_name} 内存使用率过高",
      "description": "监控Pulse Secure / Ivanti Connect Secure防火墙的整体内存使用率，当超过阈值时触发告警。内存压力过高会导致设备丢弃新建会话，需及时排查会话表过大或异常流量。",
      "metric_name": "device_memory_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ]
    },
    {
      "name": "接口接收错误包过高",
      "alert_name": "防火墙${resource_name} 接口 ${metric_ifDescr} 每秒接收错误包数过高",
      "description": "监控设备接口接收的错误包数情况，当每秒错误包数超出设定阈值时触发告警，便于发现网络接口隐患。",
      "metric_name": "interface_ifInErrors",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ]
    },
    {
      "name": "接口发送错误包过高",
      "alert_name": "防火墙${resource_name} 接口 ${metric_ifDescr} 每秒发送错误包数过高",
      "description": "监控设备接口发送端错误包数，每秒发送错误包数量超出限制时发出告警，及时定位和处理网络发送问题。",
      "metric_name": "interface_ifOutErrors",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ]
    },
    {
      "name": "接口接收丢包数过高",
      "alert_name": "防火墙${resource_name} 接口 ${metric_ifDescr} 每秒接收丢包数过高",
      "description": "实时监控设备机接口的丢包情况，当接收丢包速率超过阈值时告警，帮助排查网络接收质量问题并优化链路性能。",
      "metric_name": "interface_ifInDiscards",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ]
    },
    {
      "name": "接口发送丢包数过高",
      "alert_name": "防火墙${resource_name} 接口 ${metric_ifDescr} 每秒发送丢包数过高",
      "description": "监测接口发送丢包速率是否异常，当发送丢包数量高于预设阈值时触发告警，为网络发送端问题提供及时反馈。",
      "metric_name": "interface_ifOutDiscards",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ]
    },
    {
      "name": "Pulse Secure网关Swap使用率过高",
      "alert_name": "防火墙${resource_name} Swap 使用率过高",
      "description": "监控 Pulse Secure / Ivanti Connect Secure 网关的 Swap 使用率，持续过高表示内存耗尽，会拖慢 VPN 会话性能，需及时排查。",
      "metric_name": "device_swap_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ]
    },
    {
      "name": "Pulse Secure网关磁盘使用率过高",
      "alert_name": "防火墙${resource_name} 磁盘使用率过高",
      "description": "监控 Pulse Secure / Ivanti Connect Secure 网关的磁盘使用率，磁盘将满会阻碍日志与配置变更并可能导致设备不稳定。",
      "metric_name": "device_disk_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ]
    },
    {
      "name": "Pulse Secure网关温度过高",
      "alert_name": "防火墙${resource_name} 温度过高",
      "description": "监控 Pulse Secure / Ivanti Connect Secure 设备机箱温度（仅 MAG 刀片有效），超过阈值时触发告警，防止高温损坏设备。",
      "metric_name": "device_temperature_celsius",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 70,
          "method": ">"
        },
        {
          "level": "error",
          "value": 60,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 55,
          "method": ">"
        }
      ]
    }
  ]
}