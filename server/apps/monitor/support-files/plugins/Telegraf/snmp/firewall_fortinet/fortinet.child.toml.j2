[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_fortinet"
        config_type = "fortinet"
        brand = "fortinet"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- FortiGate CPU utilization (FORTINET-FORTIGATE-MIB fgSysCpuUsage, scalar %) ----
    # 待现网核验：1.3.6.1.4.1.12356.101.4.1.3.0（已是 0-100%）。table(measurement=device_cpu)+field usage → device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.101.4.1.3.0"
        name = "usage"
    # ---- FortiGate memory (FORTINET-FORTIGATE-MIB, usage % + total KB) ----
    # 待现网核验：fgSysMemUsage 1.3.6.1.4.1.12356.101.4.1.4.0（已是 0-100%）；fgSysMemCapacity ...4.1.5.0（KB）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.101.4.1.4.0"
        name = "usage"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.101.4.1.5.0"
        name = "total"
    # ---- FortiGate firewall-specific health (sessions / VPN tunnels / HA mode, scalars) ----
    # 待现网核验：fgSysSesCount 1.3.6.1.4.1.12356.101.4.1.8.0（IPv4 活动会话数）；
    #            fgVpnTunnelUpCount 1.3.6.1.4.1.12356.101.12.1.1.0（活动 IPsec 隧道数）；
    #            fgHaSystemMode 1.3.6.1.4.1.12356.101.13.1.1.0（standalone=1/activeActive=2/activePassive=3）。
    [[inputs.snmp.table]]
        name = "firewall"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.101.4.1.8.0"
        name = "active_sessions"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.101.12.1.1.0"
        name = "vpn_tunnels"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12356.101.13.1.1.0"
        name = "ha_mode"
