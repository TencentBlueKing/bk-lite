[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_ascom"
        config_type = "ascom"
        brand = "ascom"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB ifTable, 用于自动展开 ifDescr/ifOperStatus 等接口属性列) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64 位 IF-MIB HC 流量计数器 (ifXTable，无线 AP 上联高吞吐不易回绕，按 ifIndex 与上表接口行对齐) ----
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- 无线健康 (CPU/温度/内存/活动呼叫数/话机数) → N/A ----
    # Ascom IP-DECT（企业号 27614）的 ASCOM-IPDECT-MIB 仅暴露故障日志/告警日志条目表
    # (ipDectFaultLogTable / ipDectActiveAlarmsTable) 与逐条错误码,无 CPU 利用率/内存/温度标量对象;
    # 活动 DECT 呼叫数/注册话机数未以可轮询标量公开。本插件仅采集 IP-DECT 基站以太网上联的
    # 标准 IF-MIB 接口流量 (ifHCInOctets/ifHCOutOctets) 与运行时长 (uptime),
    # 无线 CPU/内存/温度/呼叫数/话机数为 N/A,不伪造。
