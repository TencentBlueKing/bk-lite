[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_viprinet"
        config_type = "viprinet"
        brand = "viprinet"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Viprinet CPU load (VIPRINET-MIB, 私有企业号 35424, 直接 %, scalar) ----
    # 待现网核验：整机 CPU 使用率标量 1.3.6.1.4.1.35424.1.1.7.0（设备直接以 0-100% 上报）。
    # 标量用 table+field 命名 → device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.35424.1.1.7.0"
        name = "usage"
    # ---- Viprinet 内存 (总量 + 空闲, 字节；usage=(总量-空闲)/总量) ----
    # 待现网核验：内存总量 .35424.1.1.8.0 / 空闲 .35424.1.1.9.0（bytes）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.35424.1.1.8.0"
        name = "total"
        conversion = "int"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.35424.1.1.9.0"
        name = "free"
        conversion = "int"
# ---- 温度/风扇/电源：Viprinet 紧凑型多 WAN 路由器为无风扇固定配置设计，VIPRINET-MIB 未以无需行级过滤的标量形式暴露独立温度/风扇/电源传感器 → 温度/风扇/电源 N/A 不采。CPU/内存/接口干净可采。----
