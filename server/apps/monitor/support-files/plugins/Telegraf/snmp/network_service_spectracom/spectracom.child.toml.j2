[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "${AUTH_PASSWORD__{{ config_id }}}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "${PRIV_PASSWORD__{{ config_id }}}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_spectracom"
        config_type = "spectracom"
        brand = "spectracom"

    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true

    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.18837.3.2.2.1.2"
        name = "network_service_spectracom_dc_power_state"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.18837.3.2.2.1.5"
        name = "network_service_spectracom_sync_state"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.18837.3.2.2.1.13"
        name = "network_service_spectracom_minor_alarm_state"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.18837.3.2.2.1.14"
        name = "network_service_spectracom_major_alarm_state"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.18837.3.3.2.1"
        name = "network_service_spectracom_ntp_state"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.4.1.18837.3.3.2.2"
        name = "network_service_spectracom_ntp_stratum"

    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.31.1.1"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.1"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"

[[processors.enum]]
    namepass = ["snmp"]
    [processors.enum.tagpass]
        brand = ["spectracom"]
    [[processors.enum.mapping]]
        field = "network_service_spectracom_sync_state"
        dest = "network_service_spectracom_sync_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            1 = 1
            2 = 2
    [[processors.enum.mapping]]
        field = "network_service_spectracom_dc_power_state"
        dest = "network_service_spectracom_dc_power_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            1 = 1
            2 = 2
            3 = 2
    [[processors.enum.mapping]]
        field = "network_service_spectracom_minor_alarm_state"
        dest = "network_service_spectracom_minor_alarm_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            1 = 2
            2 = 1
    [[processors.enum.mapping]]
        field = "network_service_spectracom_major_alarm_state"
        dest = "network_service_spectracom_major_alarm_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            1 = 2
            2 = 1
    [[processors.enum.mapping]]
        field = "network_service_spectracom_ntp_state"
        dest = "network_service_spectracom_ntp_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            1 = 2
            2 = 2
            3 = 2
            4 = 1
