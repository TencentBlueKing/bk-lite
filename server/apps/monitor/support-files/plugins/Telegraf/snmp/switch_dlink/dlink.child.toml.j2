[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_dlink"
        config_type = "dlink"
        brand = "dlink"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- D-Link CPU utilization (EQUIPMENT-MIB swCPUUtilizationIn5min, scalar %) ----
    # 待现网核验：1.3.6.1.4.1.171.12.1.1.6.2.0（已是 0-100%）。用 table(measurement=device_cpu)+field usage → 指标 device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.171.12.1.1.6.2.0"
        name = "usage"
    # ---- D-Link memory utilization (EQUIPMENT-MIB swDevInfoTotalUtilizationOfMemory, % 直报) ----
    # 待现网核验：1.3.6.1.4.1.171.12.1.1.9.1.4（按内存单元表索引，% 直报，无 used/free 字节）→ 统一 device_memory_usage(原始%)。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.171.12.1.1.9.1.4"
        name = "usage"
    # ---- D-Link temperature (EQUIPMENT-MIB swTemperatureCurrent, °C) ----
    # 待现网核验：1.3.6.1.4.1.171.12.11.1.8.1.2（模版单位 °C，无需换算；无独立 descr 名列，省略 descr）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.171.12.11.1.8.1.2"
        name = "celsius"
    # ---- D-Link fans (EQUIPMENT-MIB swFanStatus) ----
    # 待现网核验：风扇状态 1.3.6.1.4.1.171.12.11.1.7.1.3（无独立 descr 名列，省略 descr）。
    # 枚举 swFanStatus：0 other / 1 working(正常) / 2 fail / 3 speed-0 / 4..。**原生 1=working=normal，无需 remap**（偏离 1 即异常，policy >1）。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.171.12.11.1.7.1.3"
        name = "state"
    # ---- D-Link power supplies (EQUIPMENT-MIB swPowerStatus) ----
    # 待现网核验：电源状态 1.3.6.1.4.1.171.12.11.1.6.1.3（无独立 descr 名列，省略 descr）。
    # 枚举 swPowerStatus：0 other / 1 lowVoltage / 2 overCurrent / 3 working(正常) / 4..。
    # **正常态=3 非 1 → 下方 processors.enum 归一(3→1，其余→2)**。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.171.12.11.1.6.1.3"
        name = "state"

# ---- 枚举归一：D-Link 风扇/电源 → 统一 1=normal/2=abnormal（偏离1即异常）----
# 待现网核验：仅作用于本品牌(tagpass brand=dlink)。
# 电源 swPowerStatus working(3)→1；其余(0 other/1 lowVoltage/2 overCurrent/4..)→2。
# 风扇 swFanStatus working(1)→1；其余(0 other/2 fail/3 speed-0/..)→2——非二元(含 0=other<1)，
#   policy >1 抓不到 0=other，故同样 enum 归一以兜底（不依赖原生编码恰好 >1 才异常）。
[[processors.enum]]
    [processors.enum.tagpass]
        brand = ["dlink"]
    [[processors.enum.mapping]]
        field = "device_psu_state"
        dest = "device_psu_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "3" = 1
    [[processors.enum.mapping]]
        field = "device_fan_state"
        dest = "device_fan_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
