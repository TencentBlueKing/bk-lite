[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_apresia"
        config_type = "apresia"
        brand = "apresia"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- APRESIA CPU utilization (APRESIA-NP-HW npCpuUtilizationTable, IANA PEN 278) ----
    # npCpuUtilizationValue 1.3.6.1.4.1.278.107.1.1.4.2.1.3，Integer 0..100 (%)，主装置(マスター)CPU 使用率。
    # 表按 npCpuUtilizationIndex(...4.2.1.1) 固定 3 行：1=过去5秒/2=过去1分钟/3=过去5分钟 的同一主 CPU 平均值。
    # telegraf inputs.snmp 不支持行级过滤，三行均为合法的同设备 CPU 读数 → 共享盘 max() by instance_id 取代表值。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.278.107.1.1.4.2.1.3"
        name = "usage"
    # ---- APRESIA chassis temperature (APRESIA-NP-HW npTemperatureTable, °C 直采无缩放) ----
    # npTemperatureCurrent 1.3.6.1.4.1.278.107.1.1.1.1.3，Integer32，现在温度，单位 ℃（直采，无 ÷10）。
    # 表按 npTemperatureUnitId(...1.1.1)/npTemperatureIndex(...1.1.2) 索引；NP4000 系列每装置 1 个温度传感器。
    # 共享盘 device_temperature_celsius max() by instance_id（多传感器机型取最热）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.278.107.1.1.1.1.3"
        name = "celsius"
    # ---- APRESIA fan status (APRESIA-NP-HW npFanTable npFanStatus, 每风扇一行) ----
    # npFanStatus 1.3.6.1.4.1.278.107.1.1.2.1.4，INTEGER {normal(1), abnormal(2)}。
    # 厂商码已是 1=正常/2=异常，与共享盘 device_fan_state(1=正常,>1=异常) 一致，processors.enum 显式归一保险。
    # 行名 npFanIndex(...2.1.2)，共享盘 max() by instance_id 取最差风扇行。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.278.107.1.1.2.1.2"
        name = "fanIndex"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.278.107.1.1.2.1.4"
        name = "state"
    # ---- APRESIA power-supply status (APRESIA-NP-HW npPowerTable npPowerStatus, 每电源一行) ----
    # npPowerStatus 1.3.6.1.4.1.278.107.1.1.3.1.4，INTEGER {inOperation(1), failed(2), empty(3)}。
    # 行名 npPowerIndex(...3.1.2)；inOperation(1)→1 正常，failed(2)→2 异常，empty(3)=未安装非故障→1 正常。
    # 共享盘 device_psu_state(1=正常,>1=异常) max() by instance_id 取最差电源行。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.278.107.1.1.3.1.2"
        name = "psuIndex"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.278.107.1.1.3.1.4"
        name = "state"
# ---- 风扇状态归一：normal(1)→1(正常)，abnormal(2)→2(异常)，default=2。----
[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
            "2" = 2
# ---- 电源状态归一：inOperation(1)→1(正常)，failed(2)→2(异常)，empty(3)=未安装非故障→1(正常)，default=2。----
# ---- 共享盘 device_psu_state 约定 1=正常,>1=异常。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
            "2" = 2
            "3" = 1
# ---- 内存：APRESIA-NP-HW 私有树仅 npMemoryUtilizationFailureStatusCode(...1.1.5.1.1, OCTET STRING)，且仅在 trap 绑定时有效，非可轮询 gauge → 内存 N/A 不采。----
