[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "${AUTH_PASSWORD__{{ config_id }}}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "${PRIV_PASSWORD__{{ config_id }}}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_dellsc8000"
        config_type = "dellsc8000"
        brand = "dellsc8000"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Dell SC disk status (Dell EMC PEN 674, one row per disk) ----
    # scDiskStatus .674.11000.2000.500.1.2.14.1.3: up(1) is normal; down/degraded are faults.
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.14.1"
        name = "device_disk"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.14.1.3"
        name = "state"
    # ---- Dell SC disk healthy flag (same disk table, one row per disk) ----
    # scDiskHealthy .674.11000.2000.500.1.2.14.1.5: true(1) is normal; false(2) is a fault.
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.14.1"
        name = "device_disk"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.14.1.5"
        name = "state"
    # ---- Dell SC controller fan status (one row per controller fan) ----
    # scCtlrFanStatus .674.11000.2000.500.1.2.16.1.3: up(1) is normal; down/degraded are faults.
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.16.1"
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.16.1.3"
        name = "state"
    # ---- Dell SC controller power-supply status (one row per controller PSU) ----
    # scCtlrPowerStatus .674.11000.2000.500.1.2.17.1.3: up(1) is normal; down/degraded are faults.
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.17.1"
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.674.11000.2000.500.1.2.17.1.3"
        name = "state"
# ---- Disk health normalization: up/true(1) -> 1 (normal), all other codes -> 2 (fault). ----
[[processors.enum]]
    namepass = ["device_disk"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- Fan health normalization: up(1) -> 1 (normal), down/degraded/unknown -> 2 (fault). ----
[[processors.enum]]
    namepass = ["device_fan"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- Power-supply health normalization: up(1) -> 1 (normal), down/degraded/unknown -> 2 (fault). ----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
# ---- CPU/内存/温度 N/A ----
# 本地 Dell SC8000 profile 暴露 productIDGlobalStatus、磁盘、风扇、电源、机箱状态和接口，
# 未提供控制器 CPU/内存利用率或温度 gauge；product/enclosure 状态暂无共享盘标准 metric，
# 故不臆造为 CPU/内存/温度或 RAID 指标，待现网核验后可扩展。
