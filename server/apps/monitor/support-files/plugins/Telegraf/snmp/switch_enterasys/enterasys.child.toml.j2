[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_enterasys"
        config_type = "enterasys"
        brand = "enterasys"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Enterasys CPU load (ENTERASYS-MIB, 私有企业号 5624, etsysResourceCpuLoad, 直接 %) ----
    # 待现网核验：CPU 负载标量 1.3.6.1.4.1.5624.1.2.49.1.4.1.1.5（etsysResourceCpuLoad5min，0-100%）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.5624.1.2.49.1.4.1.1.5"
        name = "usage"
    # ---- Enterasys 内存 (已用 + 空闲, KB；无总量 → used/(used+free)) ----
    # 待现网核验：内存已用 .5624.1.2.49.1.1.1.1.7 / 空闲 .5624.1.2.49.1.1.1.1.8（KB）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.5624.1.2.49.1.1.1.1.7"
        name = "used"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.5624.1.2.49.1.1.1.1.8"
        name = "free"
    # ---- Enterasys 温度 (机箱温度, 直接 ℃, scalar) ----
    # 待现网核验：机箱温度标量 .5624.1.2.16.1.1.1.4（℃）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.5624.1.2.16.1.1.1.4"
        name = "celsius"
    # ---- Enterasys 电源状态表 (etsysChassisPowerSupplyState .5624.1.2.16.1.1.1.3, 每电源 normal(1)/notOperational(2)...) ----
    # 待现网核验：原始码 normal=1；下方 enum 归一 1→1(正常),其余→2(异常)。
    [[inputs.snmp.table]]
        oid = "1.3.6.1.4.1.5624.1.2.16.1.1.1.3"
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.5624.1.2.16.1.1.1.3"
        name = "state"
# ---- 风扇:Enterasys 私有 MIB 未以无需行级过滤的标量形式暴露独立风扇状态 OID → 风扇 N/A。CPU/内存/温度/电源四项干净可采。----
# ---- 状态归一:电源 normal(1)→1(正常),其余→2(异常)。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
