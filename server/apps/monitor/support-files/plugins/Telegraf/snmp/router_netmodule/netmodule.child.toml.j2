[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_netmodule"
        config_type = "netmodule"
        brand = "netmodule"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- NetModule 系统温度 (NB-MIB systemTemperature, scalar, 私有树 PEN 31496) ----
    # 待现网核验：标量 OID 1.3.6.1.4.1.31496.10.40.50.0（FloatSyntax display-hint d-1，原始值÷10=摄氏度）。仅系统级单点温度，无分传感器表。
    # metrics.json 查询用 /10 还原摄氏度，device_temperature_celsius max() by instance_id。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.31496.10.40.50.0"
        name = "celsius"
# ---- CPU/内存/风扇/电源：NetModule NB-MIB（PEN 31496）仅暴露系统温度标量，无 CPU、无内存、无风扇、无电源/电压对象（NB/NG 系列为无风扇工业路由器）。设备虽运行嵌入式 Linux net-snmp，HOST-RESOURCES / UCD CPU·内存 OID 是否启用因固件而异、未经现网核实，故本基线模板不采，仅采集系统温度 + 标准 IF-MIB（含 64 位 HC）接口指标。CPU/内存/风扇/电源 N/A。----
