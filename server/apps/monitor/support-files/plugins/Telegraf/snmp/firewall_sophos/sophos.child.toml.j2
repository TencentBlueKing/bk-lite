[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_sophos"
        config_type = "sophos"
        brand = "sophos"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Sophos XG/SFOS CPU (SFOS-FIREWALL-MIB cpuPercentUsage, 直接%, scalar, PEN 21067) ----
    # 待现网核验：cpuPercentUsage 1.3.6.1.4.1.21067.2.1.2.2.1.0（CPU 使用率%，直采；Sophos community 模板 % cpu usage）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.21067.2.1.2.2.1.0"
        name = "usage"
    # ---- Sophos memory (SFOS-FIREWALL-MIB memoryPercentUsage, 直接%, scalar) ----
    # 待现网核验：memoryPercentUsage 1.3.6.1.4.1.21067.2.1.2.4.2.0（主内存使用率%，直采）。device_memory_usage 直采。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.21067.2.1.2.4.2.0"
        name = "usage"
# ---- 会话/温度/风扇/电源：Sophos SFOS-FIREWALL-MIB 暴露 liveUsers(认证用户,非会话表)、disk% 等,但无标准会话/连接计数与温度/风扇/电源 OID → 会话/温/风/电 N/A。仅 CPU/内存/接口干净可采。----
