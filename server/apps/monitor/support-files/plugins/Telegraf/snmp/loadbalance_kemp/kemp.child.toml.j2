[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_kemp"
        config_type = "kemp"
        brand = "kemp"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Kemp LoadMaster CPU (B-100-MIB cpuTotal, 直接%, scalar, PEN 12196) ----
    # 待现网核验：cpuTotal 1.3.6.1.4.1.12196.13.1.1.0（整机 CPU 使用率，直接 %）。
    # 标量用 table+field 命名 → device_cpu_usage；单实例无需 avg 但 metrics.json 仍 avg() by instance_id 保持一致。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12196.13.1.1.0"
        name = "usage"
    # ---- Kemp LoadMaster memory (B-100-MIB memUsedPercent, 直接利用率%, scalar) ----
    # 待现网核验：memUsedPercent 1.3.6.1.4.1.12196.13.1.4.0（已用内存百分比，直接 %）。device_memory_usage 直采。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12196.13.1.4.0"
        name = "usage"
    # ---- Kemp LoadMaster current connections (B-100-MIB connectionTotal, scalar) ----
    # 待现网核验：connectionTotal 1.3.6.1.4.1.12196.13.5.4.0（当前活动连接总数）。
    # 度量名取 lb_current_connections（measurement=lb + field=current_connections），对齐 loadbalance 盘连接 or-chain。
    [[inputs.snmp.table]]
        name = "lb"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.12196.13.5.4.0"
        name = "current_connections"
# ---- 温度/风扇/电源：Kemp LoadMaster MIB 未以无需行过滤的标量形式暴露环境传感器 → 温度/风扇/电源 N/A 不采。仅 CPU/内存/连接/接口干净可采。----
