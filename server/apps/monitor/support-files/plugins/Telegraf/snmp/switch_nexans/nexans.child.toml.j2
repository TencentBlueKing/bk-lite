[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_nexans"
        config_type = "nexans"
        brand = "nexans"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Nexans chassis temperature (NEXANS-BM-MIB bmSwitchInfo infoTemperature, °C, scalar) ----
    # 待现网核验：标量 OID 1.3.6.1.4.1.266.20.1.12.0（专用温度对象，直采摄氏度，walk 实测 36）。
    # 阈值参考 infoTemperatureMaxAllowed 1.3.6.1.4.1.266.20.1.13.0（walk 实测 70）。device_temperature_celsius max()。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.266.20.1.12.0"
        name = "celsius"
    # ---- Nexans power-supply health proxy (NEXANS-BM-MIB infoAlarmStateM1, 工业告警继电器, scalar) ----
    # 待现网核验：标量 OID 1.3.6.1.4.1.266.20.1.21.0。原始码 1=notSupported / 2=alarmOff(正常) / 3=alarmOn / 7,8,9=电源S1/S2 告警 / 其余=各类告警。
    # 下方 processors.enum 归一为 1=正常/2=异常（2 alarmOff 及 1 notSupported 视为正常,其余告警→异常）。
    # 注：另有 infoAlarmStateM2 ...1.22.0(冗余继电器)，标量无法与 M1 同名分行，本插件取 M1 主继电器；M2 略。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.266.20.1.21.0"
        name = "state"
# ---- 电源告警归一：1=notSupported / 2=alarmOff(正常)→1(正常)，其余(3 alarmOn / 4 linkDown / 5 forced / 7,8,9 电源告警 ...)→2(异常)。----
# ---- 共享盘 device_psu_state 约定 1=正常,>1=异常。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
            "2" = 1
# ---- CPU/内存/风扇：NEXANS-BM-MIB 无 CPU、无内存、无风扇对象（GigaSwitch/DualSwitch 为无风扇工业交换机），故 N/A 不采。----
