{
  "object": "Router",
  "plugin": "Router DrayTek SNMP",
  "templates": [
    {
      "name": "DrayTek Vigor路由器CPU使用率过高",
      "alert_name": "路由器${resource_name} CPU 使用率过高",
      "description": "监控 DrayTek Vigor 路由器各运行实体（各实体）的平均 CPU 使用率，当持续高于阈值时触发告警，提示可能存在控制平面过载或路由震荡，避免管理响应变慢或转发受影响。",
      "metric_name": "device_cpu_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "DrayTek Vigor路由器内存使用率过高",
      "alert_name": "路由器${resource_name} 内存使用率过高",
      "description": "监控 DrayTek Vigor 路由器各运行实体的内存缓冲使用率，当超过阈值时触发告警，便于及时发现内存压力导致转发或路由处理性能下降的风险。",
      "metric_name": "device_memory_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "接口接收错误包过高",
      "alert_name": "路由器${resource_name} 接口 ${metric_ifDescr} 每秒接收错误包数过高",
      "description": "监控设备接口接收的错误包数情况，当每秒错误包数超出设定阈值时触发告警，便于发现网络接口隐患。",
      "metric_name": "interface_ifInErrors",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "接口发送错误包过高",
      "alert_name": "路由器${resource_name} 接口 ${metric_ifDescr} 每秒发送错误包数过高",
      "description": "监控设备接口发送端错误包数，每秒发送错误包数量超出限制时发出告警，及时定位和处理网络发送问题。",
      "metric_name": "interface_ifOutErrors",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "接口接收丢包数过高",
      "alert_name": "路由器${resource_name} 接口 ${metric_ifDescr} 每秒接收丢包数过高",
      "description": "实时监控设备机接口的丢包情况，当接收丢包速率超过阈值时告警，帮助排查网络接收质量问题并优化链路性能。",
      "metric_name": "interface_ifInDiscards",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "接口发送丢包数过高",
      "alert_name": "路由器${resource_name} 接口 ${metric_ifDescr} 每秒发送丢包数过高",
      "description": "监测接口发送丢包速率是否异常，当发送丢包数量高于预设阈值时触发告警，为网络发送端问题提供及时反馈。",
      "metric_name": "interface_ifOutDiscards",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 100,
          "method": ">"
        },
        {
          "level": "error",
          "value": 50,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    }
  ]
}
