{
  "object": "NetworkService",
  "plugin": "NetworkService Accedian SNMP",
  "templates": [
    {
      "name": "Accedian网络服务CPU使用率过高",
      "alert_name": "网络服务${resource_name} CPU 使用率过高",
      "description": "监控 Accedian 性能保障节点的整机 CPU 使用率，当持续高于阈值时触发告警，提示流量调节与性能测量处理负载过高的风险。",
      "metric_name": "device_cpu_usage",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">"
        },
        {
          "level": "error",
          "value": 80,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">"
        }
      ],
      "group_algorithm": "avg"
    }
  ]
}
