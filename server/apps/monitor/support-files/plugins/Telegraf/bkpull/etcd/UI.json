{
  "object_name": "Etcd",
  "instance_type": "etcd",
  "collect_type": "bkpull",
  "config_type": [
    "etcd"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{instance_type}}_{{server_url}}",
  "form_fields": [
    {
      "name": "server_url",
      "label": "URL",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "description": "etcd Prometheus 指标地址，填写完整 URL",
      "widget_props": {
        "placeholder": "http://127.0.0.1:2379/metrics"
      },
      "rules": [
        {
          "type": "pattern",
          "pattern": "^(http|https)://.*",
          "message": "URL必须以http://或https://开头",
          "excel_formula": "OR(LEFT({{CELL}},7)=\"http://\",LEFT({{CELL}},8)=\"https://\")"
        }
      ],
      "transform_on_edit": {
        "origin_path": "child.content.config.urls[0]"
      }
    },
    {
      "name": "tls_ca",
      "label": "CA证书路径",
      "type": "input",
      "required": false,
      "description": "HTTPS 访问时使用的 CA 证书路径",
      "widget_props": {
        "placeholder": "/etc/ssl/ca.pem"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.tls_ca"
      }
    },
    {
      "name": "tls_cert",
      "label": "客户端证书路径",
      "type": "input",
      "required": false,
      "description": "HTTPS 双向认证时使用的客户端证书路径",
      "widget_props": {
        "placeholder": "/etc/ssl/client.pem"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.tls_cert"
      }
    },
    {
      "name": "tls_key",
      "label": "客户端密钥路径",
      "type": "input",
      "required": false,
      "description": "HTTPS 双向认证时使用的客户端密钥路径",
      "widget_props": {
        "placeholder": "/etc/ssl/client-key.pem"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.tls_key"
      }
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      }
    },
    {
      "name": "insecure_skip_verify",
      "label": "跳过证书校验",
      "type": "switch",
      "required": false,
      "default_value": false,
      "description": "HTTPS 场景下是否跳过服务端证书校验",
      "widget_props": {},
      "transform_on_edit": {
        "origin_path": "child.content.config.insecure_skip_verify"
      }
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点"
      },
      "enable_row_filter": false
    },
    {
      "name": "server_url",
      "label": "URL",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "http://127.0.0.1:2379/metrics"
      },
      "rules": [
        {
          "type": "pattern",
          "pattern": "^(http|https)://.*",
          "message": "URL必须以http://或https://开头",
          "excel_formula": "OR(LEFT({{CELL}},7)=\"http://\",LEFT({{CELL}},8)=\"https://\")"
        }
      ],
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "server_url"
        ],
        "target_field": "instance_name"
      },
      "is_only": true
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称"
      }
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组"
      }
    }
  ],
  "extra_edit_fields": {}
}
