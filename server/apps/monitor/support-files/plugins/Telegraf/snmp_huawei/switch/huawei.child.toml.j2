[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_huawei"
        config_type = "huawei"
        brand = "huawei"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- Huawei CPU utilization (HUAWEI-ENTITY-EXTENT-MIB hwEntityCpuUsage, per entity) ----
    # 待现网核验：hwEntityCpuUsage 1.3.6.1.4.1.2011.5.25.31.1.1.1.1.5（已归一化为 0-100 百分比）
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.1.1.5"
        name = "usage"
    # ---- Huawei Memory utilization (HUAWEI-ENTITY-EXTENT-MIB hwEntityMemUsage, per entity) ----
    # 待现网核验：华为以利用率(%)直接上报内存，无 used/free 字节 → 统一字段名 device_memory_usage(原始百分比)
    # hwEntityMemUsage 1.3.6.1.4.1.2011.5.25.31.1.1.1.1.7
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.1.1.7"
        name = "usage"
    # ---- Huawei Temperature sensors (HUAWEI-ENTITY-EXTENT-MIB hwEntityTemperature, per entity) ----
    # 待现网核验：温度 hwEntityTemperature 1.3.6.1.4.1.2011.5.25.31.1.1.1.1.11；
    # descr 取 ENTITY-MIB entPhysicalName 1.3.6.1.2.1.47.1.1.1.1.7（与温度同 entPhysicalIndex，按 index 关联）
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.47.1.1.1.1.7"
        name = "descr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.1.1.11"
        name = "celsius"
    # ---- Huawei Fans (HUAWEI-ENTITY-EXTENT-MIB hwEntityFanState) ----
    # 待现网核验：风扇状态 hwEntityFanState 1.3.6.1.4.1.2011.5.25.31.1.1.10.1.7；
    # 华为原生编码 1=normal,2=abnormal（已与统一约定 1=normal 对齐，无需重映射，偏离 1 即异常）；
    # descr 取风扇槽位 1.3.6.1.4.1.2011.5.25.31.1.1.10.1.1
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.10.1.1"
        name = "descr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.10.1.7"
        name = "state"
    # 注：华为该模板未提供电源(PSU)状态 OID，按"Zabbix 无则不做"原则省略 device_psu_state。
