{
  "plugin": "OceanStor",
  "plugin_desc": "Huawei OceanStor storage monitoring plugin. Collects performance metrics from storage pools, drives, and volumes via the DeviceManager REST API.",
  "status_query": "any({instance_type='oceanstor', collect_type='http'}) by (instance_id)",
  "is_compound_object": true,
  "objects": [
    {
      "name": "OceanStor",
      "icon": "mm-storage_存储",
      "type": "Storage",
      "level": "base",
      "description": "Huawei OceanStor storage system",
      "default_metric": "any({instance_type='oceanstor'}) by (instance_id)",
      "instance_id_keys": ["instance_id"],
      "supplementary_indicators": ["oceanstor_pool_count", "oceanstor_drive_count", "oceanstor_volume_count"],
      "metrics": [
        {
          "metric_group": "Quantity",
          "name": "oceanstor_pool_count",
          "query": "count by (instance_id) (sum by (instance_id, resource_id) ({resource_type=\"oceanstor_pool\"}))",
          "display_name": "Number of Pools",
          "data_type": "Number",
          "unit": "counts",
          "dimensions": [],
          "instance_id_keys": ["instance_id"],
          "description": "Total number of storage pools in the OceanStor system"
        },
        {
          "metric_group": "Quantity",
          "name": "oceanstor_drive_count",
          "query": "count by (instance_id) (sum by (instance_id, resource_id) ({resource_type=\"oceanstor_drive\"}))",
          "display_name": "Number of Drives",
          "data_type": "Number",
          "unit": "counts",
          "dimensions": [],
          "instance_id_keys": ["instance_id"],
          "description": "Total number of physical drives in the OceanStor system"
        },
        {
          "metric_group": "Quantity",
          "name": "oceanstor_volume_count",
          "query": "count by (instance_id) (sum by (instance_id, resource_id) ({resource_type=\"oceanstor_volume\"}))",
          "display_name": "Number of Volumes",
          "data_type": "Number",
          "unit": "counts",
          "dimensions": [],
          "instance_id_keys": ["instance_id"],
          "description": "Total number of LUN volumes in the OceanStor system"
        }
      ]
    },
    {
      "name": "StoragePool",
      "icon": "mm-storage_存储",
      "type": "Storage",
      "level": "derivative",
      "description": "OceanStor storage pool",
      "default_metric": "any({resource_type='oceanstor_pool'}) by (instance_id, resource_id)",
      "instance_id_keys": ["instance_id", "resource_id"],
      "supplementary_indicators": ["api_pool_io_rate", "api_pool_resp_t", "api_pool_read"],
      "metrics": [
        {
          "metric_group": "IOPS",
          "name": "api_pool_io_rate",
          "query": "api_pool_io_rate{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Total IOPS",
          "data_type": "Number",
          "unit": "cps",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Total I/O operations per second of the storage pool"
        },
        {
          "metric_group": "IOPS",
          "name": "api_pool_read_io",
          "query": "api_pool_read_io{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Read IOPS",
          "data_type": "Number",
          "unit": "cps",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Read I/O operations per second of the storage pool"
        },
        {
          "metric_group": "IOPS",
          "name": "api_pool_write_io",
          "query": "api_pool_write_io{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Write IOPS",
          "data_type": "Number",
          "unit": "cps",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Write I/O operations per second of the storage pool"
        },
        {
          "metric_group": "Throughput",
          "name": "api_pool_read",
          "query": "api_pool_read{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Read Throughput",
          "data_type": "Number",
          "unit": "byteps",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Read throughput of the storage pool in bytes per second"
        },
        {
          "metric_group": "Throughput",
          "name": "api_pool_write",
          "query": "api_pool_write{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Write Throughput",
          "data_type": "Number",
          "unit": "byteps",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Write throughput of the storage pool in bytes per second"
        },
        {
          "metric_group": "Latency",
          "name": "api_pool_resp_t",
          "query": "api_pool_resp_t{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Average Response Time",
          "data_type": "Number",
          "unit": "ms",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Average I/O response time of the storage pool in milliseconds"
        },
        {
          "metric_group": "Latency",
          "name": "api_pool_resp_t_r",
          "query": "api_pool_resp_t_r{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Read Response Time",
          "data_type": "Number",
          "unit": "ms",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Average read response time of the storage pool in milliseconds"
        },
        {
          "metric_group": "Latency",
          "name": "api_pool_resp_t_w",
          "query": "api_pool_resp_t_w{resource_type=\"oceanstor_pool\", __$labels__}",
          "display_name": "Write Response Time",
          "data_type": "Number",
          "unit": "ms",
          "dimensions": [],
          "instance_id_keys": ["instance_id", "resource_id"],
          "description": "Average write response time of the storage pool in milliseconds"
        }
      ]
    },
