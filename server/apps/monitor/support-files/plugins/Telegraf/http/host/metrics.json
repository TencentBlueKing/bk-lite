{
  "plugin": "Host Remote",
  "plugin_desc": "Remote host metrics collection via SSH/WinRM through Ansible Executor. Supports CPU, memory, disk, and network metrics without agent installation on target hosts.",
  "status_query": "any({instance_type='os', collect_type='http', config_type='host'}) by (instance_id)",
  "node_selector": {
    "is_container": true
  },
  "name": "Host",
  "icon": "mm-host_主机",
  "type": "OS",
  "description": "Remote agentless host monitoring via SSH/WinRM",
  "default_metric": "any({instance_type='os'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": ["cpu_usage_total", "mem_used_percent", "disk_used_percent"],
  "display_fields": [
    {"name":"CPU使用率","sort_order":0,"metrics":[{"plugin":"Host","metric":"cpu_usage_total"},{"plugin":"Windows WMI","metric":"cpu_usage_total"},{"plugin":"Host Remote","metric":"cpu_usage_total"}]},
    {"name":"内存使用率","sort_order":1,"metrics":[{"plugin":"Host","metric":"mem_used_percent"},{"plugin":"Windows WMI","metric":"mem_used_percent"},{"plugin":"Host Remote","metric":"mem_used_percent"}]},
    {"name":"磁盘使用率","sort_order":2,"metrics":[{"plugin":"Host","metric":"disk_used_percent"},{"plugin":"Windows WMI","metric":"disk_used_percent"},{"plugin":"Host Remote","metric":"disk_used_percent"}]},
    {"name":"网络入向吞吐","sort_order":3,"metrics":[{"plugin":"Host","metric":"net_bytes_recv_rate"},{"plugin":"Windows WMI","metric":"net_bytes_recv_rate"},{"plugin":"Host Remote","metric":"net_bytes_recv_rate"}]},
    {"name":"磁盘IO使用率","sort_order":4,"metrics":[{"plugin":"Host","metric":"diskio_io_util"},{"plugin":"Windows WMI","metric":"diskio_io_util"}]}
  ],
  "metrics": [
    {
      "metric_group": "CPU",
      "name": "cpu_usage_total",
      "query": "host_cpu_usage_percent_gauge{instance_type=\"os\", __$labels__}",
      "display_name": "CPU Usage",
      "data_type": "Number",
      "unit": "%",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "CPU usage percentage"
    },
