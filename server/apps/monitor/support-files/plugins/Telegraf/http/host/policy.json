{
  "object": "Host",
  "plugin": "Host Remote",
  "templates": [
    {
      "name": "CPU使用率过高",
      "alert_name": "主机${instance_id} CPU使用率过高",
      "description": "监控主机CPU使用率，当超出设定阈值时触发告警。",
      "metric_name": "cpu_usage_total",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">"
        },
        {
          "level": "error",
          "value": 90,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">"
        }
      ]
    },
    {
      "name": "内存使用率过高",
      "alert_name": "主机${instance_id} 内存使用率过高",
      "description": "监控主机内存使用率，当超出设定阈值时触发告警。",
      "metric_name": "mem_used_percent",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">"
        },
        {
          "level": "error",
          "value": 90,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">"
        }
      ]
    },
    {
      "name": "磁盘使用率过高",
      "alert_name": "主机${instance_id} 磁盘${mount}使用率过高",
      "description": "监控主机磁盘使用率，当超出设定阈值时触发告警。",
      "metric_name": "disk_used_percent",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">"
        },
        {
          "level": "error",
          "value": 90,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">"
        }
      ]
    },
    {
      "name": "网卡入流量过高",
      "alert_name": "主机${instance_id}接口${metric_interface} 网卡入流量过高",
      "description": "监控主机网卡入流量速率，当超出设定阈值时触发告警。",
      "metric_name": "net_bytes_recv_rate",
      "algorithm": "max_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 104857600,
          "method": ">"
        },
        {
          "level": "error",
          "value": 52428800,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10485760,
          "method": ">"
        }
      ]
    },
    {
      "name": "网卡出流量过高",
      "alert_name": "主机${instance_id}接口${metric_interface} 网卡出流量过高",
      "description": "监控主机网卡出流量速率，当超出设定阈值时触发告警。",
      "metric_name": "net_bytes_sent_rate",
      "algorithm": "max_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 104857600,
          "method": ">"
        },
        {
          "level": "error",
          "value": 52428800,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 10485760,
          "method": ">"
        }
      ]
    }
  ]
}
