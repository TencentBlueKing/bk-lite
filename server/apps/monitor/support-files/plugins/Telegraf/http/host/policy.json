{
  "object": "Host",
  "plugin": "Host Remote",
  "templates": [
    {
      "name": "CPU使用率过高",
      "alert_name": "主机${instance_id} CPU使用率过高",
      "description": "监控主机CPU使用率，当超出设定阈值时触发告警。",
      "metric_name": "host_cpu_usage_percent",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">"
        },
        {
          "level": "error",
          "value": 90,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">"
        }
      ]
    },
    {
      "name": "内存使用率过高",
      "alert_name": "主机${instance_id} 内存使用率过高",
      "description": "监控主机内存使用率，当可用内存低于阈值时触发告警。",
      "metric_name": "host_mem_available_bytes",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 104857600,
          "method": "<"
        },
        {
          "level": "error",
          "value": 524288000,
          "method": "<"
        },
        {
          "level": "warning",
          "value": 1073741824,
          "method": "<"
        }
      ]
    },
    {
      "name": "磁盘使用率过高",
      "alert_name": "主机${instance_id} 磁盘${mount}使用率过高",
      "description": "监控主机磁盘使用率，当超出设定阈值时触发告警。",
      "metric_name": "host_disk_used_percent",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">"
        },
        {
          "level": "error",
          "value": 90,
          "method": ">"
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">"
        }
      ]
    }
  ]
}
