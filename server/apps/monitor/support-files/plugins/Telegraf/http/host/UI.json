{
  "object_name": "Host",
  "instance_type": "os",
  "collect_type": "http",
  "config_type": ["host"],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{instance_type}}_{{host}}",
  "form_fields": [
    {
      "name": "host",
      "label": "目标主机IP",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "目标主机的IP地址",
      "widget_props": {
        "placeholder": "10.0.0.1"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.host"
      }
    },
    {
      "name": "os_type",
      "label": "操作系统",
      "type": "select",
      "required": true,
      "default_value": "linux",
      "description": "目标主机操作系统类型",
      "widget_props": {
        "options": [
          {"label": "Linux", "value": "linux"},
          {"label": "Windows", "value": "windows"}
        ]
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.os_type"
      }
    },
    {
      "name": "metrics_modules",
      "type": "hidden",
      "required": true,
      "default_value": ["cpu", "mem", "disk", "diskio", "net", "processes", "system"],
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.metrics_modules",
        "to_form": {
          "array": true
        }
      }
    },
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": true,
      "editable": false,
      "description": "SSH/WinRM 登录用户名",
      "widget_props": {
        "placeholder": "root / Administrator"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.username"
      }
    },
    {
      "name": "auth_type",
      "label": "Linux认证方式",
      "type": "select",
      "required": false,
      "default_value": "password",
      "description": "Linux SSH 认证方式。Windows 始终使用 WinRM 密码认证。",
      "widget_props": {
        "options": [
          {"label": "密码", "value": "password"},
          {"label": "SSH密钥", "value": "private_key"}
        ]
      },
      "dependency": {
        "field": "os_type",
        "value": "linux"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.auth_type"
      }
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": true,
      "editable": false,
      "encrypted": true,
      "description": "SSH/WinRM 登录密码",
      "widget_props": {
        "placeholder": "密码"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      }
    },
    {
      "name": "private_key_content",
      "label": "SSH私钥",
      "type": "password",
      "required": false,
      "editable": false,
      "encrypted": true,
      "description": "Linux SSH 私钥内容，仅认证方式为 SSH密钥 时使用",
      "widget_props": {
        "placeholder": "-----BEGIN OPENSSH PRIVATE KEY-----"
      },
      "dependency": {
        "field": "auth_type",
        "value": "private_key"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PRIVATE_KEY_CONTENT__{{config_id}}"
      }
    },
    {
      "name": "private_key_passphrase",
      "label": "SSH私钥口令",
      "type": "password",
      "required": false,
      "editable": false,
      "encrypted": true,
      "description": "Linux SSH 私钥口令，可为空",
      "widget_props": {
        "placeholder": "私钥口令"
      },
      "dependency": {
        "field": "auth_type",
        "value": "private_key"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PRIVATE_KEY_PASSPHRASE__{{config_id}}"
      }
    },
    {
      "name": "port",
      "label": "端口",
      "type": "input",
      "required": false,
      "default_value": "",
      "description": "连接端口。Linux SSH 默认 22，Windows WinRM 默认 5986。",
      "widget_props": {
        "placeholder": "Linux: 22 / Windows: 5986"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.port"
      }
    },
    {
      "name": "winrm_scheme",
      "label": "WinRM协议",
      "type": "select",
      "required": false,
      "default_value": "https",
      "description": "Windows WinRM 协议",
      "widget_props": {
        "options": [
          {"label": "HTTPS", "value": "https"},
          {"label": "HTTP", "value": "http"}
        ]
      },
      "dependency": {
        "field": "os_type",
        "value": "windows"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.winrm_scheme"
      }
    },
    {
      "name": "winrm_transport",
      "label": "WinRM认证方式",
      "type": "select",
      "required": false,
      "default_value": "ntlm",
      "description": "推荐 NTLM。Basic 需要目标 Windows 开启 Basic 认证，默认通常未开启。",
      "widget_props": {
        "options": [
          {"label": "NTLM", "value": "ntlm"},
          {"label": "Basic", "value": "basic"},
          {"label": "CredSSP", "value": "credssp"}
        ]
      },
      "dependency": {
        "field": "os_type",
        "value": "windows"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.winrm_transport"
      }
    },
    {
      "name": "winrm_cert_validation",
      "label": "校验WinRM证书",
      "type": "switch",
      "required": false,
      "default_value": false,
      "description": "HTTPS WinRM 是否校验证书。自签证书场景建议关闭。",
      "dependency": {
        "field": "os_type",
        "value": "windows"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.http_headers.winrm_cert_validation"
      }
    },
    {
      "name": "interval",
      "label": "采集间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 10,
        "precision": 0,
        "placeholder": "60",
        "addonAfter": "s"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      }
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点"
      },
      "enable_row_filter": false
    },
    {
      "name": "host",
      "label": "目标主机IP",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "10.0.0.1"
      },
      "change_handler": {
        "type": "simple",
        "source_fields": ["host"],
        "target_field": "instance_name"
      }
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false
      }
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组"
      }
    }
  ],
  "extra_edit_fields": {}
}
