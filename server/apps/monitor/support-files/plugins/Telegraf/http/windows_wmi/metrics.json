{
  "plugin": "Windows WMI",
  "plugin_desc": "Remote Windows host metrics collection through WMI/DCOM from Stargazer. Requires WMI service, account permission, and WMI/DCOM/RPC network reachability.",
  "status_query": "any({instance_type='os', collect_type='http', config_type='windows_wmi'}) by (instance_id)",
  "node_selector": {
    "is_container": true
  },
  "name": "Host",
  "icon": "mm-host_主机",
  "type": "OS",
  "description": "Remote Windows host monitoring through WMI",
  "default_metric": "any({instance_type='os'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": ["cpu_usage_total", "mem_used_percent", "disk_used_percent"],
  "display_fields": [
    {
      "name": "CPU Usage",
      "sort_order": 0,
      "metrics": [{"plugin": "Windows WMI", "metric": "cpu_usage_total"}]
    },
    {
      "name": "Memory Usage",
      "sort_order": 1,
      "metrics": [{"plugin": "Windows WMI", "metric": "mem_used_percent"}]
    },
    {
      "name": "Disk Usage",
      "sort_order": 2,
      "metrics": [{"plugin": "Windows WMI", "metric": "disk_used_percent"}]
    }
  ],
  "metrics": [
    {
      "metric_group": "CPU",
      "name": "cpu_usage_total",
      "query": "cpu_usage_total_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "CPU Usage",
      "data_type": "Number",
      "unit": "%",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "CPU usage percentage"
    },
    {
      "metric_group": "Memory",
      "name": "mem_used_percent",
      "query": "mem_used_percent_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Memory Usage",
      "data_type": "Number",
      "unit": "%",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "Used memory percentage"
    },
    {
      "metric_group": "Disk",
      "name": "disk_used_percent",
      "query": "disk_used_percent_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Disk Usage",
      "data_type": "Number",
      "unit": "%",
      "dimensions": [{"name": "device"}],
      "instance_id_keys": ["instance_id"],
      "description": "Disk usage percentage per logical disk"
    },
    {
      "metric_group": "Memory",
      "name": "mem_total",
      "query": "mem_total_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Memory Total",
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "Total memory in bytes"
    },
    {
      "metric_group": "Memory",
      "name": "mem_available",
      "query": "mem_available_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Memory Available",
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "Available memory in bytes"
    },
    {
      "metric_group": "Disk",
      "name": "disk_total",
      "query": "disk_total_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Disk Total",
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [{"name": "device"}],
      "instance_id_keys": ["instance_id"],
      "description": "Total disk space in bytes per logical disk"
    },
    {
      "metric_group": "Disk",
      "name": "disk_free",
      "query": "disk_free_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Disk Free",
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [{"name": "device"}],
      "instance_id_keys": ["instance_id"],
      "description": "Free disk space in bytes per logical disk"
    },
    {
      "metric_group": "Network",
      "name": "net_packets_recv_rate",
      "query": "rate(net_packets_recv_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Receive Packet Rate",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "interface"}],
      "instance_id_keys": ["instance_id"],
      "description": "Network received packet rate over the past 5 minutes"
    },
    {
      "metric_group": "Network",
      "name": "net_packets_sent_rate",
      "query": "rate(net_packets_sent_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Transmit Packet Rate",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "interface"}],
      "instance_id_keys": ["instance_id"],
      "description": "Network transmitted packet rate over the past 5 minutes"
    },
    {
      "metric_group": "Network",
      "name": "net_bytes_recv_rate",
      "query": "rate(net_bytes_recv_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Receive Byte Rate",
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [{"name": "interface"}],
      "instance_id_keys": ["instance_id"],
      "description": "Network received byte rate over the past 5 minutes"
    },
    {
      "metric_group": "Network",
      "name": "net_bytes_sent_rate",
      "query": "rate(net_bytes_sent_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
