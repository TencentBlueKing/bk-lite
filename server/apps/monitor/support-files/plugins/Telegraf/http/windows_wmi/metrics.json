    },
    {
      "metric_group": "Network",
      "name": "net_drop_out_rate",
      "query": "rate(net_drop_out_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Transmit Drop Rate",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "interface"}],
      "instance_id_keys": ["instance_id"],
      "description": "Network transmit drop rate over the past 5 minutes"
    },
    {
      "metric_group": "Disk IO",
      "name": "diskio_io_util",
      "query": "diskio_io_util_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}",
      "display_name": "Disk IO Utilization",
      "data_type": "Number",
