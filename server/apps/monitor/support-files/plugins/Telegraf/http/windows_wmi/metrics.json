    },
    {
      "metric_group": "Network",
      "name": "net_err_in_rate",
      "query": "rate(net_err_in_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Receive Error Rate",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "interface"}],
      "instance_id_keys": ["instance_id"],
      "description": "Network receive error rate over the past 5 minutes"
    },
    {
      "metric_group": "Network",
      "name": "net_err_out_rate",
      "query": "rate(net_err_out_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Transmit Error Rate",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "interface"}],
      "instance_id_keys": ["instance_id"],
      "description": "Network transmit error rate over the past 5 minutes"
    },
    {
      "metric_group": "Network",
      "name": "net_drop_in_rate",
      "query": "rate(net_drop_in_gauge_value{instance_type=\"os\", config_type=\"windows_wmi\", __$labels__}[5m])",
      "display_name": "Network Receive Drop Rate",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "interface"}],
