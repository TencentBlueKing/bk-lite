      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Average write response time of each storage pool in milliseconds"
    },
    {
      "metric_group": "Drive IOPS",
      "name": "api_drive_io_rate",
      "query": "api_drive_io_rate{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Drive Total IOPS",
      "data_type": "Number",
