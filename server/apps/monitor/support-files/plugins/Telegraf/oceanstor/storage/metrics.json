{
  "plugin": "OceanStor",
  "plugin_desc": "Huawei OceanStor storage monitoring plugin. Collects performance metrics from storage pools, drives, and volumes via the DeviceManager REST API.",
  "status_query": "any({instance_type='storage', collect_type='oceanstor'}) by (instance_id)",
  "name": "Storage",
  "icon": "mm-storage_储存设备",
  "type": "Hardware Device",
  "description": "",
  "default_metric": "any({instance_type='storage'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": [
    "oceanstor_pool_count",
    "oceanstor_drive_count",
    "oceanstor_volume_count",
    "api_pool_io_rate",
    "api_drive_io_rate",
    "api_volume_io_rate"
  ],
  "metrics": [
    {
      "metric_group": "Quantity",
      "name": "oceanstor_pool_count",
      "query": "count by (instance_id) (sum by (instance_id, pool_id) (api_pool_io_rate{resource_type=\"oceanstor\"}))",
      "display_name": "Number of Pools",
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "Total number of storage pools in the OceanStor system"
    },
    {
      "metric_group": "Quantity",
      "name": "oceanstor_drive_count",
      "query": "count by (instance_id) (sum by (instance_id, drive_id) (api_drive_io_rate{resource_type=\"oceanstor\"}))",
      "display_name": "Number of Drives",
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "Total number of physical drives in the OceanStor system"
    },
    {
      "metric_group": "Quantity",
      "name": "oceanstor_volume_count",
      "query": "count by (instance_id) (sum by (instance_id, volume_id) (api_volume_io_rate{resource_type=\"oceanstor\"}))",
      "display_name": "Number of Volumes",
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "instance_id_keys": ["instance_id"],
      "description": "Total number of LUN volumes in the OceanStor system"
    },
    {
      "metric_group": "Pool IOPS",
      "name": "api_pool_io_rate",
      "query": "api_pool_io_rate{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Total IOPS",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Total I/O operations per second of each storage pool"
    },
    {
      "metric_group": "Pool IOPS",
      "name": "api_pool_read_io",
      "query": "api_pool_read_io{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Read IOPS",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Read I/O operations per second of each storage pool"
    },
    {
      "metric_group": "Pool IOPS",
      "name": "api_pool_write_io",
      "query": "api_pool_write_io{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Write IOPS",
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Write I/O operations per second of each storage pool"
    },
    {
      "metric_group": "Pool Throughput",
      "name": "api_pool_read",
      "query": "api_pool_read{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Read Throughput",
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Read throughput of each storage pool in bytes per second"
    },
    {
      "metric_group": "Pool Throughput",
      "name": "api_pool_write",
      "query": "api_pool_write{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Write Throughput",
      "data_type": "Number",
      "unit": "byteps",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Write throughput of each storage pool in bytes per second"
    },
    {
      "metric_group": "Pool Latency",
      "name": "api_pool_resp_t",
      "query": "api_pool_resp_t{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Average Response Time",
      "data_type": "Number",
      "unit": "ms",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Average I/O response time of each storage pool in milliseconds"
    },
    {
      "metric_group": "Pool Latency",
      "name": "api_pool_resp_t_r",
      "query": "api_pool_resp_t_r{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Read Response Time",
      "data_type": "Number",
      "unit": "ms",
      "dimensions": [{"name": "pool_id", "description": "Pool ID"}],
      "instance_id_keys": ["instance_id"],
      "description": "Average read response time of each storage pool in milliseconds"
    },
    {
      "metric_group": "Pool Latency",
      "name": "api_pool_resp_t_w",
      "query": "api_pool_resp_t_w{resource_type=\"oceanstor\", __$labels__}",
      "display_name": "Pool Write Response Time",
      "data_type": "Number",
