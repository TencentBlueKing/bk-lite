[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_stormshield"
        config_type = "stormshield"
        brand = "stormshield"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Stormshield CPU usage (HOST-RESOURCES hrProcessorLoad, per-core %, headline avg by instance) ----
    # 待现网核验：1.3.6.1.2.1.25.3.3.1.2（每核 0-100%，共享盘 avg by instance_id 取整机均值）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.25.3.3.1.2"
        name = "usage"
    # ---- Stormshield memory (UCD-SNMP-MIB, total + free, KB; used/usage 由 total-free 计算) ----
    # 待现网核验：memTotalReal 1.3.6.1.4.1.2021.4.5.0；memAvailReal 1.3.6.1.4.1.2021.4.6.0（均为 KB，共享盘 *1024 转字节）。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2021.4.5.0"
        name = "total"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2021.4.6.0"
        name = "free"
    # ---- Stormshield firewall-specific (ASQ TCP/UDP connections + mature VPN tunnels, scalars) ----
    # 待现网核验：snsASQTCPConnCount 1.3.6.1.4.1.11256.1.12.1.23.0；snsASQUDPConnCount ...1.12.1.33.0；
    #            snsVPNNbMatureSA 1.3.6.1.4.1.11256.1.13.2.2.0（活动/成熟 VPN 隧道数）。
    [[inputs.snmp.table]]
        name = "firewall"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.11256.1.12.1.23.0"
        name = "tcp_connections"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.11256.1.12.1.33.0"
        name = "udp_connections"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.11256.1.13.2.2.0"
        name = "vpn_tunnels"
