[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_alcatel"
        config_type = "alcatel"
        brand = "alcatel"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- Alcatel-Lucent TiMOS CPU utilization (TIMETRA-CHASSIS-MIB sgiCpuUsage, scalar %) ----
    # 待现网核验：1.3.6.1.4.1.6527.3.1.2.1.1.1.0（已是 0-100%）。用 table(measurement=device_cpu)+field usage → 指标 device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.1.1.1.0"
        name = "usage"
    # ---- Alcatel-Lucent TiMOS system memory pool (used + available, KB) ----
    # 待现网核验：used sgiMemoryUsed 1.3.6.1.4.1.6527.3.1.2.1.1.9.0；free sgiMemoryAvailable ...1.1.10.0。
    # ⚠ 原始单位 KB（模版有 MULTIPLIER 1024 → bytes），inputs.snmp 不能算术缩放 → 采到的是 KB；
    #   利用率 used/(used+free) 比值与单位无关(KB 抵消)正确；绝对 device_memory_used 是 KB(显示偏小 1024 倍)留「待现网核验」。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.1.1.9.0"
        name = "used"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.1.1.10.0"
        name = "free"
    # ---- Alcatel-Lucent TiMOS hardware temperature (TIMETRA-CHASSIS-MIB tmnxHwTemperature, °C) ----
    # 待现网核验：温度 1.3.6.1.4.1.6527.3.1.2.2.1.8.1.18（模版单位 °C，无需换算）；descr=tmnxHwName ...8.1.8。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.2.1.8.1.8"
        name = "descr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.2.1.8.1.18"
        name = "celsius"
    # ---- Alcatel-Lucent TiMOS fans (TIMETRA-CHASSIS-MIB tmnxChassisFanOperStatus, TmnxDeviceState) ----
    # 待现网核验：风扇状态 1.3.6.1.4.1.6527.3.1.2.2.1.4.1.2（无独立 descr 名列，省略 descr）。
    # 枚举 TmnxDeviceState 非 1=normal：3 deviceStateOk → 下方 processors.enum 归一(3→1，其余→2)。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.2.1.4.1.2"
        name = "state"
    # ---- Alcatel-Lucent TiMOS power supplies (TIMETRA-CHASSIS-MIB tmnxChassisPowerSupplyStatus, TmnxDeviceState) ----
    # 待现网核验：电源状态 1.3.6.1.4.1.6527.3.1.2.2.1.5.1.7（无独立 descr 名列，省略 descr）。
    # 枚举同风扇：3 deviceStateOk → 下方 processors.enum 归一(3→1，其余→2)。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.6527.3.1.2.2.1.5.1.7"
        name = "state"

# ---- 枚举归一：把 Alcatel TmnxDeviceState 映射到统一 1=normal/2=abnormal（偏离1即异常）----
# 待现网核验：仅作用于本品牌(tagpass brand=alcatel)，避免影响其它品牌同名字段。
# 健康态 3 deviceStateOk → 1；其余(1 unknown/2 notEquipped/4 failed/5 outOfService)→2。
[[processors.enum]]
    [processors.enum.tagpass]
        brand = ["alcatel"]
    [[processors.enum.mapping]]
        field = "device_fan_state"
        dest = "device_fan_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "3" = 1
    [[processors.enum.mapping]]
        field = "device_psu_state"
        dest = "device_psu_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "3" = 1
