[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_qtech"
        config_type = "qtech"
        brand = "qtech"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- QTech CPU utilization (QTECH-MIB, scalar %) ----
    # 待现网核验：1.3.6.1.4.1.27514.100.1.11.10.0（已是 0-100%）。用 table(measurement=device_cpu)+field usage → 指标 device_cpu_usage。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.27514.100.1.11.10.0"
        name = "usage"
    # ---- QTech system memory (QTECH-MIB, used + total, bytes) ----
    # 待现网核验：used 1.3.6.1.4.1.27514.100.1.11.7.0；total ...1.11.6.0 → device_memory_used/device_memory_total。
    # 利用率在共享盘按 used/total 计算。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.27514.100.1.11.7.0"
        name = "used"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.27514.100.1.11.6.0"
        name = "total"
    # ---- QTech temperature (QTECH-MIB switchTemperature, scalar °C) ----
    # 待现网核验：1.3.6.1.4.1.27514.100.1.11.9.0（整机 testpoint 单值，°C，无 per-sensor descr）。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.27514.100.1.11.9.0"
        name = "celsius"
    # ---- QTech fans (QTECH-MIB sysFanStatus) ----
    # 待现网核验：风扇状态 1.3.6.1.4.1.27514.100.1.12.1.3（无独立 descr 名列，省略 descr）。
    # 枚举 sysFanStatus：0 normal / 1 abnormal。**正常态=0 非 1 → 下方 processors.enum 归一(0→1，其余→2)**。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.27514.100.1.12.1.3"
        name = "state"
    # ---- QTech power supplies (QTECH-MIB sysPowerStatus) ----
    # 待现网核验：电源状态 1.3.6.1.4.1.27514.100.1.7.1.5（无独立 descr 名列，省略 descr）。
    # 枚举 sysPowerStatus：0 normal / 1 abnormal / 2 not available。**正常态=0 非 1 → 下方 processors.enum 归一(0→1，其余→2)**。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.27514.100.1.7.1.5"
        name = "state"

# ---- 枚举归一：QTech sysFanStatus/sysPowerStatus 原生 0=normal → 统一 1=normal/2=abnormal（偏离1即异常）----
# 待现网核验：仅作用于本品牌(tagpass brand=qtech)。normal(0)→1；其余(1 abnormal / 2 not available)→2。
[[processors.enum]]
    [processors.enum.tagpass]
        brand = ["qtech"]
    [[processors.enum.mapping]]
        field = "device_fan_state"
        dest = "device_fan_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
    [[processors.enum.mapping]]
        field = "device_psu_state"
        dest = "device_psu_state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "0" = 1
