[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_huawei_ar"
        config_type = "huawei_ar"
        brand = "huawei_ar"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Huawei CPU utilization (HUAWEI-ENTITY-EXTENT-MIB hwEntityCpuUsage, per entity, %) ----
    # 来源：官方 HUAWEI-ENTITY-EXTENT-MIB（复用已产 huawei switch 的 OID，AR 路由器同 MIB）。
    # 待现网核验：hwEntityCpuUsage 1.3.6.1.4.1.2011.5.25.31.1.1.1.1.5（已归一化为 0-100%）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.1.1.5"
        name = "usage"
    # ---- Huawei memory utilization (HUAWEI-ENTITY-EXTENT-MIB hwEntityMemUsage, % 直报，per entity) ----
    # 待现网核验：hwEntityMemUsage 1.3.6.1.4.1.2011.5.25.31.1.1.1.1.7 → 统一 device_memory_usage(原始%)。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.1.1.7"
        name = "usage"
    # ---- Huawei chassis temperature (HUAWEI-ENTITY-EXTENT-MIB hwEntityTemperature, °C, per entity, same hwEntityStateTable) ----
    # 待现网核验：hwEntityTemperature 1.3.6.1.4.1.2011.5.25.31.1.1.1.1.11（°C，不支持的实体报哨兵 -1）。
    # device_temperature_celsius 在 metrics.json 用 (x != -1) 过滤未支持实体后 max() by instance_id。
    [[inputs.snmp.table]]
        name = "device_temperature"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.1.1.11"
        name = "celsius"
    # ---- Huawei fan state (HUAWEI-ENTITY-EXTENT-MIB hwEntityFanState, hwFanStatusTable) ----
    # 待现网核验：hwEntityFanState 1.3.6.1.4.1.2011.5.25.31.1.1.10.1.7（原始码 normal(1)/abnormal(2)，恰为本系统 1=正常/2=异常约定，无需 enum 归一）。
    [[inputs.snmp.table]]
        name = "device_fan"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.10.1.7"
        name = "state"
    # ---- Huawei PSU state (HUAWEI-ENTITY-EXTENT-MIB hwEntityPwrState, hwPwrStatusTable) ----
    # 待现网核验：hwEntityPwrState 1.3.6.1.4.1.2011.5.25.31.1.1.18.1.6（原始码 supply(1)/notSupply(2)/sleep(3)/unknown(4)）。
    # 下方 processors.enum 归一为 1=正常(1供电/3休眠待机=冗余正常)/2=异常(2无供电/4未知)。
    [[inputs.snmp.table]]
        name = "device_psu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.2011.5.25.31.1.1.18.1.6"
        name = "state"
# ---- BGP 邻居走 BGP4-MIB bgpPeerTable(per-peer walk,需聚合计数)→本轮 N/A,后续可补 BGP peer 数。----

# ---- 电源状态归一：1=supply(供电)/3=sleep(冗余待机)→1(正常)，2=notSupply/4=unknown→2(异常)。风扇 normal(1)/abnormal(2) 已是本约定,无需归一。----
[[processors.enum]]
    namepass = ["device_psu"]
    [[processors.enum.mapping]]
        field = "state"
        default = 2
        [processors.enum.mapping.value_mappings]
            "1" = 1
            "3" = 1
