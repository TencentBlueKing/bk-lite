{
  "object_name": "ElasticSearch",
  "instance_type": "elasticsearch",
  "collect_type": "database",
  "config_type": [
    "elasticsearch"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{server}}",
  "form_fields": [
    {
      "name": "server",
      "label": "服务器地址",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "监控对象的服务器地址",
      "guide_short": "填写完整 URL，含端口与协议，例如 http://10.0.0.10:9200；保存前可在采集节点用 curl 验证连通性。",
      "widget_props": {
        "placeholder": "http://localhost:9200"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]"
      },
      "label_en": "Server Address"
    },
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": true,
      "editable": false,
      "description": "用于访问接口的用户名",
      "guide_short": "建议使用只读监控账号，至少可读 _cluster/health 与 _nodes/stats",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.username"
      },
      "label_en": "Username",
      "description_en": "Username for accessing the interface"
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": true,
      "editable": false,
      "description": "对应的登录密码",
      "guide_short": "填写与用户名对应的登录密码，注意不要带入首尾空格。",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      },
      "label_en": "Password",
      "description_en": "Corresponding login password"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "guide_short": "默认 60 秒；过低会增加 ES 集群压力，过高会延误告警。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "server",
      "label": "服务器地址",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "http://localhost:9200"
      },
      "rules": [
        {
          "type": "pattern",
          "pattern": "^(http|https)://.*",
          "message": "服务器地址必须以http://或https://开头",
          "excel_formula": "OR(LEFT({{CELL}},7)=\"http://\",LEFT({{CELL}},8)=\"https://\")"
        }
      ],
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "server"
        ],
        "target_field": "instance_name"
      },
      "label_en": "Server Address"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}