{
  "object_name": "Mysql",
  "instance_type": "mysql",
  "collect_type": "database",
  "config_type": [
    "mysql"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{host}}_{{port}}",
  "form_fields": [
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": true,
      "editable": false,
      "description": "用于连接 MySQL 数据库的用户名",
      "guide_short": "建议使用专用只读监控账号，至少具备 PROCESS 与 REPLICATION CLIENT 权限，以及 performance_schema / information_schema 的 SELECT 权限。",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "^([^:]+):"
        }
      },
      "label_en": "Username"
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": true,
      "editable": false,
      "description": "用于连接 MySQL 数据库的密码",
      "guide_short": "填写与用户名对应的登录密码，注意不要带入首尾空格或换行；MySQL 8.0 默认 caching_sha2_password，请确认采集端驱动兼容。",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      },
      "label_en": "Password"
    },
    {
      "name": "host",
      "label": "主机",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "与设备进行通信的主机",
      "guide_short": "填写 MySQL 实例的 IP 或域名，例如 10.0.0.10；保存前可在采集节点用 mysql -h <host> -u <user> -p 验证连通。",
      "widget_props": {
        "placeholder": "主机地址"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "@tcp\\(([^:]+):"
        }
      },
      "label_en": "Host"
    },
    {
      "name": "port",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "与设备进行通信的端口",
      "guide_short": "MySQL 服务监听端口，默认 3306；若修改过 my.cnf 的 port，请填写实际端口；本端口与任何 exporter 端口无关。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口",
        "placeholder_en": "Port"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "@tcp\\([^:]+:(\\d+)\\)"
        }
      },
      "label_en": "Port"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "guide_short": "默认 60 秒；过低会增加 MySQL 实例压力，过高会延误告警；建议不少于 30 秒。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "host",
      "label": "主机",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "主机地址"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": [
          "host",
          "port"
        ],
        "target_field": "instance_name",
        "separator": ":"
      },
      "label_en": "Host"
    },
    {
      "name": "port",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口",
        "placeholder_en": "Port"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": [
          "host",
          "port"
        ],
        "target_field": "instance_name",
        "separator": ":"
      },
      "label_en": "Port"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}