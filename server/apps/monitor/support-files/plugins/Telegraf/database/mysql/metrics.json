      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "MySQL super_read_only setting, commonly enabled on replicas to prevent accidental writes",
      "query": "max by (instance_id) (mysql_variables_super_read_only{__$labels__})"
    },
    {
      "metric_group": "Replication",
      "name": "mysql_variables_log_bin",
      "display_name": "Binary Log Enabled",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Whether binary logging is enabled, used to identify primary or replication-capable instances",
      "query": "max by (instance_id) (mysql_variables_log_bin{__$labels__})"
    },
    {
      "metric_group": "Replication",
      "name": "mysql_variables_log_slave_updates",
      "display_name": "Log Replica Updates Enabled",
      "instance_id_keys": ["instance_id"],
