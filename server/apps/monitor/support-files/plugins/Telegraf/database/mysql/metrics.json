    },
    {
      "metric_group": "TableCache",
      "name": "mysql_variables_open_files_limit",
      "display_name": "Open Files Limit Setting",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Configured open_files_limit used as the file descriptor capacity baseline",
      "query": "mysql_variables_open_files_limit{__$labels__}"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_open_tables",
      "display_name": "Open Tables",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of currently open table handles",
      "query": "mysql_open_tables{__$labels__}"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_opened_tables_rate",
      "display_name": "Opened Tables Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Rate of table openings, high values may indicate insufficient table cache",
      "query": "rate(mysql_opened_tables{__$labels__}[5m])"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_open_files",
      "display_name": "Open Files",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of open files used by MySQL",
      "query": "mysql_open_files{__$labels__}"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_open_files_utilization",
      "display_name": "Open Files Utilization",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of current open files to open_files_limit, used to assess file descriptor pressure",
      "query": "100 * max by (instance_id) (mysql_open_files{__$labels__}) / on(instance_id) clamp_min(max by (instance_id) (mysql_variables_open_files_limit{__$labels__}), 1)"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_table_open_cache_utilization",
      "display_name": "Table Open Cache Utilization",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of open tables to table_open_cache, used to assess table cache capacity pressure",
      "query": "100 * max by (instance_id) (mysql_open_tables{__$labels__}) / on(instance_id) clamp_min(max by (instance_id) (mysql_variables_table_open_cache{__$labels__}), 1)"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_table_open_cache_hits_rate",
      "display_name": "Table Cache Hits Ratio",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Table cache hit rate; <95% requires adjusting table_open_cache configuration",
      "query": "100 * rate(mysql_table_open_cache_hits{__$labels__}[5m]) / clamp_min(rate(mysql_table_open_cache_hits{__$labels__}[5m]) + rate(mysql_table_open_cache_misses{__$labels__}[5m]), 1e-6)"
    },
    {
      "metric_group": "TableCache",
      "name": "mysql_table_open_cache_misses_rate",
      "display_name": "Table Cache Misses Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Number of table open cache miss requests, reflecting table cache hit status",
      "query": "rate(mysql_table_open_cache_misses{__$labels__}[5m])"
    },
    {
      "metric_group": "KeyCache",
      "name": "mysql_key_reads_rate",
      "display_name": "Key Reads Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "MyISAM key blocks read from disk",
      "query": "rate(mysql_key_reads{__$labels__}[5m])"
    },
    {
      "metric_group": "KeyCache",
      "name": "mysql_key_read_requests_rate",
      "display_name": "Key Read Requests Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Logical MyISAM key read requests",
      "query": "rate(mysql_key_read_requests{__$labels__}[5m])"
    },
    {
      "metric_group": "KeyCache",
      "name": "mysql_key_cache_hit_ratio",
      "display_name": "Key Cache Hit Ratio",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of MyISAM key reads served from cache",
      "query": "100 * (1 - rate(mysql_key_reads{__$labels__}[5m]) / clamp_min(rate(mysql_key_read_requests{__$labels__}[5m]), 1e-6))"
    },
    {
      "metric_group": "TempTable",
      "name": "mysql_variables_tmp_table_size",
      "display_name": "Tmp Table Size Setting",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "Configured tmp_table_size threshold, useful for temporary table memory headroom analysis",
      "query": "mysql_variables_tmp_table_size{__$labels__}"
    },
    {
      "metric_group": "TempTable",
      "name": "mysql_variables_max_heap_table_size",
      "display_name": "Max Heap Table Size Setting",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "Configured max_heap_table_size threshold, used with tmp_table_size to assess in-memory temp table limits",
      "query": "mysql_variables_max_heap_table_size{__$labels__}"
    },
    {
      "metric_group": "InnoDBPerf",
      "name": "mysql_variables_innodb_buffer_pool_size",
      "display_name": "InnoDB Buffer Pool Size Setting",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "bytes",
      "dimensions": [],
      "description": "Configured innodb_buffer_pool_size, used as the cache capacity baseline",
      "query": "mysql_variables_innodb_buffer_pool_size{__$labels__}"
    },
    {
      "metric_group": "TempTable",
      "name": "mysql_created_tmp_disk_tables_rate",
      "display_name": "Disk Temporary Tables Create Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Number of disk temporary tables created",
      "query": "rate(mysql_created_tmp_disk_tables{__$labels__}[5m])"
    },
    {
      "metric_group": "TempTable",
      "name": "mysql_created_tmp_memory_tables_rate",
      "display_name": "Memory Temporary Tables Create Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Estimated rate of temporary tables created in memory, derived from total temporary tables minus disk temporary tables",
      "query": "clamp_min(rate(mysql_created_tmp_tables{__$labels__}[5m]) - rate(mysql_created_tmp_disk_tables{__$labels__}[5m]), 0)"
    },
    {
      "metric_group": "TempTable",
      "name": "mysql_created_tmp_tables_rate",
      "display_name": "Total Temporary Tables Create Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Total number of temporary tables (memory + disk) created",
      "query": "rate(mysql_created_tmp_tables{__$labels__}[5m])"
    },
    {
      "metric_group": "TempTable",
      "name": "mysql_tmp_disk_table_ratio",
      "display_name": "Disk Temp Table Ratio",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of temporary tables created on disk",
      "query": "100 * rate(mysql_created_tmp_disk_tables{__$labels__}[5m]) / clamp_min(rate(mysql_created_tmp_tables{__$labels__}[5m]), 1e-6)"
    }
  ]
}
