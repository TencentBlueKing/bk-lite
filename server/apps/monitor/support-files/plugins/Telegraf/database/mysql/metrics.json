{
  "plugin": "Mysql",
  "plugin_desc": "Used to collect and monitor key metrics for MySQL database health and performance.",
  "status_query": "any({instance_type='mysql', collect_type='database'}) by (instance_id)",
  "name": "Mysql",
  "icon": "mm-mysql_Mysql",
  "type": "Database",
  "description": "",
  "default_metric": "any({instance_type='mysql'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": ["mysql_uptime", "mysql_threads_running", "mysql_threads_connected", "mysql_queries_rate", "mysql_slow_queries_rate", "mysql_buffer_pool_hit_ratio", "mysql_connection_utilization", "mysql_variables_max_connections", "mysql_slave_seconds_behind_master"],
  "display_fields": [{"name": "Service Uptime", "sort_order": 0, "metrics": [{"plugin": "Mysql", "metric": "mysql_uptime"}]}, {"name": "Running Threads", "sort_order": 1, "metrics": [{"plugin": "Mysql", "metric": "mysql_threads_running"}]}, {"name": "Current Connections", "sort_order": 2, "metrics": [{"plugin": "Mysql", "metric": "mysql_threads_connected"}]}, {"name": "QPS (Queries)", "sort_order": 3, "metrics": [{"plugin": "Mysql", "metric": "mysql_queries_rate"}]}, {"name": "Slow Query Request Trigger Rate", "sort_order": 4, "metrics": [{"plugin": "Mysql", "metric": "mysql_slow_queries_rate"}]}, {"name": "Buffer Pool Hit Ratio", "sort_order": 5, "metrics": [{"plugin": "Mysql", "metric": "mysql_buffer_pool_hit_ratio"}]}, {"name": "Connection Utilization", "sort_order": 6, "metrics": [{"plugin": "Mysql", "metric": "mysql_connection_utilization"}]}, {"name": "Max Connections Setting", "sort_order": 7, "metrics": [{"plugin": "Mysql", "metric": "mysql_variables_max_connections"}]}, {"name": "Replication Delay", "sort_order": 8, "metrics": [{"plugin": "Mysql", "metric": "mysql_slave_seconds_behind_master"}]}],
  "metrics": [
    {
      "metric_group": "Base",
      "name": "mysql_uptime",
      "display_name": "Service Uptime",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "s",
      "dimensions": [],
      "description": "Duration since the MySQL instance was last started, used to observe restart frequency and runtime stability",
      "query": "mysql_uptime{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_threads_connected",
      "display_name": "Current Connections",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of currently open connections; new connections are rejected when approaching max_connections",
      "query": "mysql_threads_connected{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_threads_running",
      "display_name": "Running Threads",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of threads currently executing queries, reflecting concurrent processing capacity",
      "query": "mysql_threads_running{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_threads_cached",
      "display_name": "Cached Threads",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of cached reusable threads, reflecting connection reuse capability",
      "query": "mysql_threads_cached{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_process_list_threads_idle",
      "display_name": "Idle Process List Threads",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of process list threads in idle state, used to identify idle connection accumulation",
      "query": "max by (instance_id) (mysql_process_list_threads_idle{__$labels__})"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_process_list_threads_executing",
      "display_name": "Executing Process List Threads",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of process list threads currently executing queries, used to assess active query concurrency",
      "query": "max by (instance_id) (mysql_process_list_threads_executing{__$labels__})"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_process_list_threads_sending_data",
      "display_name": "Sending Data Process List Threads",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of process list threads in Sending data state, often related to large scans or slow result processing",
      "query": "max by (instance_id) (mysql_process_list_threads_sending_data{__$labels__})"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_process_list_threads_waiting_for_lock",
      "display_name": "Lock Waiting Process List Threads",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of process list threads waiting for locks, used to identify blocking and lock contention",
      "query": "max by (instance_id) (mysql_process_list_threads_waiting_for_lock{__$labels__})"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_variables_max_connections",
      "display_name": "Max Connections Setting",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Configured max_connections limit used as the true connection capacity baseline",
      "query": "mysql_variables_max_connections{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_max_used_connections",
      "display_name": "Max Used Connections",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Historical peak of used connections, used to assess connection pool headroom",
      "query": "mysql_max_used_connections{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_aborted_connects",
      "display_name": "Aborted Connections",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of failed connection attempts, possibly due to permissions, network, or configuration",
      "query": "mysql_aborted_connects{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
