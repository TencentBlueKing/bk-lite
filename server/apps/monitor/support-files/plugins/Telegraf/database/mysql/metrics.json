      "display_name": "Aborted Connections Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Rate of failed connection attempts, useful for detecting authentication, network, or configuration issues",
      "query": "rate(mysql_aborted_connects{__$labels__}[5m])"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_aborted_clients",
      "display_name": "Aborted Clients",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of clients disconnected abnormally, often related to network jitter or timeout",
      "query": "mysql_aborted_clients{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_aborted_clients_rate",
      "display_name": "Aborted Clients Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Rate of abnormal client disconnects, useful for identifying network jitter, timeout, or connection pool issues",
      "query": "rate(mysql_aborted_clients{__$labels__}[5m])"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_errors_internal",
      "display_name": "Internal Connection Errors",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Connection failures caused by internal server errors",
      "query": "mysql_connection_errors_internal{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_errors_max_connections",
      "display_name": "Max Connections Errors",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Connection failures caused by reaching max_connections",
      "query": "mysql_connection_errors_max_connections{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_errors_max_connections_rate",
      "display_name": "Max Connections Errors Rate",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "cps",
      "dimensions": [],
      "description": "Rate of connection failures caused by reaching max_connections, indicating immediate connection saturation impact",
      "query": "rate(mysql_connection_errors_max_connections{__$labels__}[5m])"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_errors_peer_address",
      "display_name": "Peer Address Connection Errors",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Connection failures caused by invalid or rejected peer addresses",
      "query": "mysql_connection_errors_peer_address{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_errors_select",
      "display_name": "Socket Poll Connection Errors",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Connection failures caused during socket select handling",
      "query": "mysql_connection_errors_select{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_errors_tcpwrap",
      "display_name": "Access Control Connection Errors",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Connection failures caused by TCP wrapper access control",
      "query": "mysql_connection_errors_tcpwrap{__$labels__}"
    },
    {
      "metric_group": "ConnStatus",
      "name": "mysql_connection_utilization",
      "display_name": "Connection Utilization",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of current open connections to configured max_connections, used to estimate connection pressure",
      "query": "100 * max by (instance_id) (mysql_threads_connected{__$labels__}) / on(instance_id) clamp_min(max by (instance_id) (mysql_variables_max_connections{__$labels__}), 1)"
    },
    {
      "metric_group": "Replication",
      "name": "mysql_slave_seconds_behind_master",
      "display_name": "Replication Delay",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Seconds the replica is behind its source, used to assess replication lag",
      "query": "max by (instance_id) (mysql_slave_seconds_behind_master{__$labels__})"
    },
    {
      "metric_group": "Replication",
      "name": "mysql_slave_io_running",
