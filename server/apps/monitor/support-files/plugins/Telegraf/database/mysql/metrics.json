      "display_name": "Buffer Pool Hit Ratio",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of logical reads served by buffer pool instead of disk",
      "query": "100 * (1 - rate(mysql_innodb_buffer_pool_reads{__$labels__}[5m]) / clamp_min(rate(mysql_innodb_buffer_pool_read_requests{__$labels__}[5m]), 1e-6))"
    },
    {
      "metric_group": "InnoDBPerf",
      "name": "mysql_buffer_pool_dirty_ratio",
      "display_name": "Dirty Pages Ratio",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of dirty pages in total buffer pool pages",
      "query": "100 * mysql_innodb_buffer_pool_pages_dirty{__$labels__} / clamp_min(mysql_innodb_buffer_pool_pages_total{__$labels__}, 1)"
    },
    {
      "metric_group": "InnoDBPerf",
      "name": "mysql_buffer_pool_used_ratio",
      "display_name": "Buffer Pool Used Ratio",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "Ratio of used pages in total buffer pool pages",
      "query": "100 * (mysql_innodb_buffer_pool_pages_total{__$labels__} - mysql_innodb_buffer_pool_pages_free{__$labels__}) / clamp_min(mysql_innodb_buffer_pool_pages_total{__$labels__}, 1)"
    },
