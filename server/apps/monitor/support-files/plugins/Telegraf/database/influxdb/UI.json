{
  "object_name": "InfluxDB",
  "instance_type": "influxdb",
  "collect_type": "database",
  "config_type": [
    "influxdb"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{server}}",
  "form_fields": [
    {
      "name": "server",
      "label": "服务器地址",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "InfluxDB v1 debug 接口地址，通常为 http://host:8086/debug/vars",
      "widget_props": {
        "placeholder": "http://localhost:8086/debug/vars"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.urls[0]"
      },
      "label_en": "Server Address"
    },
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": false,
      "editable": false,
      "description": "如接口启用 Basic Auth 可填写用户名",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.username"
      },
      "label_en": "Username"
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": false,
      "editable": false,
      "description": "如接口启用 Basic Auth 可填写密码",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      },
      "label_en": "Password"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    },
    {
      "name": "timeout",
      "label": "超时时间",
      "type": "inputNumber",
      "required": true,
      "default_value": 30,
      "description": "单次请求 `debug/vars` 接口的超时时间（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "超时时间",
        "addonAfter": "s",
        "placeholder_en": "Timeout"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.timeout",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Timeout"
    },
    {
      "name": "tls_ca",
      "label": "CA证书路径",
      "type": "input",
      "required": false,
      "editable": false,
      "description": "HTTPS 场景下使用的 CA 证书路径",
      "widget_props": {
        "placeholder": "/etc/ssl/ca.pem"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.tls_ca"
      },
      "label_en": "CA Certificate Path"
    },
    {
      "name": "tls_cert",
      "label": "客户端证书路径",
      "type": "input",
      "required": false,
      "editable": false,
      "description": "HTTPS 双向认证时使用的客户端证书路径",
      "widget_props": {
        "placeholder": "/etc/ssl/client.pem"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.tls_cert"
      },
      "label_en": "Client Certificate Path"
    },
    {
      "name": "tls_key",
      "label": "客户端密钥路径",
      "type": "input",
      "required": false,
      "editable": false,
      "description": "HTTPS 双向认证时使用的客户端密钥路径",
      "widget_props": {
        "placeholder": "/etc/ssl/client-key.pem"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.tls_key"
      },
      "label_en": "Client Key Path"
    },
    {
      "name": "insecure_skip_verify",
      "label": "跳过证书校验",
      "type": "switch",
      "required": false,
      "default_value": false,
      "description": "HTTPS 场景下是否跳过服务端证书校验",
      "widget_props": {},
      "transform_on_edit": {
        "origin_path": "child.content.config.insecure_skip_verify"
      },
      "label_en": "Skip Certificate Verification"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "server",
      "label": "服务器地址",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "http://localhost:8086/debug/vars"
      },
      "rules": [
        {
          "type": "pattern",
          "pattern": "^(http|https)://.+/debug/vars$",
          "message": "服务器地址必须是以http://或https://开头的完整 debug/vars 地址",
          "excel_formula": "AND(OR(LEFT({{CELL}},7)=\"http://\",LEFT({{CELL}},8)=\"https://\"),RIGHT({{CELL}},11)=\"/debug/vars\")"
        }
      ],
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "server"
        ],
        "target_field": "instance_name",
        "regex": "^(?:https?://)?([^/]+)"
      },
      "label_en": "Server Address"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}