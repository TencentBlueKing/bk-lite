{
  "object_name": "Redis",
  "instance_type": "redis",
  "collect_type": "database",
  "config_type": [
    "redis"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_{{host}}_{{port}}",
  "form_fields": [
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": false,
      "editable": false,
      "description": "用于访问接口的用户名",
      "guide_short": "仅 Redis 6+ 启用 ACL 时填写；未启用 ACL 时可留空。账号至少具备执行 INFO 命令的权限。",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.username"
      },
      "label_en": "Username",
      "description_en": "Username for accessing the interface"
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": false,
      "editable": false,
      "description": "对应的登录密码",
      "guide_short": "对应 Redis 设置的 requirepass 密码；未启用认证时保持为空，注意不要带入首尾空格。",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      },
      "label_en": "Password",
      "description_en": "Corresponding login password"
    },
    {
      "name": "host",
      "label": "主机",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "与设备进行通信的主机",
      "guide_short": "填写 Redis 服务所在的主机 IP 或域名，例如 10.0.0.10；保存前可用 redis-cli -h <host> -p <port> PING 验证可达。",
      "widget_props": {
        "placeholder": "主机地址"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "://([^:]+):"
        }
      },
      "label_en": "Host"
    },
    {
      "name": "port",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "与设备进行通信的端口",
      "guide_short": "Redis 服务端口，默认 6379；范围 1-65535，请与目标实例实际监听端口保持一致。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口",
        "placeholder_en": "Port"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": ":(\\d+)$"
        }
      },
      "label_en": "Port"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "guide_short": "默认 60 秒；过低会增加 Redis 实例压力，过高会延误告警。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "host",
      "label": "主机",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "主机地址"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": [
          "host",
          "port"
        ],
        "target_field": "instance_name",
        "separator": ":"
      },
      "label_en": "Host"
    },
    {
      "name": "port",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口",
        "placeholder_en": "Port"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": [
          "host",
          "port"
        ],
        "target_field": "instance_name",
        "separator": ":"
      },
      "label_en": "Port"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}