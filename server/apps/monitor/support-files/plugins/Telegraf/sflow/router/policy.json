{
  "object": "Router",
  "plugin": "Router Flow sFlow",
  "templates": [
    {
      "name": "设备总流量过高",
      "alert_name": "路由器${resource_name} 设备总流量过高",
      "description": "sFlow 总流量过高告警。",
      "metric_name": "device_flow_bytes_rate",
      "algorithm": "max_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 900,
          "method": ">"
        }
      ],
      "group_algorithm": "max"
    },
    {
      "name": "设备总包量过高",
      "alert_name": "路由器${resource_name} 设备总包量过高",
      "description": "sFlow 总包量过高告警。",
      "metric_name": "device_flow_packets_rate",
      "algorithm": "max_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 900,
          "method": ">"
        }
      ],
      "group_algorithm": "max"
    },
    {
      "name": "平均包大小异常",
      "alert_name": "路由器${resource_name} 平均包大小异常",
      "description": "sFlow 平均包大小异常告警。",
      "metric_name": "device_flow_avg_packet_size",
      "algorithm": "max_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 900,
          "method": ">"
        }
      ],
      "group_algorithm": "max"
    }
  ]
}
