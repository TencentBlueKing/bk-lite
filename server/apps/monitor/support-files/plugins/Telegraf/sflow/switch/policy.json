{
  "object": "Switch",
  "plugin": "Switch Flow sFlow",
  "templates": [
    {
      "name": "设备总流量过高",
      "alert_name": "交换机${resource_name} 设备总流量过高",
      "description": "sFlow 总流量过高告警。",
      "metric_name": "device_flow_bytes_rate",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 900,
          "method": ">"
        }
      ]
    },
    {
      "name": "设备总包量过高",
      "alert_name": "交换机${resource_name} 设备总包量过高",
      "description": "sFlow 总包量过高告警。",
      "metric_name": "device_flow_packets_rate",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 900,
          "method": ">"
        }
      ]
    },
    {
      "name": "平均包大小异常",
      "alert_name": "交换机${resource_name} 平均包大小异常",
      "description": "sFlow 平均包大小异常告警。",
      "metric_name": "device_flow_avg_packet_size",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 900,
          "method": ">"
        }
      ]
    }
  ]
}
