[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_paloalto"
        config_type = "paloalto"
        brand = "paloalto"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB, auto-walked column names) ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    # ---- 64-bit IF-MIB HC traffic counters (ifXTable, wrap-safe on high-speed ports) ----
    # 待现网核验：ifHCInOctets 1.3.6.1.2.1.31.1.1.1.6 / ifHCOutOctets ...1.10，按 ifIndex 与上表接口行对齐。
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- Palo Alto CPU usage (HOST-RESOURCES hrProcessorLoad, per-core %, headline avg by instance) ----
    # 待现网核验：1.3.6.1.2.1.25.3.3.1.2（每核 0-100%，共享盘 avg by instance_id 取整机均值）。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.25.3.3.1.2"
        name = "usage"
    # ---- Palo Alto firewall-specific session health (PAN-COMMON-MIB panSession, scalars) ----
    # 来源：官方 PAN-COMMON-MIB（panSession = 1.3.6.1.4.1.25461.2.1.2.3），LibreNMS Panos.php 验证。待现网核验。
    #   panSessionUtilization .1.0(%) / panSessionMax .2.0 / panSessionActive .3.0 /
    #   panSessionActiveTcp .4.0 / panSessionActiveUdp .5.0 / panSessionActiveICMP .6.0
    [[inputs.snmp.table]]
        name = "firewall"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.25461.2.1.2.3.1.0"
        name = "session_utilization"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.25461.2.1.2.3.2.0"
        name = "max_sessions"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.25461.2.1.2.3.3.0"
        name = "active_sessions"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.25461.2.1.2.3.4.0"
        name = "active_sessions_tcp"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.25461.2.1.2.3.5.0"
        name = "active_sessions_udp"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.25461.2.1.2.3.6.0"
        name = "active_sessions_icmp"
# ---- 内存/温度/风扇/电源：Palo Alto 内存走 HOST-RESOURCES hrStorage（需按 hrStorageDescr 行级匹配 ----
# ---- netbuffer/内存行）、温度/风扇/电源走 PAN-ENTITY-EXT entity-sensor（需按 entPhySensorType 行级过滤）。----
# ---- telegraf inputs.snmp 不能行级过滤 → 标 N/A 不采（架构限制，同 fortinet/checkpoint 温度）。----
