[[inputs.snmp]]
    startup_error_behavior = "retry"
    interval = "{{ interval }}s"
    {% if version == 2 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 2
    community = "{{ community }}"
    timeout = "{{ timeout }}s"
    {% elif version == 3 %}
    agents = ["udp://{{ ip }}:{{ port }}"]
    version = 3
    timeout = "{{ timeout }}s"
    sec_name = "{{ sec_name }}"
    sec_level = "{{ sec_level }}"
    auth_protocol = "{{ auth_protocol }}"
    auth_password = "{{ auth_password }}"
    priv_protocol = "{{ priv_protocol }}"
    priv_password = "{{ priv_password }}"
    {% else %}
    {% endif %}
    [inputs.snmp.tags]
        instance_id = "{{ instance_id }}"
        instance_type = "{{ instance_type }}"
        collect_type = "snmp_a10"
        config_type = "a10"
        brand = "a10"
    # ---- System ----
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.3.0"
        name = "uptime"
    [[inputs.snmp.field]]
        oid = "1.3.6.1.2.1.1.5.0"
        name = "source"
        is_tag = true
    # ---- Interfaces (generic IF-MIB) + 64-bit HC ----
    [[inputs.snmp.table]]
        oid = "1.3.6.1.2.1.2.2"
        name = "interface"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.2.2.1.2"
        name = "ifDescr"
        is_tag = true
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.6"
        name = "ifHCInOctets"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.2.1.31.1.1.1.10"
        name = "ifHCOutOctets"
    # ---- A10 Thunder/ACOS CPU (A10-AX-MIB axSysCpuUsage, per-CPU table, %, PEN 22610) ----
    # 待现网核验：axSysCpuUsage 列 1.3.6.1.4.1.22610.2.4.1.3.2.1.3（每 CPU 使用率%，按 CPU 索引；LibreNMS acos os_discovery 用此列）。
    # 多 CPU(控制/数据) → device_cpu_usage avg() by instance_id。
    [[inputs.snmp.table]]
        name = "device_cpu"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.22610.2.4.1.3.2.1.3"
        name = "usage"
    # ---- A10 memory (A10-AX-MIB axSysMemoryTotal/Usage, KB, scalar) ----
    # 待现网核验：total=axSysMemoryTotal 1.3.6.1.4.1.22610.2.4.1.2.1.0（KB，snmprec 2072432）/ used=axSysMemoryUsage ...2.2.0（KB，snmprec 1176400）。
    # 利用率 metrics.json 按 100*used/total（KB 相消比值正确）；绝对量 metrics.json 查询里 *1024 转字节。
    [[inputs.snmp.table]]
        name = "device_memory"
        inherit_tags = ["source"]
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.22610.2.4.1.2.1.0"
        name = "total"
    [[inputs.snmp.table.field]]
        oid = "1.3.6.1.4.1.22610.2.4.1.2.2.0"
        name = "used"
# ---- 连接数/温度/风扇/电源：A10 axSysTotalCurrentConnections 未在 LibreNMS 源中确认数字 OID(snmprec 未含)→连接 N/A 待现网核验;----
# ---- 温度在 axSysHardware 传感器表按名混合(行级)→温度/风扇/电源 N/A。仅 CPU/内存/接口干净可采。----
