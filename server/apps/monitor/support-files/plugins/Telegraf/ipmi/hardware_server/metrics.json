{
  "plugin": "Hardware Server IPMI",
  "plugin_desc": "The IPMI collection plugin gathers generic hardware component metrics from physical servers.",
  "status_query": "any({instance_type='hardware_server', collect_type='ipmi'}) by (instance_id)",
  "name": "Hardware Server",
  "icon": "mm-hardwareDevice_硬件设备",
  "type": "Hardware Device",
  "description": "",
  "default_metric": "any({instance_type='hardware_server'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": ["ipmi_chassis_power_state", "ipmi_fan_speed_rpm", "ipmi_temperature_celsius"],
  "display_fields": [
    {"name": "Power State", "sort_order": 0, "metrics": [{"plugin": "Hardware Server IPMI", "metric": "ipmi_chassis_power_state"}]},
    {"name": "Fan Speed", "sort_order": 1, "metrics": [{"plugin": "Hardware Server IPMI", "metric": "ipmi_fan_speed_rpm"}]},
    {"name": "Temperature", "sort_order": 2, "metrics": [{"plugin": "Hardware Server IPMI", "metric": "ipmi_temperature_celsius"}]}
  ],
  "metrics": [
    {
      "metric_group": "Chassis",
      "name": "ipmi_chassis_power_state",
      "query": "ipmi_chassis_power_state{instance_type='hardware_server', __$labels__}",
      "display_name": "Power State",
      "data_type": "Enum",
      "unit": "[{\"name\":\"开机\",\"id\":1,\"color\":\"#1ac44a\"},{\"name\":\"关机\",\"id\":0,\"color\":\"#ff4d4f\"},{\"name\":\"未知\",\"id\":-1,\"color\":\"#8c8c8c\"}]",
      "dimensions": [{"name": "component_id", "description": "component_id"}, {"name": "raw_name", "description": "raw_name"}, {"name": "profile", "description": "profile"}],
      "instance_id_keys": ["instance_id"],
      "description": "Current chassis power state obtained from the IPMI chassis command."
    },
    {
      "metric_group": "Chassis",
      "name": "ipmi_chassis_power_watts",
      "query": "ipmi_chassis_power_watts{instance_type='hardware_server', __$labels__}",
      "display_name": "Chassis Power",
      "data_type": "Number",
      "unit": "watts",
      "dimensions": [{"name": "component_id", "description": "component_id"}, {"name": "raw_name", "description": "raw_name"}, {"name": "profile", "description": "profile"}],
      "instance_id_keys": ["instance_id"],
      "description": "Chassis power consumption reported by a generic IPMI sensor."
    },
    {
      "metric_group": "Chassis",
      "name": "ipmi_chassis_temperature_celsius",
      "query": "ipmi_chassis_temperature_celsius{instance_type='hardware_server', __$labels__}",
      "display_name": "Chassis Temperature",
      "data_type": "Number",
      "unit": "celsius",
      "dimensions": [{"name": "component_id", "description": "component_id"}, {"name": "location", "description": "location"}, {"name": "raw_name", "description": "raw_name"}, {"name": "profile", "description": "profile"}],
      "instance_id_keys": ["instance_id"],
      "description": "Inlet, exhaust, or ambient chassis temperature."
    },
    {
      "metric_group": "Chassis",
      "name": "ipmi_chassis_airflow_cfm",
      "query": "ipmi_chassis_airflow_cfm{instance_type='hardware_server', __$labels__}",
      "display_name": "Chassis Airflow",
