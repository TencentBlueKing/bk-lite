{
  "object_name": "Hardware Server",
  "instance_type": "hardware_server",
  "collect_type": "ipmi",
  "config_type": [
    "hardware_server"
  ],
  "collector": "Telegraf",
  "instance_id": "{{cloud_region}}_hardware_server_ipmi_{{ip}}",
  "form_fields": [
    {
      "name": "monitor_ip",
      "label": "IP",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "监控的目标主机的 IP 地址，用于标识数据收集的来源",
      "widget_props": {
        "placeholder": "IP地址"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "\\(([^)]+)\\)"
        }
      },
      "label_en": "IP"
    },
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": true,
      "editable": false,
      "description": "用于访问接口的用户名",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "^([^:]+):"
        }
      },
      "label_en": "Username",
      "description_en": "Username for accessing the interface"
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": true,
      "editable": false,
      "encrypted": true,
      "description": "对应的登录密码",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      },
      "label_en": "Password",
      "description_en": "Corresponding login password"
    },
    {
      "name": "protocol",
      "label": "协议",
      "type": "input",
      "required": false,
      "editable": false,
      "default": "lanplus",
      "description": "表示使用 LAN+ 协议进行访问（通常用于较新版本的 IPMI）",
      "widget_props": {
        "placeholder": "协议",
        "placeholder_en": "Protocol"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.servers[0]",
        "to_form": {
          "regex": "@([^(]+)\\("
        }
      },
      "label_en": "Protocol"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "ip",
      "label": "IP",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "IP地址"
      },
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "ip"
        ],
        "target_field": "instance_name"
      },
      "label_en": "IP"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ],
  "extra_edit_fields": {}
}