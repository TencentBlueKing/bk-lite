{
  "object_name": "Oracle",
  "instance_type": "oracle",
  "collect_type": "exporter",
  "config_type": [
    "oracle"
  ],
  "collector": "Oracle-Exporter",
  "instance_id": "{{cloud_region}}_{{ENV_HOST}}_{{ENV_PORT}}",
  "form_fields": [
    {
      "name": "ENV_USER",
      "label": "用户名",
      "type": "input",
      "required": true,
      "description": "用于访问接口的用户名",
      "guide_short": "建议使用只读监控账号，至少具备 dba_tablespace_usage_metrics、dba_tablespaces、v$system_wait_class、v$asm_diskgroup_stat、v$datafile、v$sysstat、v$process、v$waitclassmetric、v$session、v$resource_limit 等视图的 SELECT 权限；可直接 GRANT SELECT_CATALOG_ROLE。",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.USER__{{config_id}}"
      },
      "label_en": "Username",
      "description_en": "Username for accessing the interface"
    },
    {
      "name": "ENV_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": true,
      "description": "对应的登录密码",
      "guide_short": "填写与用户名对应的登录密码，注意不要带入首尾空格；特殊字符无需额外转义。",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PASSWORD__{{config_id}}"
      },
      "label_en": "Password",
      "description_en": "Corresponding login password"
    },
    {
      "name": "ENV_SERVICE_NAME",
      "label": "服务名称",
      "type": "input",
      "required": true,
      "description": "要监控的服务名称，确保其与实际运行的服务一致",
      "guide_short": "填写 Oracle 的 service_name（不是 SID），可用 sqlplus <user>/<pass>@//<host>:<port>/<service_name> 验证。",
      "widget_props": {
        "placeholder": "服务名称",
        "placeholder_en": "Service Name"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SERVICE_NAME__{{config_id}}"
      },
      "label_en": "Service Name"
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "description": "指定程序运行时应监听的端口号，用于接受外部请求和连接",
      "guide_short": "Oracle-Exporter 在采集节点本地暴露 /metrics 的端口，不是 Oracle 数据库端口（默认 1521）；确认未被占用，可通过 curl http://127.0.0.1:<监听端口>/metrics 验证。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口",
        "placeholder_en": "Listen Port"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.LISTEN_PORT__{{config_id}}"
      },
      "label_en": "Listen Port"
    },
    {
      "name": "ENV_HOST",
      "label": "主机",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "description": "与设备进行通信的主机",
      "guide_short": "填写 Oracle 数据库所在的主机 IP 或域名，需确保采集节点可通过 sqlplus 访问。",
      "widget_props": {
        "placeholder": "主机地址"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.HOST__{{config_id}}"
      },
      "label_en": "Host"
    },
    {
      "name": "ENV_PORT",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "description": "与设备进行通信的端口",
      "guide_short": "Oracle 数据库监听端口，默认 1521；与 Oracle-Exporter 本地监听端口不同，勿混淆。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口",
        "placeholder_en": "Port"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.PORT__{{config_id}}"
      },
      "label_en": "Port"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "guide_short": "默认 60 秒；过低会增加 Oracle 数据库与 exporter 压力，过高会延误告警。",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口",
        "placeholder_en": "Listen Port"
      },
      "label_en": "Listen Port"
    },
    {
      "name": "ENV_HOST",
      "label": "主机",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "主机地址"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": [
          "ENV_HOST",
          "ENV_PORT"
        ],
        "target_field": "instance_name",
        "separator": ":"
      },
      "label_en": "Host"
    },
    {
      "name": "ENV_PORT",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口",
        "placeholder_en": "Port"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": [
          "ENV_HOST",
          "ENV_PORT"
        ],
        "target_field": "instance_name",
        "separator": ":"
      },
      "label_en": "Port"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}