{
  "object_name": "Kafka",
  "instance_type": "kafka",
  "collect_type": "exporter",
  "config_type": [
    "kafka"
  ],
  "collector": "Kafka-Exporter",
  "instance_id": "{{cloud_region}}_{{ENV_KAFKA_SERVER}}",
  "form_fields": [
    {
      "name": "ENV_KAFKA_VERSION",
      "label": "版本",
      "type": "input",
      "required": true,
      "description": "指定当前程序的版本详情",
      "widget_props": {
        "placeholder": "2.0.0"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.KAFKA_VERSION__{{config_id}}"
      },
      "label_en": "Version"
    },
    {
      "name": "ENV_SASL_ENABLED",
      "label": "启用认证",
      "type": "switch",
      "required": false,
      "default_value": false,
      "description": "是否启用 SASL 认证（用户名和密码）",
      "transform_on_create": {
        "mapping": {
          "true": "--sasl.enabled",
          "false": ""
        }
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SASL_ENABLED__{{config_id}}",
        "to_form": {
          "mapping": {
            "true": [
              "--sasl.enabled"
            ],
            "false": [
              "",
              null
            ]
          }
        },
        "to_api": {
          "mapping": {
            "true": "--sasl.enabled",
            "false": ""
          }
        }
      },
      "label_en": "Enable Authentication"
    },
    {
      "name": "ENV_SASL_USERNAME",
      "label": "用户名",
      "type": "input",
      "required": true,
      "description": "用于访问接口的用户名",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "dependency": {
        "field": "ENV_SASL_ENABLED",
        "value": true
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SASL_USERNAME__{{config_id}}"
      },
      "label_en": "Username",
      "description_en": "Username for accessing the interface"
    },
    {
      "name": "ENV_SASL_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": true,
      "description": "对应的登录密码",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "dependency": {
        "field": "ENV_SASL_ENABLED",
        "value": true
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SASL_PASSWORD__{{config_id}}"
      },
      "label_en": "Password",
      "description_en": "Corresponding login password"
    },
    {
      "name": "ENV_SASL_MECHANISM",
      "label": "运行机制",
      "type": "input",
      "required": false,
      "description": "用于处理和响应通过发布端口接收的请求，包括请求的解析、处理和返回结果的完整流程",
      "widget_props": {
        "placeholder": "plain"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SASL_MECHANISM__{{config_id}}"
      },
      "label_en": "Operation Mode"
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "description": "指定程序运行时应监听的端口号，用于接受外部请求和连接",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口",
        "placeholder_en": "Listen Port"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.LISTEN_PORT__{{config_id}}"
      },
      "label_en": "Listen Port"
    },
    {
      "name": "ENV_KAFKA_SERVER",
      "label": "服务器地址",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "description": "监控对象的服务器地址",
      "widget_props": {
        "placeholder": "kafka:9092"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.KAFKA_SERVER__{{config_id}}"
      },
      "label_en": "Server Address"
    },
    {
      "name": "ENV_TOPIC_FILTER",
      "label": "Topic包含",
      "type": "input",
      "required": false,
      "default_value": ".*",
      "description": "按正则包含要采集的 Topic",
      "widget_props": {
        "placeholder": ".*"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.TOPIC_FILTER__{{config_id}}"
      },
      "label_en": "Topic Include"
    },
    {
      "name": "ENV_TOPIC_EXCLUDE",
      "label": "Topic排除",
      "type": "input",
      "required": false,
      "default_value": "^$",
      "description": "按正则排除不需要采集的 Topic",
      "widget_props": {
        "placeholder": "^$"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.TOPIC_EXCLUDE__{{config_id}}"
      },
      "label_en": "Topic Exclude"
    },
    {
      "name": "ENV_GROUP_FILTER",
      "label": "消费组包含",
      "type": "input",
      "required": false,
      "default_value": ".*",
      "description": "按正则包含要采集的消费组",
      "widget_props": {
        "placeholder": ".*"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.GROUP_FILTER__{{config_id}}"
      },
      "label_en": "Consumer Group Include"
    },
    {
      "name": "ENV_GROUP_EXCLUDE",
      "label": "消费组排除",
      "type": "input",
      "required": false,
      "default_value": "^$",
      "description": "按正则排除不需要采集的消费组",
      "widget_props": {
        "placeholder": "^$"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.GROUP_EXCLUDE__{{config_id}}"
      },
      "label_en": "Consumer Group Exclude"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口",
        "placeholder_en": "Listen Port"
      },
      "label_en": "Listen Port"
    },
    {
      "name": "ENV_KAFKA_SERVER",
      "label": "服务器地址",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "kafka:9092"
      },
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "ENV_KAFKA_SERVER"
        ],
        "target_field": "instance_name"
      },
      "label_en": "Server Address"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ]
}