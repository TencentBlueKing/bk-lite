{
  "object_name": "JVM",
  "instance_type": "jvm",
  "collect_type": "jmx",
  "config_type": [
    "jvm"
  ],
  "collector": "JVM-JMX",
  "instance_id": "{{cloud_region}}_jvm_{{jmx_url}}",
  "form_fields": [
    {
      "name": "username",
      "label": "用户名",
      "type": "input",
      "required": false,
      "editable": false,
      "description": "用于访问接口的用户名",
      "widget_props": {
        "placeholder": "用户名",
        "placeholder_en": "Username"
      },
      "transform_on_edit": {
        "origin_path": "base.content.username"
      },
      "label_en": "Username",
      "description_en": "Username for accessing the interface"
    },
    {
      "name": "password",
      "label": "密码",
      "type": "password",
      "required": false,
      "editable": false,
      "description": "对应的登录密码",
      "widget_props": {
        "placeholder": "密码",
        "placeholder_en": "Password"
      },
      "transform_on_edit": {
        "origin_path": "base.content.password"
      },
      "label_en": "Password",
      "description_en": "Corresponding login password"
    },
    {
      "name": "monitor_url",
      "label": "JmxUrl",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "editable": false,
      "description": "监控的目标网址链接，以检测其可用性和性能",
      "widget_props": {
        "placeholder": ""
      },
      "transform_on_edit": {
        "origin_path": "base.content.jmxUrl"
      },
      "label_en": "JMX URL"
    },
    {
      "name": "LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "description": "指定程序运行时应监听的端口号，用于接受外部请求和连接",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口",
        "placeholder_en": "Listen Port"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.LISTEN_PORT__{{config_id}}"
      },
      "label_en": "Listen Port"
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s",
        "placeholder_en": "Interval"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      },
      "label_en": "Interval",
      "description_en": "Collection time interval (unit: seconds)"
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点",
        "placeholder_en": "Please select node"
      },
      "enable_row_filter": false,
      "label_en": "Node"
    },
    {
      "name": "jmx_url",
      "label": "URL",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "http://example.com:8000"
      },
      "change_handler": {
        "type": "simple",
        "source_fields": [
          "jmx_url"
        ],
        "target_field": "instance_name"
      },
      "label_en": "URL"
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "placeholder": "监听端口",
        "min": 1,
        "precision": 0,
        "placeholder_en": "Listen Port"
      },
      "label_en": "Listen Port"
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false,
        "placeholder_en": "Instance Name"
      },
      "label_en": "Instance Name"
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组",
        "placeholder_en": "Please select group"
      },
      "label_en": "Group"
    }
  ],
  "extra_edit_fields": {}
}