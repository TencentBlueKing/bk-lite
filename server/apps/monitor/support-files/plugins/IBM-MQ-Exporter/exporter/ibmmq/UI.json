{
  "object_name": "IBMMQ",
  "instance_type": "ibmmq",
  "collect_type": "exporter",
  "config_type": ["ibmmq"],
  "collector": "IBM-MQ-Exporter",
  "instance_id": "{{cloud_region}}_{{ENV_IBMMQ_CONNECTION_CONNNAME}}_{{ENV_IBMMQ_CONNECTION_QUEUEMANAGER}}",
  "form_fields": [
    {
      "name": "ENV_IBMMQ_CONNECTION_CONNNAME",
      "label": "连接地址",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "description": "IBM MQ 服务连接地址，格式为 ip(port)，例如 10.0.0.5(1414)",
      "widget_props": {
        "placeholder": "10.0.0.5(1414)"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_CONNECTION_CONNNAME__{{config_id}}"
      }
    },
    {
      "name": "ENV_IBMMQ_CONNECTION_QUEUEMANAGER",
      "label": "队列管理器",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "description": "要监控的队列管理器名称，例如 QM1",
      "widget_props": {
        "placeholder": "QM1"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_CONNECTION_QUEUEMANAGER__{{config_id}}"
      }
    },
    {
      "name": "ENV_IBMMQ_CONNECTION_CHANNEL",
      "label": "连接通道",
      "type": "input",
      "required": true,
      "default_value": "SVRCONN",
      "description": "用于客户端连接的服务器连接通道名称，例如 SVRCONN",
      "widget_props": {
        "placeholder": "SVRCONN"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_CONNECTION_CHANNEL__{{config_id}}"
      }
    },
    {
      "name": "ENV_IBMMQ_CONNECTION_USER",
      "label": "用户名",
      "type": "input",
      "required": false,
      "description": "连接队列管理器使用的用户名（可选）",
      "widget_props": {
        "placeholder": "用户名"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_CONNECTION_USER__{{config_id}}"
      }
    },
    {
      "name": "ENV_IBMMQ_CONNECTION_PASSWORD",
      "label": "密码",
      "type": "password",
      "required": false,
      "description": "连接队列管理器使用的密码（可选）",
      "widget_props": {
        "placeholder": "密码"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_CONNECTION_PASSWORD__{{config_id}}"
      }
    },
    {
      "name": "ENV_IBMMQ_OBJECTS_QUEUES",
      "label": "监控队列",
      "type": "input",
      "required": true,
      "default_value": "*",
      "description": "需要监控的队列过滤表达式，默认 * 表示所有队列，可用逗号分隔，! 前缀表示排除",
      "widget_props": {
        "placeholder": "*"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_OBJECTS_QUEUES__{{config_id}}"
      }
    },
    {
      "name": "ENV_IBMMQ_OBJECTS_CHANNELS",
      "label": "监控通道",
      "type": "input",
      "required": true,
      "default_value": "*",
      "description": "需要监控的通道过滤表达式，默认 * 表示所有通道，可用逗号分隔，! 前缀表示排除",
      "widget_props": {
        "placeholder": "*"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.IBMMQ_OBJECTS_CHANNELS__{{config_id}}"
      }
    },
    {
      "name": "ENV_MQCCSID",
      "label": "字符集编码",
      "type": "input",
      "required": false,
      "description": "队列管理器字符集编码（CCSID），通常无需填写；如出现编码异常可设为 819 或 1208",
      "widget_props": {
        "placeholder": "819"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.MQCCSID__{{config_id}}"
      }
    },
    {
      "name": "ENV_MQ_INSTALLATION_PATH",
      "label": "MQ 客户端目录",
      "type": "input",
      "required": true,
      "default_value": "/opt/mqm",
      "description": "节点上 IBM MQ redistributable client 的安装目录。探针以客户端方式连接 MQ，依赖该目录下的客户端库；默认 /opt/mqm，若客户端安装在其他目录请修改",
      "widget_props": {
        "placeholder": "/opt/mqm"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.MQ_INSTALLATION_PATH__{{config_id}}"
      }
    },
    {
      "name": "ENV_LD_LIBRARY_PATH",
      "label": "MQ 客户端库路径",
      "type": "input",
      "required": true,
      "default_value": "/opt/mqm/lib64",
      "description": "IBM MQ 客户端动态库路径（LD_LIBRARY_PATH），探针运行时据此加载 MQ 客户端库；默认 /opt/mqm/lib64，须与 MQ 客户端安装目录一致",
      "widget_props": {
        "placeholder": "/opt/mqm/lib64"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.LD_LIBRARY_PATH__{{config_id}}"
      }
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "default_value": 9601,
      "visible_in": "edit",
      "description": "探针在本机暴露 /metrics 的监听端口，供采集器抓取",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "9601"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.LISTEN_PORT__{{config_id}}"
      }
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 60,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      }
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点"
      },
      "enable_row_filter": false
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口"
      }
    },
    {
      "name": "ENV_IBMMQ_CONNECTION_CONNNAME",
      "label": "连接地址",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "10.0.0.5(1414)"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": ["ENV_IBMMQ_CONNECTION_CONNNAME", "ENV_IBMMQ_CONNECTION_QUEUEMANAGER"],
        "target_field": "instance_name",
        "separator": "/"
      }
    },
    {
      "name": "ENV_IBMMQ_CONNECTION_QUEUEMANAGER",
      "label": "队列管理器",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "QM1"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": ["ENV_IBMMQ_CONNECTION_CONNNAME", "ENV_IBMMQ_CONNECTION_QUEUEMANAGER"],
        "target_field": "instance_name",
        "separator": "/"
      }
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false
      }
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组"
      }
    }
  ]
}
