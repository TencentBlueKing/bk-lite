{
  "object": "IBMMQ",
  "plugin": "IBM-MQ-Exporter",
  "templates": [
    {
      "name": "队列管理器存活状态",
      "alert_name": "IBMMQ 队列管理器 ${resource_name} 不可用",
      "description": "监测队列管理器运行状态，状态非 2（运行中）表示队列管理器已停止、静默或无法连接，将导致消息收发中断，需立即检查 MQ 服务与监听端口。",
      "metric_name": "ibmmq_qmgr_status_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 2,
          "method": "!="
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "队列消息积压（最早消息时长）",
      "alert_name": "IBMMQ ${resource_name} 队列消息积压",
      "description": "监控队列中最早消息的滞留时长，时间过长说明消费端处理不及时或停滞，存在积压风险，需检查消费应用。",
      "metric_name": "ibmmq_queue_oldest_message_age_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 86400,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 3600,
          "method": ">="
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "队列未提交消息堆积",
      "alert_name": "IBMMQ ${resource_name} 队列未提交消息过多",
      "description": "监控队列中未提交的消息数量，数量过多通常表示存在长事务或回滚问题，可能阻塞队列。",
      "metric_name": "ibmmq_queue_uncommitted_messages_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "warning",
          "value": 100,
          "method": ">="
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "队列管理器内存不足",
      "alert_name": "IBMMQ 队列管理器 ${resource_name} 内存不足",
      "description": "监控队列管理器所在主机的空闲内存百分比，空闲内存过低可能导致性能下降甚至服务异常。",
      "metric_name": "ibmmq_qmgr_ram_free_percentage_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 10,
          "method": "<="
        },
        {
          "level": "warning",
          "value": 20,
          "method": "<="
        }
      ],
      "group_algorithm": "avg"
    },
    {
      "name": "队列管理器日志空间不足",
      "alert_name": "IBMMQ 队列管理器 ${resource_name} 日志空间不足",
      "description": "监控当前主日志空间使用百分比，日志空间耗尽会阻塞持久消息写入，需及时检查日志配置与归档。",
      "metric_name": "ibmmq_qmgr_log_current_primary_space_in_use_percentage_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 80,
          "method": ">="
        }
      ],
      "group_algorithm": "avg"
    }
  ]
}
