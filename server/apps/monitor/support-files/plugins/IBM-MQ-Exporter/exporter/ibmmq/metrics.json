{
  "plugin": "IBM-MQ-Exporter",
  "plugin_desc": "IBM MQ Exporter collects queue manager, queue, topic and subscription metrics from IBM MQ over an MQI client connection, helping monitor message queue availability, backlog and resource usage. Requires the IBM MQ redistributable client on the node.",
  "status_query": "any({instance_type='ibmmq', collect_type='exporter'}) by (instance_id)",
  "name": "IBMMQ",
  "icon": "mm-ibmmq_IBMMQ",
  "type": "Middleware",
  "description": "",
  "default_metric": "any({instance_type='ibmmq'}) by (instance_id)",
  "instance_id_keys": ["instance_id"],
  "supplementary_indicators": ["ibmmq_qmgr_status_gauge", "ibmmq_qmgr_connection_count_gauge", "ibmmq_qmgr_ram_free_percentage_gauge"],
  "display_fields": [
    {"name": "Queue Manager Status", "sort_order": 0, "metrics": [{"plugin": "IBM-MQ-Exporter", "metric": "ibmmq_qmgr_status_gauge"}]},
    {"name": "Connection Count", "sort_order": 1, "metrics": [{"plugin": "IBM-MQ-Exporter", "metric": "ibmmq_qmgr_connection_count_gauge"}]},
    {"name": "RAM Free", "sort_order": 2, "metrics": [{"plugin": "IBM-MQ-Exporter", "metric": "ibmmq_qmgr_ram_free_percentage_gauge"}]}
  ],
  "metrics": [
    {
      "metric_group": "Status",
      "name": "ibmmq_qmgr_status_gauge",
      "display_name": "Queue Manager Status",
      "instance_id_keys": ["instance_id"],
      "data_type": "Enum",
      "unit": "[{\"name\":\"Stopped\",\"id\":0,\"color\":\"#ff4d4f\"},{\"name\":\"Starting\",\"id\":1,\"color\":\"#fa8c16\"},{\"name\":\"Running\",\"id\":2,\"color\":\"#1ac44a\"},{\"name\":\"Quiescing\",\"id\":3,\"color\":\"#fa8c16\"},{\"name\":\"Standby\",\"id\":4,\"color\":\"#1890ff\"}]",
      "dimensions": [],
      "description": "Queue manager status. 0 means the exporter cannot connect (stopped/unavailable), 1 starting, 2 running, 3 quiescing, 4 standby.",
      "query": "ibmmq_qmgr_status_gauge{__$labels__}"
    },
    {
      "metric_group": "Status",
      "name": "ibmmq_qmgr_channel_initiator_status_gauge",
      "display_name": "Channel Initiator Status",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "none",
      "dimensions": [],
      "description": "Status of the channel initiator of the queue manager.",
      "query": "ibmmq_qmgr_channel_initiator_status_gauge{__$labels__}"
    },
    {
      "metric_group": "Status",
      "name": "ibmmq_qmgr_command_server_status_gauge",
      "display_name": "Command Server Status",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "none",
      "dimensions": [],
      "description": "Status of the command server of the queue manager.",
      "query": "ibmmq_qmgr_command_server_status_gauge{__$labels__}"
    },
    {
      "metric_group": "Base",
      "name": "ibmmq_qmgr_uptime_gauge",
      "display_name": "Uptime",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "s",
      "dimensions": [],
      "description": "How long the queue manager has been running, in seconds.",
      "query": "ibmmq_qmgr_uptime_gauge{__$labels__}"
    },
    {
      "metric_group": "Base",
      "name": "ibmmq_qmgr_connection_count_gauge",
      "display_name": "Connection Count",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "Number of active connections to the queue manager.",
