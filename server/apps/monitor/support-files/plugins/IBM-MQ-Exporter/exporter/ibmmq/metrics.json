      "unit": "counts",
      "dimensions": [],
      "description": "Number of commit operations on the queue manager during the interval.",
      "query": "ibmmq_qmgr_commit_count_gauge{__$labels__}"
    },
    {
      "metric_group": "Base",
      "name": "ibmmq_qmgr_rollback_count_gauge",
      "display_name": "Rollback Count",
      "instance_id_keys": ["instance_id"],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
