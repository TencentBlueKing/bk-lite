# Dameng collector for DM-Exporter.
# Query result columns in Dameng are uppercase by default.
db_type: dm
collector_name: dm_sql

metrics:
  - metric_name: dm_exporter_connections
    type: gauge
    help: "Current connection count"
    values:
      - CONNECTIONS
    query: |
      SELECT COUNT(1) AS CONNECTIONS FROM sys.V$sessions

  - metric_name: dm_exporter_session_rests
    type: gauge
    help: "Free session count"
    values:
      - FREE_SESSIONS
    query: |
      SELECT (MaxSessions - Sessions) AS FREE_SESSIONS
      FROM (SELECT COUNT(1) AS Sessions FROM sys.V$sessions) s,
           (SELECT PARA_VALUE AS MaxSessions FROM sys.V$DM_INI WHERE PARA_NAME = 'MAX_SESSIONS') p

  - metric_name: dm_exporter_session_used_ratio
    type: gauge
    help: "Session usage ratio in percent"
    values:
      - SESSION_USED_RATIO
    query: |
      SELECT ROUND((UsedSessions / MaxSessions) * 100, 2) AS SESSION_USED_RATIO
      FROM (SELECT COUNT(1) AS UsedSessions FROM sys.V$sessions) a,
           (SELECT PARA_VALUE AS MaxSessions FROM sys.V$DM_INI WHERE PARA_NAME = 'MAX_SESSIONS') p

  - metric_name: dm_exporter_memory_used_size
    type: gauge
    help: "Memory used size in MB"
    values:
      - MEMORY_USED
    query: |
      SELECT stat_val / 1024 / 1024 AS MEMORY_USED
      FROM v$sysstat
      WHERE name = 'memory used bytes from os'

  - metric_name: dm_exporter_buffer_cache_hit_percent
    type: gauge
    help: "Buffer cache hit percent"
    values:
      - HIT_RATE
    key_labels:
      - HIT_NAME
    query: |
      SELECT NAME AS HIT_NAME, ROUND(AVG(RAT_HIT) * 100, 2) AS HIT_RATE
      FROM V$BUFFERPOOL
      GROUP BY NAME

  - metric_name: dm_exporter_locks
    type: gauge
    help: "Lock holder count"
    values:
      - LOCK_NUM
    query: |
      SELECT COUNT(*) AS LOCK_NUM FROM V$LOCK

  - metric_name: dm_exporter_lock_blocks
    type: gauge
    help: "Blocked lock waiter count"
    values:
      - LOCK_BLOCKS
    query: |
      SELECT COUNT(*) AS LOCK_BLOCKS FROM V$LOCK WHERE blocked = 1

  - metric_name: dm_exporter_deadlock_count
    type: gauge
    help: "Historical deadlock count"
    values:
      - DEADLOCK_COUNT
    query: |
      SELECT COUNT(*) AS DEADLOCK_COUNT FROM v$deadlock_history

  - metric_name: dm_exporter_tablespace_total_size
    type: gauge
    help: "Tablespace total size in MB"
    values:
      - TOTAL_SIZE
    key_labels:
      - TABLESPACE_NAME
    query_ref: tablespace_query

  - metric_name: dm_exporter_tablespace_free_size
    type: gauge
    help: "Tablespace free size in MB"
    values:
      - FREE_SIZE
    key_labels:
      - TABLESPACE_NAME
    query_ref: tablespace_query

  - metric_name: dm_exporter_tablespace_used_size
    type: gauge
    help: "Tablespace used size in MB"
    values:
      - USED_SIZE
    key_labels:
      - TABLESPACE_NAME
    query_ref: tablespace_query

  - metric_name: dm_exporter_tablespace_used_ratio
    type: gauge
    help: "Tablespace used ratio in percent"
    values:
      - USED_RATIO
    key_labels:
      - TABLESPACE_NAME
    query_ref: tablespace_query

  - metric_name: dm_exporter_checkpoint_dirty_pages
    type: gauge
    help: "Checkpoint dirty pages"
    values:
      - CKPT_DIRTY_PAGES
    query: |
      SELECT VALUE AS CKPT_DIRTY_PAGES FROM V$PARAMETER WHERE NAME = 'CKPT_DIRTY_PAGES'

  - metric_name: dm_exporter_checkpoint_interval_time
    type: gauge
    help: "Checkpoint interval time in seconds"
    values:
      - CKPT_INTERVAL
    query: |
      SELECT VALUE AS CKPT_INTERVAL FROM V$PARAMETER WHERE NAME = 'CKPT_INTERVAL'

  - metric_name: dm_exporter_table_used_space
    type: gauge
    help: "Table block count"
    values:
      - BLOCKS_COUNT
    key_labels:
      - OWNER
      - TABLE_NAME
    query: |
      SELECT OWNER, TABLE_NAME, TABLE_USED_SPACE(owner, table_name) AS BLOCKS_COUNT
      FROM dba_tables
      WHERE owner NOT IN ('SYS', 'SYSSSO', 'SYSAUDITOR')

  - metric_name: dm_exporter_index_used_space
    type: gauge
    help: "Index block count"
    values:
      - USED_SPACE
    key_labels:
      - OWNER
      - INDEX_NAME
    query: |
      SELECT a.OWNER, a.INDEX_NAME, INDEX_USED_SPACE(object_id) AS USED_SPACE
      FROM dba_indexes a, dba_objects b
      WHERE a.owner = b.owner
        AND a.index_name = b.object_name
        AND a.owner NOT IN ('SYS', 'SYSSSO', 'SYSAUDITOR', 'CTISYS')

  - metric_name: dm_exporter_shared_pool_size
    type: gauge
    help: "Shared memory size"
    values:
      - PARA_VALUE
    query: |
      SELECT PARA_VALUE FROM v$DM_INI WHERE PARA_NAME = 'MEMORY_POOL'

  - metric_name: dm_exporter_redo_file_size
    type: gauge
    help: "Current redo file used size in MB"
    values:
      - USED_SIZE
    key_labels:
      - PATH
    query: |
      SELECT v$rlogfile.PATH AS PATH,
             ROUND((v$rlog.TOTAL_SPACE - v$rlog.FREE_SPACE) / 1024 / 1024, 2) AS USED_SIZE
      FROM v$rlog
      JOIN v$rlogfile ON v$rlog.CUR_FILE = v$rlogfile.FILE_ID

  - metric_name: dm_exporter_open_cursor
    type: gauge
    help: "Open cursor count"
    values:
      - OPEN_CURSOR
    query: |
      SELECT COUNT(*) AS OPEN_CURSOR FROM sys.V$OPEN_STMT WHERE TYPE = 'SELECT'

  - metric_name: dm_exporter_roll_state
    type: gauge
    help: "Rollback segment state"
    values:
      - ROLL_STATUS
    key_labels:
      - ROLL_TYPE
    query_ref: roll_query

  - metric_name: dm_exporter_roll_size
    type: gauge
    help: "Rollback segment total size"
    values:
      - TOTAL_SIZE
    key_labels:
      - ROLL_TYPE
    query_ref: roll_query

  - metric_name: dm_exporter_redo_log_size
    type: gauge
    help: "Redo log size in MB"
    values:
      - RLOG_SIZE
    key_labels:
      - PATH
      - STATUS
    query: |
      SELECT PATH,
             a.RLOG_SIZE / 1024 / 1024 AS RLOG_SIZE,
             CASE a.FILE_ID WHEN b.CUR_FILE THEN 'CURRENT' ELSE 'INACTIVE' END AS STATUS
      FROM v$rlogfile a, v$rlog b

  - metric_name: dm_exporter_2pc_pending
    type: gauge
    help: "Pending 2PC transaction count"
    values:
      - PENDING
    query: |
      SELECT COUNT(1) AS PENDING
      FROM v$sessions t1, v$trx t2
      WHERE t1.trx_id = t2.id
        AND t1.state = 'IDLE'
        AND t2.status = 'ACTIVE'

  - metric_name: dm_exporter_load_five_average
    type: gauge
    help: "Database 5-minute load average"
    values:
      - LOAD_FIVE_AVERAGE
    query: |
      SELECT LOAD_FIVE_AVERAGE FROM V$SYSTEMINFO

  - metric_name: dm_exporter_executions_total
    type: counter
    help: "Total executed SQL count"
    values:
      - STAT_VAL
    query: |
      SELECT STAT_VAL
      FROM sys.v$sysstat
      WHERE sf_get_ep_seqno(rowid) = sf_get_self_ep_seqno()
        AND name = 'transaction total count'

  - metric_name: dm_exporter_slow_query
    type: gauge
    help: "Slow queries over 2 seconds"
    values:
      - SLOW_QUERY
    query: |
      SELECT COUNT(1) AS SLOW_QUERY
      FROM (
        SELECT sess_id,
               sql_text,
               DATEDIFF(ss, last_recv_time, SYSDATE) AS Y_EXETIME,
               SF_GET_SESSION_SQL(SESS_ID) AS fullsql,
               clnt_ip
        FROM V$SESSIONS
        WHERE STATE = 'ACTIVE'
      )
      WHERE Y_EXETIME >= 2

  - metric_name: dm_exporter_unusable_index
    type: gauge
    help: "Unusable index count"
    values:
      - UNUSABLE
    query: |
      SELECT COUNT(*) AS UNUSABLE FROM dba_indexes WHERE STATUS = 'UNUSABLE'

  - metric_name: dm_exporter_asm_real_used_percent
    type: gauge
    help: "ASM real space usage ratio in percent"
    values:
      - USEDRATIO
    key_labels:
      - GROUP_NAME
    query_ref: asm_query

  - metric_name: dm_exporter_asm_free_size
    type: gauge
    help: "ASM safe free size in MB"
    values:
      - FREE_SIZE
    key_labels:
      - GROUP_NAME
    query_ref: asm_query

  - metric_name: dm_exporter_backup_is_status
    type: gauge
    help: "Primary-standby instance status"
    values:
      - IS_STATUS
    key_labels:
      - MAL_HOST
      - MAL_INST_HOST
      - INSTANCE_NAME
      - HOST_NAME
      - OGUID
    query_ref: backup_query

  - metric_name: dm_exporter_backup_i_mode
    type: gauge
    help: "Primary-standby instance mode"
    values:
      - I_MODE
    key_labels:
      - MAL_HOST
      - MAL_INST_HOST
      - INSTANCE_NAME
      - HOST_NAME
      - OGUID
    query_ref: backup_query

  - metric_name: dm_exporter_backup_arch_status
    type: gauge
    help: "Primary-standby archive status"
    values:
      - ARCH_STATUS
    key_labels:
      - MAL_HOST
      - MAL_INST_HOST
      - INSTANCE_NAME
      - HOST_NAME
      - OGUID
    query_ref: backup_query

  - metric_name: dm_exporter_backup_dw_status
    type: gauge
    help: "Primary-standby watcher status"
    values:
      - DW_STATUS
    key_labels:
      - MAL_HOST
      - MAL_INST_HOST
      - INSTANCE_NAME
      - HOST_NAME
      - OGUID
    query_ref: backup_query

  - metric_name: dm_exporter_backup_late_time
    type: gauge
    help: "Primary-standby replication lag in seconds"
    values:
      - LATE_TIME
    query: |
      SELECT LAST_CMT_TIME - APPLY_CMT_TIME AS LATE_TIME FROM v$rapply_stat

queries:
  - query_name: tablespace_query
    query: |
      SELECT
        df.TABLESPACE_NAME AS TABLESPACE_NAME,
        ROUND(df.TOTAL_SIZE_MB, 2) AS TOTAL_SIZE,
        ROUND(NVL(fs.FREE_SIZE_MB, 0), 2) AS FREE_SIZE,
        ROUND(df.TOTAL_SIZE_MB - NVL(fs.FREE_SIZE_MB, 0), 2) AS USED_SIZE,
        ROUND((df.TOTAL_SIZE_MB - NVL(fs.FREE_SIZE_MB, 0)) * 100 / NULLIF(df.TOTAL_SIZE_MB, 0), 2) AS USED_RATIO
      FROM (
        SELECT TABLESPACE_NAME, SUM(BYTES) / 1024 / 1024 AS TOTAL_SIZE_MB
        FROM DBA_DATA_FILES
        GROUP BY TABLESPACE_NAME
      ) df
      LEFT JOIN (
        SELECT TABLESPACE_NAME, SUM(BYTES) / 1024 / 1024 AS FREE_SIZE_MB
        FROM DBA_FREE_SPACE
        GROUP BY TABLESPACE_NAME
      ) fs
        ON df.TABLESPACE_NAME = fs.TABLESPACE_NAME

  - query_name: roll_query
    query: |
      SELECT NAME AS ROLL_TYPE, STATUS$ AS ROLL_STATUS, TOTAL_SIZE
      FROM V$TABLESPACE
      WHERE NAME = 'ROLL'

  - query_name: asm_query
    query: |
      SELECT GROUP_NAME,
             FREE_SIZE,
             100 * (TOTAL_SIZE - FREE_SIZE) / TOTAL_SIZE AS USEDRATIO
      FROM V$ASMGROUP

  - query_name: backup_query
    query: |
      SELECT
        dmmal.MAL_HOST,
        dmmal.MAL_INST_HOST,
        INSTANCE_NAME,
        HOST_NAME,
        DECODE(STATUS$, 'OPEN', 0, 'MOUNT', 1, 'SUSPEND', 2) AS IS_STATUS,
        DECODE(MODE$, 'PRIMARY', 0, 'STANDBY', 1, 'NORMAL', 2) AS I_MODE,
        OGUID,
        (
          SELECT DECODE(ARCH_STATUS, 'VALID', 0, 'INVALID', 1)
          FROM v$ARCH_STATUS
          WHERE ARCH_TYPE = 'LOCAL'
        ) AS ARCH_STATUS,
        DECODE(dmwatch.DW_STATUS, 'ENABLED', 0, 'DISABLED', 1) AS DW_STATUS
      FROM v$instance ins
      LEFT JOIN v$dmwatcher dmwatch ON ins.INSTANCE_NAME = dmwatch.INST_NAME
      LEFT JOIN v$DM_MAL_INI dmmal ON ins.INSTANCE_NAME = dmmal.MAL_INST_NAME
