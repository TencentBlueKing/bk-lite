{
  "object_name": "Dameng",
  "instance_type": "dameng",
  "collect_type": "exporter",
  "config_type": ["dameng"],
  "collector": "DM-Exporter",
  "instance_id": "{{cloud_region}}_{{ENV_SQL_EXPORTER_HOST}}_{{ENV_SQL_EXPORTER_PORT}}",
  "form_fields": [
    {
      "name": "ENV_SQL_EXPORTER_USER",
      "label": "用户名",
      "type": "input",
      "required": true,
      "description": "达梦数据库登录用户名",
      "widget_props": {
        "placeholder": "SYSDBA"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SQL_EXPORTER_USER__{{config_id}}"
      }
    },
    {
      "name": "ENV_SQL_EXPORTER_PASS",
      "label": "密码",
      "type": "password",
      "required": true,
      "description": "达梦数据库登录密码",
      "widget_props": {
        "placeholder": "密码"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SQL_EXPORTER_PASS__{{config_id}}"
      }
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "description": "DM-Exporter 本地监听端口，Telegraf 将从该端口抓取指标",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.LISTEN_PORT__{{config_id}}"
      }
    },
    {
      "name": "ENV_SQL_EXPORTER_HOST",
      "label": "主机",
      "type": "input",
      "required": true,
      "visible_in": "edit",
      "description": "达梦数据库主机地址",
      "widget_props": {
        "placeholder": "127.0.0.1"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SQL_EXPORTER_HOST__{{config_id}}"
      }
    },
    {
      "name": "ENV_SQL_EXPORTER_PORT",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "visible_in": "edit",
      "description": "达梦数据库服务端口",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "5236"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SQL_EXPORTER_PORT__{{config_id}}"
      }
    },
    {
      "name": "ENV_COLLECTOR_REFS",
      "label": "采集配置名称",
      "type": "hidden",
      "required": true,
      "default_value": "dm_sql",
      "description": "内置达梦采集配置名称，对应 dm.collector.yml 中的 collector_name",
      "transform_on_edit": {
        "origin_path": "child.env_config.COLLECTOR_REFS__{{config_id}}"
      }
    },
    {
      "name": "ENV_SCRAPE_TIMEOUT",
      "label": "采集超时时间",
      "type": "inputNumber",
      "required": true,
      "default_value": 10,
      "description": "DM-Exporter 单次 SQL 采集超时时间（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "addonAfter": "s"
      },
      "transform_on_create": {
        "suffix": "s"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.SCRAPE_TIMEOUT__{{config_id}}",
        "to_form": {
          "regex": "^(\\d+)s$",
          "type": "number"
        },
        "to_api": {
          "suffix": "s"
        }
      }
    },
    {
      "name": "ENV_MAX_CONNECTION_LIFETIME",
      "label": "最长连接时长",
      "type": "inputNumber",
      "required": true,
      "default_value": 5,
      "description": "DM-Exporter 数据库连接最长复用时间（单位：分钟）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "addonAfter": "m"
      },
      "transform_on_create": {
        "suffix": "m"
      },
      "transform_on_edit": {
        "origin_path": "child.env_config.MAX_CONNECTION_LIFETIME__{{config_id}}",
        "to_form": {
          "regex": "^(\\d+)m$",
          "type": "number"
        },
        "to_api": {
          "suffix": "m"
        }
      }
    },
    {
      "name": "interval",
      "label": "间隔",
      "type": "inputNumber",
      "required": true,
      "default_value": 10,
      "description": "监控数据的采集时间间隔（单位：秒）",
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "间隔",
        "addonAfter": "s"
      },
      "transform_on_edit": {
        "origin_path": "child.content.config.interval",
        "to_form": {
          "regex": "^(\\d+)s$"
        },
        "to_api": {
          "suffix": "s"
        }
      }
    }
  ],
  "table_columns": [
    {
      "name": "node_ids",
      "label": "节点",
      "type": "select",
      "required": true,
      "widget_props": {
        "placeholder": "请选择节点"
      },
      "enable_row_filter": false
    },
    {
      "name": "ENV_LISTEN_PORT",
      "label": "监听端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "监听端口"
      }
    },
    {
      "name": "ENV_SQL_EXPORTER_HOST",
      "label": "主机",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "主机地址"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": ["ENV_SQL_EXPORTER_HOST", "ENV_SQL_EXPORTER_PORT"],
        "target_field": "instance_name",
        "separator": ":"
      }
    },
    {
      "name": "ENV_SQL_EXPORTER_PORT",
      "label": "端口",
      "type": "inputNumber",
      "required": true,
      "widget_props": {
        "min": 1,
        "precision": 0,
        "placeholder": "端口"
      },
      "change_handler": {
        "type": "combine",
        "source_fields": ["ENV_SQL_EXPORTER_HOST", "ENV_SQL_EXPORTER_PORT"],
        "target_field": "instance_name",
        "separator": ":"
      }
    },
    {
      "name": "instance_name",
      "label": "实例名称",
      "type": "input",
      "required": true,
      "widget_props": {
        "placeholder": "实例名称",
        "disabled": false
      }
    },
    {
      "name": "group_ids",
      "label": "组",
      "type": "group_select",
      "required": false,
      "widget_props": {
        "placeholder": "请选择组"
      }
    }
  ]
}
