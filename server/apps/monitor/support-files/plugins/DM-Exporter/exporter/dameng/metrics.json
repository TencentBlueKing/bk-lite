{
  "plugin": "DM-Exporter",
  "plugin_desc": "通过 DM-Exporter 下发达梦数据库监控探针，采集连接、会话、锁、表空间、回滚段、Redo、主备、ASM、慢查询等核心监控指标，帮助快速掌握数据库运行状态与性能变化。",
  "status_query": "any({instance_type='dameng', collect_type='exporter'}) by (instance_id)",
  "name": "Dameng",
  "icon": "cc-dameng_达梦",
  "type": "Database",
  "description": "",
  "default_metric": "any({instance_type='dameng'}) by (instance_id)",
  "instance_id_keys": [
    "instance_id"
  ],
  "supplementary_indicators": [
    "up_gauge",
    "dm_exporter_tablespace_used_ratio_gauge",
    "dm_exporter_session_used_ratio_gauge",
    "dm_exporter_lock_blocks_gauge",
    "dm_exporter_slow_query_gauge",
    "dm_exporter_backup_late_time_gauge"
  ],
  "metrics": [
    {
      "metric_group": "基础",
      "name": "up_gauge",
      "display_name": "Exporter状态",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Enum",
      "unit": "[{\"name\":\"异常\",\"id\":0,\"color\":\"#ff4d4f\"},{\"name\":\"正常\",\"id\":1,\"color\":\"#1ac44a\"}]",
      "dimensions": [],
      "description": "DM-Exporter 与达梦数据库的探测状态，0 表示抓取失败，1 表示抓取成功。",
      "query": "up_gauge{__$labels__}"
    },
    {
      "metric_group": "会话",
      "name": "dm_exporter_connections_gauge",
      "display_name": "当前连接数",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前达梦数据库会话连接总数。",
      "query": "dm_exporter_connections_gauge{__$labels__}"
    },
    {
      "metric_group": "会话",
      "name": "dm_exporter_session_rests_gauge",
      "display_name": "可用会话数",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前仍可分配的会话数量，用于评估会话资源余量。",
      "query": "dm_exporter_session_rests_gauge{__$labels__}"
    },
    {
      "metric_group": "会话",
      "name": "dm_exporter_session_used_ratio_gauge",
      "display_name": "会话使用率",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [],
      "description": "会话使用率百分比，持续升高通常意味着连接容量逼近上限。",
      "query": "dm_exporter_session_used_ratio_gauge{__$labels__}"
    },
    {
      "metric_group": "资源",
      "name": "dm_exporter_memory_used_size_gauge",
      "display_name": "内存使用量",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "mebibytes",
      "dimensions": [],
      "description": "数据库实例当前消耗的操作系统内存大小。",
      "query": "dm_exporter_memory_used_size_gauge{__$labels__}"
    },
    {
      "metric_group": "资源",
      "name": "dm_exporter_buffer_cache_hit_percent_gauge",
      "display_name": "缓存命中率",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [
        {
          "name": "HIT_NAME",
          "description": "缓存池名称"
        }
      ],
      "description": "缓存池命中率，较低时通常意味着更多磁盘访问或缓存配置不合理。",
      "query": "dm_exporter_buffer_cache_hit_percent_gauge{__$labels__}"
    },
    {
      "metric_group": "锁",
      "name": "dm_exporter_locks_gauge",
      "display_name": "获取锁的进程数",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前持有锁的进程数量。",
      "query": "dm_exporter_locks_gauge{__$labels__}"
    },
    {
      "metric_group": "锁",
      "name": "dm_exporter_lock_blocks_gauge",
      "display_name": "等待锁的进程数",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "当前等待锁且已发生阻塞的进程数量。",
      "query": "dm_exporter_lock_blocks_gauge{__$labels__}"
    },
    {
      "metric_group": "锁",
      "name": "dm_exporter_deadlock_count_gauge",
      "display_name": "死锁累计数量",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "counts",
      "dimensions": [],
      "description": "死锁历史累计数量，可用于识别并发事务冲突趋势。",
      "query": "dm_exporter_deadlock_count_gauge{__$labels__}"
    },
    {
      "metric_group": "表空间",
      "name": "dm_exporter_tablespace_total_size_gauge",
      "display_name": "表空间总大小",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "mebibytes",
      "dimensions": [
        {
          "name": "TABLESPACE_NAME",
          "description": "表空间名称"
        }
      ],
      "description": "单个表空间总容量大小。",
      "query": "dm_exporter_tablespace_total_size_gauge{__$labels__}"
    },
    {
      "metric_group": "表空间",
      "name": "dm_exporter_tablespace_used_size_gauge",
      "display_name": "表空间已使用大小",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "mebibytes",
      "dimensions": [
        {
          "name": "TABLESPACE_NAME",
          "description": "表空间名称"
        }
      ],
      "description": "单个表空间已使用空间大小。",
      "query": "dm_exporter_tablespace_used_size_gauge{__$labels__}"
    },
    {
      "metric_group": "表空间",
      "name": "dm_exporter_tablespace_free_size_gauge",
      "display_name": "表空间剩余大小",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "mebibytes",
      "dimensions": [
        {
          "name": "TABLESPACE_NAME",
          "description": "表空间名称"
        }
      ],
      "description": "单个表空间剩余可用空间大小。",
      "query": "dm_exporter_tablespace_free_size_gauge{__$labels__}"
    },
    {
      "metric_group": "表空间",
      "name": "dm_exporter_tablespace_used_ratio_gauge",
      "display_name": "表空间使用率",
      "instance_id_keys": [
        "instance_id"
      ],
      "data_type": "Number",
      "unit": "percent",
      "dimensions": [
        {
          "name": "TABLESPACE_NAME",
          "description": "表空间名称"
