{
  "object": "Dameng",
  "plugin": "DM-Exporter",
  "templates": [
    {
      "name": "实例存活状态",
      "alert_name": "达梦实例 ${resource_name} 采集异常",
      "description": "监控 DM-Exporter 对达梦实例的抓取状态，采集失败通常意味着连接异常、权限不足或 exporter 进程异常。",
      "metric_name": "up_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 0,
          "method": "<="
        }
      ]
    },
    {
      "name": "表空间使用率",
      "alert_name": "达梦实例 ${resource_name} 表空间使用率过高",
      "description": "监控表空间使用率，空间持续逼近上限可能导致写入失败或业务中断。",
      "metric_name": "dm_exporter_tablespace_used_ratio_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 95,
          "method": ">="
        },
        {
          "level": "error",
          "value": 90,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 85,
          "method": ">="
        }
      ]
    },
    {
      "name": "会话使用率",
      "alert_name": "达梦实例 ${resource_name} 会话使用率过高",
      "description": "监控数据库会话使用率，接近上限时新连接可能失败，影响业务访问。",
      "metric_name": "dm_exporter_session_used_ratio_gauge",
      "algorithm": "last_over_time",
      "threshold": [
        {
          "level": "critical",
          "value": 90,
          "method": ">="
        },
        {
          "level": "error",
          "value": 80,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 70,
          "method": ">="
        }
      ]
    },
    {
      "name": "锁等待",
      "alert_name": "达梦实例 ${resource_name} 锁等待进程偏多",
      "description": "监控等待锁的进程数量，异常上升通常表示并发冲突、长事务或 SQL 执行阻塞。",
      "metric_name": "dm_exporter_lock_blocks_gauge",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 10,
          "method": ">="
        },
        {
          "level": "error",
          "value": 5,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 1,
          "method": ">="
        }
      ]
    },
    {
      "name": "慢查询数量",
      "alert_name": "达梦实例 ${resource_name} 慢查询偏多",
      "description": "监控当前执行时长超过 2 秒的慢查询数量，异常升高通常意味着 SQL 性能劣化或资源瓶颈。",
      "metric_name": "dm_exporter_slow_query_gauge",
      "algorithm": "max",
      "threshold": [
        {
          "level": "critical",
          "value": 10,
          "method": ">="
        },
        {
          "level": "error",
          "value": 5,
          "method": ">="
        },
        {
          "level": "warning",
          "value": 1,
          "method": ">="
        }
      ]
    }
  ]
}
