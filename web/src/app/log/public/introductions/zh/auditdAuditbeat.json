{
  "overview": {
    "title": "概述",
    "paragraphs": [
      "Linux 认证日志记录了系统的所有身份验证活动，包括 SSH 远程登录、sudo 权限提升、PAM 认证等。这些日志是安全监控和入侵检测的重要数据来源。",
      "本集成使用 Auditbeat 的 System 模块采集用户登录和用户变更事件。Auditbeat 提供开箱即用的数据采集能力，无需手动编写解析规则。"
    ]
  },
  "features": {
    "title": "核心功能",
    "items": [
      {
        "icon": "🔑",
        "title": "SSH 登录监控",
        "description": "记录所有 SSH 登录尝试，包括成功和失败的登录"
      },
      {
        "icon": "⬆️",
        "title": "sudo 权限追踪",
        "description": "监控 sudo 命令的使用，记录提权操作"
      },
      {
        "icon": "📝",
        "title": "账户变更监控",
        "description": "记录用户创建、删除、密码修改等账户操作"
      }
    ]
  },
  "fieldTables": [
    {
      "title": "日志字段说明",
      "columns": [
        { "key": "field", "title": "字段名", "width": "200px" },
        { "key": "type", "title": "类型", "width": "100px" },
        { "key": "description", "title": "说明" }
      ],
      "data": [
        {
          "field": "@timestamp",
          "type": "datetime",
          "description": "事件发生时间"
        },
        {
          "field": "event.module",
          "type": "string",
          "description": "模块名称：system"
        },
        {
          "field": "event.dataset",
          "type": "string",
          "description": "数据集：login / user"
        },
        {
          "field": "event.action",
          "type": "string",
          "description": "具体操作：user_login / user_logout / user_added 等"
        },
        { "field": "user.name", "type": "string", "description": "用户名" },
        {
          "field": "source.ip",
          "type": "string",
          "description": "登录来源 IP 地址"
        },
        { "field": "host.name", "type": "string", "description": "主机名" }
      ]
    },
    {
      "title": "常见事件类型",
      "columns": [
        { "key": "action", "title": "事件动作", "width": "200px" },
        { "key": "meaning", "title": "含义", "width": "120px" },
        { "key": "example", "title": "字段示例" }
      ],
      "data": [
        {
          "action": "user_login",
          "meaning": "用户登录成功",
          "example": "event.action: user_login, event.outcome: success"
        },
        {
          "action": "user_logout",
          "meaning": "用户注销",
          "example": "event.action: user_logout"
        },
        {
          "action": "user_login (failed)",
          "meaning": "登录失败",
          "example": "event.action: user_login, event.outcome: failure"
        },
        {
          "action": "user_added",
          "meaning": "新增用户",
          "example": "event.action: user_added"
        },
        {
          "action": "user_modified",
          "meaning": "用户信息变更",
          "example": "event.action: user_modified"
        },
        {
          "action": "user_removed",
          "meaning": "用户删除",
          "example": "event.action: user_removed"
        }
      ]
    }
  ],
  "bestPractices": {
    "title": "最佳实践",
    "items": [
      "监控登录失败：频繁的登录失败可能表示暴力破解攻击，建议设置告警",
      "关注 root 登录：生产环境应禁止 root SSH 登录，检测到时立即告警",
      "追踪 sudo 使用：记录所有 sudo 命令执行，用于审计和调查",
      "启用 GeoIP：地理位置解析可以帮助识别来自异常位置的登录",
      "保留足够历史：认证日志是安全调查的重要证据，建议保留至少 90 天",
      "关联其他日志：将认证日志与系统日志、应用日志关联，获得完整的安全视图"
    ]
  }
}
