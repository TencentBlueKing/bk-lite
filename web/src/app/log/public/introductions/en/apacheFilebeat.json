{
  "overview": {
    "title": "Overview",
    "paragraphs": [
      "Apache integration uses the Filebeat Apache module to automatically collect and parse Apache HTTP server access logs and error logs. Structured log data helps you analyze traffic patterns, monitor error rates, and troubleshoot web application issues."
    ]
  },
  "features": {
    "title": "Features",
    "items": [
      {
        "icon": "📊",
        "title": "Access Log Parsing",
        "description": "Parse client IP, request method, URL, status code, response size, and other fields"
      },
      {
        "icon": "⏱️",
        "title": "Error Log Analysis",
        "description": "Capture error levels, error messages, file paths, and line numbers"
      },
      {
        "icon": "🔍",
        "title": "Geo-IP Enrichment",
        "description": "Automatic lookup of client IP geographic location"
      },
      {
        "icon": "🌍",
        "title": "User-Agent Parsing",
        "description": "Extract browser, OS, and device type information"
      }
    ]
  },
  "fieldTables": [
    {
      "title": "Access Log Fields",
      "description": "Apache access logs will be parsed into the following structured fields:",
      "columns": [
        { "key": "field", "title": "Field Name", "width": "200px" },
        { "key": "type", "title": "Type", "width": "120px" },
        { "key": "description", "title": "Description" }
      ],
      "data": [
        {
          "field": "@timestamp",
          "type": "date",
          "description": "Request timestamp"
        },
        {
          "field": "source.address",
          "type": "ip",
          "description": "Client IP address"
        },
        {
          "field": "http.request.method",
          "type": "keyword",
          "description": "HTTP method (GET, POST, etc.)"
        },
        {
          "field": "url.path",
          "type": "keyword",
          "description": "Request URL path"
        },
        {
          "field": "http.response.status_code",
          "type": "integer",
          "description": "HTTP status code"
        },
        {
          "field": "http.response.body.bytes",
          "type": "long",
          "description": "Response body size (bytes)"
        },
        {
          "field": "http.request.referrer",
          "type": "keyword",
          "description": "Referrer URL"
        },
        {
          "field": "user_agent.original",
          "type": "text",
          "description": "Original User-Agent string"
        }
      ]
    },
    {
      "title": "Error Log Fields",
      "columns": [
        { "key": "field", "title": "Field Name", "width": "200px" },
        { "key": "type", "title": "Type", "width": "120px" },
        { "key": "description", "title": "Description" }
      ],
      "data": [
        {
          "field": "@timestamp",
          "type": "date",
          "description": "Error timestamp"
        },
        {
          "field": "log.level",
          "type": "keyword",
          "description": "Error level (error, warn, notice, etc.)"
        },
        {
          "field": "apache.error.module",
          "type": "keyword",
          "description": "Apache module generating the error"
        },
        {
          "field": "message",
          "type": "text",
          "description": "Error message content"
        },
        {
          "field": "source.address",
          "type": "ip",
          "description": "Client IP (if applicable)"
        }
      ]
    }
  ]
}
