{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "dev:tauri": "node scripts/tauri-cli.mjs dev",
    "package:tauri": "node scripts/tauri-cli.mjs build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:build-config": "node --test scripts/mobile-build-config-test.mjs",
    "test:h5-deploy": "node --test scripts/mobile-h5-deploy-config-test.mjs",
    "test:h5-auth": "node --test scripts/mobile-h5-auth-test.mjs",
    "test:h5-image": "node scripts/mobile-h5-image-test.mjs",
    "clean": "rm -rf .next",
    "prepare": "husky",
    "tauri": "tauri",
    "build": "pnpm build:tauri",
    "build:tauri": "node scripts/next-build.mjs --target tauri",
    "build:h5": "node scripts/next-build.mjs --target h5",
    "build:android": "node scripts/android-build.mjs --release",
    "build:android-debug": "node scripts/android-build.mjs",
    "build:android-all": "node scripts/android-build.mjs --release --all-targets",
    "build:aab": "node scripts/android-build.mjs --aab",
    "install:android": "node scripts/android-build.mjs --install",
    "install:android-release": "node scripts/android-build.mjs --release --install"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.2",
    "@ant-design/x": "^1.6.1",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-store": "^2.4.1",
    "@types/markdown-it": "^14.1.2",
    "antd": "^5.27.4",
    "antd-mobile": "^5.41.1",
    "antd-mobile-icons": "^0.3.0",
    "dompurify": "^3.3.1",
    "intl-messageformat": "^10.7.18",
    "markdown-it": "^14.1.0",
    "next": "15.5.9",
    "next-auth": "4.24.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/env": "15.5.9",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.3",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
