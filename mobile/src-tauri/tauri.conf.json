{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "bklite-mobile",
  "version": "0.1.0",
  "identifier": "org.bklite.mobile",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://127.0.0.1:3001",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build -- --target tauri"
  },
  "app": {
    "windows": [
      {
        "title": "bklite-mobile",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
